---
import Base from '../layouts/Base.astro';
import Step from '../components/Step.astro';
import WeekNav from '../components/WeekNav.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sections = [
  { id: 'why', label: 'ทำไมต้องรู้เรื่องเสา' },
  { id: 'pattern', label: '🎬 Radiation pattern' },
  { id: 'types', label: 'ชนิดสายอากาศ' },
  { id: 'walkdip', label: '🧪 โจทย์: ไดโพล' },
  { id: 'gain', label: 'เกน + พื้นที่ประสิทธิผล' },
  { id: 'walkdish', label: '🧪 โจทย์: จานพาราโบลา' },
  { id: 'reg', label: 'ใครคุมคลื่น (กสทช)' },
  { id: 'prop', label: '🎬 การแพร่ 3 โหมด' },
  { id: 'los', label: 'สมการเส้นสายตา' },
  { id: 'walklos', label: '🧪 โจทย์: เสาสูงเท่าไหร่' },
  { id: 'fsl', label: '🎬 Free space loss' },
  { id: 'friis', label: 'Friis + เกน (คืนสู่ link budget)' },
  { id: 'hwsat', label: '📝 การบ้านครั้งที่ 2 (ของจริง)' },
  { id: 'next', label: '⏳ ที่เหลือของ Week 4' },
  { id: 'fast', label: '⚡ คิดไวในห้องสอบ' },
  { id: 'code', label: '💻 โค้ดรันได้' },
  { id: 'exam', label: '✸ ข้อสอบจับเวลา' },
  { id: 'check', label: 'เช็กเข้าใจ' },
  { id: 'summary', label: 'สรุป' },
];
---
<Base title="Week 4 — สายอากาศและการแพร่กระจายคลื่น">
  <main class="wrap">
    <div class="crumb"><a href={`${base}/`}>หน้าแรก</a> / Week 4</div>
    <h2>Week 4 · สายอากาศและการแพร่กระจายคลื่น</h2>
    <p class="hint">Radiation pattern · ชนิดสายอากาศ · เกน/พื้นที่ประสิทธิผล · Ground/Sky/LOS · สมการเส้นสายตา · Free space loss · Friis — เรียบเรียงจาก<b>คาบบรรยายจริง (15 ก.ค.) + สไลด์</b> · กล่องส้ม 🎙 = ที่อาจารย์พูดนอกสไลด์ · ⚠️ <b>คาบนี้อาจารย์สอนถึงสมการ Friis (สไลด์ ~40/88)</b> — หัวข้อที่เหลือ (path loss exponent, noise, fading, MIMO) จะเติมเมื่อเรียนต่อ</p>

    <div class="shell">
      <WeekNav week={4} sections={sections} />
      <div class="lesson-main">

        <!-- ============ 1 ============ -->
        <Step kind="real" icon="🎯" title="สามสัปดาห์แรกคือ 'ข้างใน' — สัปดาห์นี้คลื่นออกสู่อากาศจริง" id="why">
          <p>Week 1 ให้เครื่องมือ (dB) · Week 2 ให้แผนที่ (โพรโทคอล/สวิตชิง) · Week 3 ให้ตัวคลื่นและเพดานของมัน (Nyquist/Shannon) — แต่ทั้งหมดยังไม่ตอบคำถามพื้นฐานสุด: <b>คลื่นออกจากเครื่องไปลอยในอากาศได้ยังไง แล้วมันเดินทางแบบไหนกว่าจะถึงปลายทาง?</b> คำตอบคือพระเอกของสัปดาห์นี้: <span class="term">สายอากาศ (antenna)</span></p>
          <p>นิยามจากสไลด์: สายอากาศคือ<b>ตัวนำสัญญาณทางไฟฟ้า หรือระบบของตัวนำ</b> ทำงานสองขา:</p>
          <ul>
            <li><b>ขาส่ง</b> — เปลี่ยนพลังงานไฟฟ้าให้เป็น<b>คลื่นแม่เหล็กไฟฟ้าแผ่ออกไปในอากาศ</b></li>
            <li><b>ขารับ</b> — <b>รวบรวม</b>พลังงานคลื่นแม่เหล็กไฟฟ้าจากอากาศกลับมาเป็นสัญญาณไฟฟ้า</li>
          </ul>
          <p>และประโยคสำคัญที่ออกสอบเชิงทฤษฎีได้: <b>ในการสื่อสาร 2 ทาง สายอากาศอันเดียวกันใช้ได้ทั้งส่งและรับ</b></p>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — เสาเดียวส่ง+รับ แต่ "ไม่ใช่เวลาเดียวกัน"</span>
          อาจารย์ยกวอล์กี้ทอล์กี้ (walkie-talkie): เสาต้นเดียวที่เห็น ใช้ทั้งรับทั้งส่ง — แล้วถามห้องว่า "ส่งกับรับ<b>พร้อมกัน</b>ได้ไหม?" … ไม่ได้! นั่นคือเหตุผลที่วอล์กี้ทอล์กี้ต้องกดปุ่มค้างเวลาพูด (<b>สลับส่ง-สลับรับ</b>) · มือถือเราก็หลักการเดียวกัน — เสาอากาศซ่อนอยู่ในเครื่อง ใช้ร่วมกันระหว่างรับ/ส่งด้วยเทคนิคแบ่งเวลา/ความถี่ (โยงกลับ FDM/TDM ของ Week 3 เป๊ะ ๆ)</div>
          <p class="why">ทำไมวิศวกรคอมต้องแคร์? เพราะทุกดีไซน์ไร้สายชนคำถามชุดเดียวกัน: เสาแบบไหน (รอบทิศหรือเล็งเป้า) · ตั้งสูงเท่าไหร่ (โลกโค้ง!) · ส่งกี่วัตต์ถึงจะรอดระยะทาง — สามคำถามนี้คือสามก้อนใหญ่ของบทนี้ และทุกก้อนจบด้วยสูตรที่คำนวณได้จริงในข้อสอบ</p>
        </Step>

        <!-- ============ 2 ============ -->
        <Step kind="anim" icon="📡" title="Radiation pattern — สายอากาศ 'สาดพลังงาน' หน้าตาแบบไหน" id="pattern">
          <p>ศัพท์ชุดแรกของบท (สไลด์ 3): <span class="term">แบบรูปการแผ่พลังงาน (radiation pattern)</span> = การแสดง<b>เป็นรูปกราฟิก</b>ว่าสายอากาศแผ่คลื่นไปทิศไหนแรงแค่ไหน — ปกติวาดเป็น<b>ภาพตัดขวาง (ผ่ากลาง) 2 มิติ</b> ของรูปทรง 3 มิติจริง · ฝั่งรับก็มี <b>reception pattern</b> ซึ่ง<b>เหมือนกับแบบรูปการแผ่ของตัวเดียวกัน</b> (ส่งเก่งทางไหน รับก็เก่งทางนั้น)</p>
          <p>คำที่ต้องชี้ได้บนรูป:</p>
          <ul>
            <li><b>พูหลัก (main lobe)</b> — ก้อนพลังงานใหญ่สุด ทิศที่สายอากาศ "ตั้งใจ" ยิง</li>
            <li><b>พูข้าง (sidelobes)</b> — พลังงาน<b>ส่วนเกิน</b>ที่เล็ดออกทิศอื่นนอกพูหลัก (ของแถมที่ไม่ได้อยากได้)</li>
            <li><b>นัลล์ (nulls)</b> — ทิศที่พลังงาน<b>น้อยมาก</b> ระหว่างพูหลักกับพูข้าง (จุดบอด)</li>
            <li><b>ความกว้างลำ (beam width)</b> — ตัววัด "ความเป็นทิศทาง": มุมกว้างของพูหลัก วัดที่จุดซึ่งกำลัง<b>ลดลงครึ่งหนึ่ง (−3 dB / half-power point)</b></li>
          </ul>
          <div class="lab">
            <h4>🎬 กดเล่นทีละขั้น — จากวงกลมอุดมคติ ถึงลำคลื่นพุ่งเป้า</h4>
            <div id="antStepper"></div>
          </div>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — จุด −3 dB โผล่อีกแล้ว</span>
          ความกว้างลำวัดที่ "<b>จุดกำลังหายไปครึ่งหนึ่ง</b>" ซึ่งภาษาไฟฟ้าเรียก half-power point — คุ้นไหม? คือ <b>3 dB</b> ตัวเดียวกับการบ้าน Week 1 ("Loss 3 dB = หายครึ่ง") เป๊ะ ๆ · อาจารย์ยังชี้ pattern ตัวอย่างว่า: สัญญาณแผ่ไป<b>ทางขวาเยอะ</b> ข้างหลังแทบไม่มี — ใครยืนนอกพู "รับสัญญาณไม่ได้เลย" ทั้งที่อยู่ใกล้กว่า คนอยู่ในพูที่ไกลกว่า</div>
        </Step>

        <!-- ============ 3 ============ -->
        <Step kind="deep" icon="🗼" title="ชนิดสายอากาศ 4 ตระกูล + ไดโพลคำนวณได้จริง" id="types">
          <p>สไลด์ 6 แบ่งสายอากาศที่ใช้กันเป็น 4 แบบหลัก — ไล่จากอุดมคติไปหาของจริง:</p>
          <ul>
            <li><b>ไอโซทรอปิก (isotropic antenna)</b> — แผ่พลังงาน<b>เท่ากันทุกทิศทาง</b> (ทรงกลมสมบูรณ์)</li>
            <li><b>ไดโพล (dipole antenna)</b> — เสาตรง ๆ สองแบบ: <b>ครึ่งคลื่น (half-wave dipole)</b> หรือชื่อเล่น <b>Hertz antenna</b> ความยาว L = λ/2 · และ<b>หนึ่งส่วนสี่คลื่นแนวตั้ง (quarter-wave vertical)</b> หรือ <b>Marconi antenna</b> ความยาว L = λ/4 (เสียบตั้งบนพื้น ใช้พื้นดินเป็นกระจกสะท้อนอีกครึ่ง)</li>
            <li><b>จานสะท้อนพาราโบลา (parabolic reflective antenna)</b> — ใช้ผิวโค้งพาราโบลารวมคลื่นเข้า<b>จุดโฟกัส</b></li>
            <li><b>แบบมีทิศทาง (directional antenna)</b> — เอาสายอากาศหลายต้นมาเรียงเป็น<b>แถว (array)</b> แล้วปรับ<b>แอมพลิจูดและเฟส</b>ของแต่ละต้นเพื่อ "ปั้น" ทิศทางลำคลื่น — สไลด์ย้ำว่า<b>ใช้งานมากในระบบสมัยใหม่</b> (5G beamforming คือหลานแท้ ๆ ของไอเดียนี้)</li>
          </ul>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — isotropic สร้างได้ไหม + โดนัทไม่มีรู</span>
          "สายอากาศที่แผ่เท่ากันทุกทิศ <b>สร้างจริงได้ไหม?</b> … ไม่ได้!" (แค่มีสายไฟต่อเข้าไปก็เสียความสมมาตรแล้ว) — isotropic เป็นสายอากาศ<b>อุดมคติ</b> เอาไว้เป็น<b>ตัวอ้างอิง</b>ว่าสายอากาศจริงตัวไหน "ขยายกว่ามัน" กี่เท่า (นี่คือที่มาของเกนในหัวข้อถัดไป) · ส่วน pattern ของไดโพล อาจารย์ให้นึกภาพ 3 มิติ: หมุนเลข 8 รอบแกนเสา → ได้ทรง<b>"โดนัทที่ไม่มีรู"</b> — แรงสุดรอบเอว เงียบสนิทหัวท้าย · มองจากบนลงมา (top view) เป็น<b>วงกลม</b> = คำว่า <b>omnidirectional "รอบทิศในระนาบเดี่ยว"</b> ที่ Week 3 ทิ้งไว้ (Wi-Fi ในบ้านเราคือแบบนี้แหละ)</div>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — จานพาราโบลา = ไฟฉายกลับด้าน</span>
          จานที่เห็นตามบ้าน "<b>ตัวจานไม่ได้รับสัญญาณนะ</b> — มันแค่<b>สะท้อน</b>" คลื่นที่ตกลงบนผิวโค้งทุกจุดจะเด้งไปรวมที่<b>จุดโฟกัส</b> ซึ่งเป็นที่อยู่ของ<b>หัวรับจริง (ก้านที่ยื่นออกมาหน้าจาน)</b> · หลักการเดียวกับ<b>ไฟฉาย</b>แต่กลับทิศ: หลอดไฟเปล่า ๆ สาดแสงรอบทิศ พอมีกรวยสะท้อนข้างหลัง แสงถูกบีบพุ่งไปข้างหน้า — ยากิ (Yagi) ที่เป็นก้าง ๆ บนหลังคาก็อยู่ตระกูล directional เหมือนกัน (เสาทีวีสมัยก่อน)</div>
          <div class="lab">
            <h4>🗼 Dipole Lab — ความถี่กำหนดขนาดเสา (λ = c/f คุมทุกอย่าง)</h4>
            <div class="sine-controls" style="grid-template-columns:1fr">
              <label>ความถี่ f = <b><span id="lblDipF"></span></b><input type="range" id="dipF" min="30" max="2400" step="10" value="100" /></label>
            </div>
            <div id="dipSvg"></div>
            <div class="enc-cap" id="dipOut"></div>
            <div class="btnrow">
              <button class="btn ghost" data-dip="100">โจทย์ครู: FM 100 MHz</button>
              <button class="btn ghost" data-dip="30">วิทยุ 30 MHz (λ = 10 m)</button>
              <button class="btn ghost" data-dip="900">มือถือ 900 MHz</button>
              <button class="btn ghost" data-dip="2400">WiFi 2.4 GHz</button>
            </div>
          </div>
          <p class="why">เลื่อนแล้วเห็นชัด: <b>ความถี่ยิ่งสูง เสายิ่งจิ๋ว</b> — เหตุผลเดียวกับที่ Week 3 เฉลยว่าทำไมเสา WiFi ซ่อนในมือถือได้แต่เสาวิทยุ AM สูงเป็นสิบเมตร ตอนนี้ได้สูตรเป๊ะ ๆ แล้ว: ขนาดเสา "ล็อก" กับ λ/2 หรือ λ/4</p>
        </Step>

        <!-- ============ 4 ============ -->
        <Step kind="check" icon="🧪" title="โจทย์ที่อาจารย์ทำสด #1 — ไดโพลครึ่งคลื่นรับ 100 MHz ยาวกี่เมตร" id="walkdip">
          <p>โจทย์แรกของบท (สไลด์ 8) อาจารย์เดินบนกระดานทีละขั้น — เดินตามพร้อมกับดักที่อาจารย์ดักไว้:</p>
          <div id="walkDipole"></div>
        </Step>

        <!-- ============ 5 ============ -->
        <Step kind="deep" icon="📈" title="เกนสายอากาศ + พื้นที่ประสิทธิผล — 'ขยาย' โดยไม่ใส่พลังงานเพิ่มได้ยังไง" id="gain">
          <p><span class="term">อัตราขยายสายอากาศ (antenna gain, G)</span> = พลังงานขาออก<b>ในทิศทางเฉพาะ</b> เทียบกับพลังงานที่สายอากาศ<b>ไอโซทรอปิก</b> (ตัวอ้างอิงอุดมคติ) สร้างในทุกทิศทาง — ระวังความหมาย: สายอากาศ<b>ไม่ได้สร้างพลังงานเพิ่ม</b> มันแค่<b>บีบพลังงานก้อนเดิมให้พุ่งทางเดียว</b> (เหมือนไฟฉาย: หลอดวัตต์เท่าเดิม แต่จ้ากว่าเพราะรวมแสง) — นี่คือสิ่งที่เห็นในขั้น 5 ของ animation แรก</p>
          <p>คู่หูของเกนคือ <span class="term">พื้นที่ประสิทธิผล (effective area, Ae)</span> — "ขนาดมือ" ที่สายอากาศใช้กอบเก็บคลื่นจากอากาศ สัมพันธ์กับขนาด/รูปร่างทางกายภาพ และผูกกับเกนด้วยสมการ (สไลด์ 16):</p>
          <div class="formula">G = 4π·Ae / λ²  =  4π·f²·Ae / c²
G = เกน (ไม่มีหน่วย!) · Ae = พื้นที่ประสิทธิผล (m²) · f = ความถี่ (Hz) · λ = ความยาวคลื่น (m)</div>
          <p>ตาราง Antenna Gains and Effective Areas (สไลด์ 17 — <b>ตารางนี้คือคลังสูตรของข้อสอบ</b>):</p>
          <table class="tbl">
            <thead><tr><th>ชนิดสายอากาศ</th><th>พื้นที่ประสิทธิผล Ae</th><th>เกน G (เทียบ isotropic)</th></tr></thead>
            <tbody>
              <tr><td>ไอโซทรอปิก</td><td>λ²/4π</td><td><b>1</b> (ตัวอ้างอิง)</td></tr>
              <tr><td>ไดโพลเล็กมาก หรือแบบบ่วง (loop)</td><td>1.5·λ²/4π</td><td>1.5</td></tr>
              <tr><td>ไดโพลครึ่งคลื่น</td><td>1.64·λ²/4π</td><td>1.64</td></tr>
              <tr><td>ปากแตร (Horn) หน้าตัด A</td><td>0.81·A</td><td>10A/λ²</td></tr>
              <tr><td>พาราโบลา หน้าตัด A</td><td><b>0.56·A</b></td><td><b>7A/λ²</b></td></tr>
              <tr><td>กากบาท (Turnstile)</td><td>1.15·λ²/4π</td><td>1.15</td></tr>
            </tbody>
          </table>
          <div class="note">⚠️ <b>สามกับดักที่อาจารย์ประกาศกลางห้อง:</b> (1) <b>G เพล่า ๆ ไม่มีหน่วย</b> — "ใครใส่หน่วยเป็น dB ตรงนี้ปุ๊บ จบเลยนะ" จะเป็น dB ต่อเมื่อกด 10·log₁₀ แล้วเท่านั้น · (2) สูตรเกนของจาน/ปากแตรใช้ <b>A พื้นที่หน้าตัดจริง ไม่ใช่ Ae</b> — เอา Ae ไปแทน "ผิดเลย" · (3) ไดโพลเป็นเส้น ไม่มีพื้นที่หน้าตัด — <b>ใช้ค่าจากตารางตรง ๆ</b> ไม่ต้องหาสูตรพื้นที่</div>
          <div class="lab">
            <h4>📈 Gain Lab — เลือกชนิด + ความถี่ (+ ขนาดจาน) ดู Ae/G สด</h4>
            <div class="sine-controls">
              <label>ชนิดสายอากาศ
                <select id="gainType" style="width:100%">
                  <option value="para" selected>จานพาราโบลา</option>
                  <option value="horn">ปากแตร (Horn)</option>
                  <option value="half">ไดโพลครึ่งคลื่น</option>
                  <option value="loop">ไดโพลเล็กมาก/บ่วง</option>
                  <option value="turn">กากบาท (Turnstile)</option>
                  <option value="iso">ไอโซทรอปิก (อ้างอิง)</option>
                </select></label>
              <label>ความถี่ f = <b><span id="lblGainF"></span> GHz</b><input type="range" id="gainF" min="0.5" max="30" step="0.5" value="12" /></label>
              <label id="gainDWrap">เส้นผ่านศูนย์กลาง Ø = <b><span id="lblGainD"></span> m</b><input type="range" id="gainD" min="0.5" max="5" step="0.1" value="2" /></label>
            </div>
            <div class="enc-cap" id="gainOut" style="min-height:4.4em"></div>
          </div>
          <p class="why">ลองสลับชนิดดู: จานที่ f สูง ๆ เกนทะลุหมื่นเท่า แต่ไดโพลนิ่งอยู่ 1.64 ตลอด — เพราะจานมี "พื้นที่กายภาพ" ให้เก็บคลื่น ยิ่ง λ สั้นเทียบกับจาน ยิ่งบีบลำได้แคบ · สังเกตอีกอย่าง: <b>ชนิดเดียวกัน ความถี่สูงขึ้น → เกนขึ้น</b> นี่คือเหตุผลที่จานดาวเทียม (GHz) ตัวเล็กกว่าจานเรดาร์ความถี่ต่ำมหาศาล</p>
        </Step>

        <!-- ============ 6 ============ -->
        <Step kind="check" icon="🧪" title="โจทย์ที่อาจารย์ทำสด #2 — จานพาราโบลา Ø 2 m ที่ 12 GHz" id="walkdish">
          <p>โจทย์เต็มทรงข้อสอบ (สไลด์ 18): หา Ae เป็นตารางเมตร และเกนเป็น dB — ข้อนี้อาจารย์เก็บกับดักไว้ครบทุกจุด:</p>
          <div id="walkDish"></div>
        </Step>

        <!-- ============ 7 ============ -->
        <Step kind="real" icon="⚖️" title="แถมจากสไลด์: คลื่นเป็นสมบัติชาติ — ใครอยากใช้ต้องขอ กสทช" id="reg">
          <p>สไลด์ 14 "ข้อควรพิจารณาของสเปกตรัม": ในไทย สเปกตรัมถูกควบคุมโดย <b>กสทช</b> ใน 3 มิติ:</p>
          <ul>
            <li><b>ความถี่ของสัญญาณ</b> — ใครใช้ย่านไหน (จำเรื่อง "การเมืองของคลื่น" ใน Week 3 ได้ไหม — นี่ไง หน่วยงานตัวจริง)</li>
            <li><b>กำลังส่ง</b> — แรงได้แค่ไหน</li>
            <li><b>วิธีเข้าถึงหลายทาง (Multiple Access Control)</b> — แบ่งกันใช้ยังไง: ต่างเวลา = <b>TDMA</b> · ต่างความถี่ = <b>FDMA</b> · ต่างรหัส = <b>CDMA</b> (สองตัวแรกคือญาติตรงของ TDM/FDM ที่เพิ่งเรียน — เวอร์ชัน "หลายคนเข้าถึงสื่อ" จะเจอเต็ม ๆ ในบทหลัง)</li>
          </ul>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — ทำไมต้องคุม "กำลังส่ง" ด้วย</span>
          ส่งแรง ๆ ดีไม่ใช่เหรอ? ไปได้ไกลดี — "แต่<b>กวนคนอื่นไหมล่ะ?</b>" สัญญาณแรงของเราคือ noise ของเพื่อนบ้านที่ใช้ย่านใกล้กัน (นึกถึง SNR ของ Week 3: S ของเรา = N ของเขา) กสทช เลยต้องคุมทั้งความถี่และวัตต์พร้อมกัน</div>
        </Step>

        <!-- ============ 8 ============ -->
        <Step kind="anim" icon="🌍" title="คลื่นเดินทาง 3 โหมด — ความถี่เป็นตัวเลือกเส้นทาง" id="prop">
          <p>ปล่อยคลื่นออกจากเสาแล้วมันไปยังไงต่อ? สไลด์ 19 ตอบว่า<b>แล้วแต่ความถี่</b> — มี 3 แบบแผนการแพร่กระจาย (propagation modes):</p>
          <div class="lab">
            <h4>🎬 กดเล่น — ดูทั้งสามโหมดบนโลกโค้ง</h4>
            <div id="propStepper"></div>
          </div>
          <table class="tbl">
            <thead><tr><th>โหมด</th><th>ความถี่</th><th>กลไก</th><th>ตัวอย่างใช้จริง</th></tr></thead>
            <tbody>
              <tr><td><b>คลื่นดิน (ground wave)</b></td><td>สูงสุด <b>2 MHz</b></td><td>เกาะผิวโลก <b>โค้งตามความโค้งของโลก</b>ได้ → ระยะทางค่อนข้างไกล</td><td><b>วิทยุ AM</b></td></tr>
              <tr><td><b>คลื่นฟ้า (sky wave)</b></td><td>2 – 30 MHz</td><td><b>สะท้อนชั้นไอโอโนสเฟียร์</b> (ชั้นบรรยากาศที่มีไอออน) กลับสู่โลก เด้งไป-มาได้หลายช่วง (hop) — ที่จริงผลสะท้อนเกิดจาก<b>การหักเห</b></td><td><b>วิทยุสมัครเล่น</b> วิทยุสื่อสารประชาชน</td></tr>
              <tr><td><b>เส้นสายตา (line-of-sight, LOS)</b></td><td>มากกว่า <b>30 MHz</b></td><td>วิ่ง<b>เส้นตรง</b> — เสาส่งกับเสารับต้อง "มองเห็นกัน" · ความถี่เกิน 30 MHz <b>ไม่สะท้อนไอโอโนสเฟียร์แล้ว</b></td><td><b>ดาวเทียม</b> · ไมโครเวฟภาคพื้นดิน · มือถือ/WiFi</td></tr>
            </tbody>
          </table>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — ตัวเลขที่อาจารย์ผูกเรื่องให้จำง่าย</span>
          ทำไมวิทยุ AM ไปไกล? เพราะความถี่ AM อยู่แถว <b>~1 MHz</b> → ต่ำกว่า 2 MHz → ได้โหมดคลื่นดิน โค้งตามผิวโลกไปเรื่อย ๆ · ส่วนวิทยุสมัครเล่น/วอล์กี้ทอล์กี้บางรุ่นใช้แถว <b>~28 MHz</b> — ยังไม่เกิน 30 เลยเด้งฟ้าได้ ("ขึ้นฟ้าก็ได้") คุยข้ามจังหวัดด้วยเครื่องเล็ก ๆ · แต่พอเกิน 30 MHz ทุกอย่างที่เราใช้ทุกวันนี้ (มือถือ WiFi ดาวเทียม) <b>บังคับเส้นตรงหมด</b> → เจอปัญหาใหม่ทันที: <b>โลกมันโค้ง</b> — ต้องทำเสาสูง ซึ่งพาไปสูตรถัดไป</div>
        </Step>

        <!-- ============ 9 ============ -->
        <Step kind="deep" icon="🔭" title="สมการเส้นสายตา — เสาสูง h เห็นไกลแค่ไหน (และทำไมวิทยุ 'เห็น' ไกลกว่าตา)" id="los">
          <p>โลกโค้ง → ยิ่งไกล ขอบโลกยิ่งบังเส้นตรง → ระยะ LOS ถูกจำกัดด้วย<b>ความสูงของเสา</b> สไลด์ 27 ให้สองสูตร:</p>
          <div class="formula">ขอบฟ้าของ "แสง" (ตามอง):      d = 3.57·√h
ขอบฟ้าของ "คลื่นวิทยุ":        d = 3.57·√(K·h)     โดย K = 4/3
d = ระยะถึงขอบฟ้า (กิโลเมตร!) · h = ความสูงสายอากาศ (เมตร!) — หน่วยไม่เท่ากัน จงระวัง</div>
          <p><b>ทำไมวิทยุไปไกลกว่าแสง?</b> เพราะ<b>การหักเห (refraction)</b>: ความเร็วคลื่นแม่เหล็กไฟฟ้าเป็นฟังก์ชันของความหนาแน่นตัวกลาง — อากาศชั้นล่างหนากว่าชั้นบน คลื่นเลย<b>โค้งงอลงเล็กน้อย</b>ตามผิวโลก (เหมือนวิ่งเลนในทรายข้างหนึ่ง ถนนข้างหนึ่ง — ตัววิ่งจะเบี้ยวเข้าหาฝั่งช้า) ผลคือ "โลกเสมือนแบนลงนิดหน่อย" คิดเป็นตัวคูณ <b>K = 4/3</b> ในสูตร</p>
          <p>สองเสาช่วยกัน (สไลด์ 28) — ระยะไกลสุดระหว่างเสาสูง h₁ กับ h₂:</p>
          <div class="formula">d = 3.57·(√(K·h₁) + √(K·h₂))     ← ขอบฟ้าของสองฝั่ง "ยื่นมาแตะกัน"</div>
          <div class="lab">
            <h4>🔭 LOS Lab — เลื่อนความสูงเสา ดูระยะขอบฟ้าวิทยุ</h4>
            <div class="sine-controls" style="grid-template-columns:1fr 1fr">
              <label>เสาส่ง h₁ = <b><span id="lblLosH1"></span> m</b><input type="range" id="losH1" min="0" max="200" step="5" value="100" /></label>
              <label>เสารับ h₂ = <b><span id="lblLosH2"></span> m</b><input type="range" id="losH2" min="0" max="60" step="1" value="0" /></label>
            </div>
            <div class="btnrow">
              <button class="btn" data-losk="radio">คลื่นวิทยุ (K = 4/3)</button>
              <button class="btn ghost" data-losk="opt">แสง/ตามอง (K = 1)</button>
            </div>
            <div id="losSvg"></div>
            <div class="enc-cap" id="losOut"></div>
          </div>
          <p class="why">ตั้ง h₁ = 100, h₂ = 0 คือโจทย์ครูข้อถัดไปพอดี (~41 กม.) — แล้วลองเลื่อน h₂ ขึ้นนิดเดียว จะเห็นระยะพุ่งเร็วช่วงแรก (เพราะ √h ชันตอน h เล็ก) นี่คือเหตุผลที่ "ยกเสารับขึ้นนิดเดียว ประหยัดความสูงเสาส่งได้เยอะ"</p>
        </Step>

        <!-- ============ 10 ============ -->
        <Step kind="check" icon="🧪" title="โจทย์ที่อาจารย์ทำสด #3 — เสาส่ง 100 เมตร ส่งได้ไกลเท่าไหร่" id="walklos">
          <p>โจทย์สองต่อ (สไลด์ 29): ข้อ (ก) ตรงสูตร ข้อ (ข) กลับด้าน — ทรงนี้ออกสอบบ่อยเพราะวัดว่าย้ายข้างสมการเป็นไหม:</p>
          <div id="walkLOS"></div>
        </Step>

        <!-- ============ 11 ============ -->
        <Step kind="anim" icon="🌌" title="Free space loss — ทำไมสัญญาณหายทั้งที่ไม่มีอะไรขวาง" id="fsl">
          <p>สัญญาณเดินทางใน "อวกาศว่าง" ไม่มีตึก ไม่มีฝน ไม่มีอะไรดูดซับเลย — <b>ก็ยังอ่อนลงอยู่ดี</b> ทำไม? สไลด์ 33 เปิดเรื่องการลดทอน (attenuation): ความแรงสัญญาณตกลงตามระยะทาง ฝั่งรับต้องแรงพอให้วงจร (1) ประมวลผลได้ และ (2) สูงกว่า noise พอที่จะไม่ผิดพลาด · สาเหตุหลักในอวกาศว่างไม่ใช่ "อะไรมากิน" สัญญาณ แต่คือ<b>เรขาคณิตล้วน ๆ</b>:</p>
          <div class="lab">
            <h4>🎬 กดเล่น — พลังงานก้อนเดิม เกลี่ยบนทรงกลมที่โตขึ้นเรื่อย ๆ</h4>
            <div id="fslStepper"></div>
          </div>
          <p>เขียนเป็นสูตร (สไลด์ 34) — <span class="term">ความสูญเสียในอวกาศว่าง (free space loss)</span> สำหรับสายอากาศไอโซทรอปิกอุดมคติ:</p>
          <div class="formula">Loss = Pₜ/Pᵣ = (4πd)²/λ² = (4πfd)²/c²        (ไม่มีหน่วย — เป็นอัตราส่วน)
Pₜ, Pᵣ = กำลังส่ง/รับ (W) · d = ระยะห่างส่ง-รับ · λ = ความยาวคลื่นพาห์
⚠️ d กับ λ ต้องหน่วยเดียวกัน (เช่น เมตรทั้งคู่)</div>
          <p>และร่าง dB (สไลด์ 35) ที่ใช้จริงในโจทย์ทุกข้อ:</p>
          <div class="formula">L(dB) = 10·log(Pₜ/Pᵣ) = 20·log(4πd/λ)
      = −20·log(λ) + 20·log(d) + 21.98 dB          ← ร่างที่ใช้ λ
      = 20·log(f) + 20·log(d) − 147.56 dB          ← ร่างที่ใช้ f (จำตัวนี้!)</div>
          <p class="why">อ่านสูตรให้ออก 2 ประเด็น: (1) <b>d อยู่ใน log ×20</b> → ระยะ ×2 = loss เพิ่ม 6.02 dB, ×10 = +20 dB — ไม่ได้แย่ลงเชิงเส้น! (2) <b>f ก็อยู่ใน ×20</b> → ความถี่สูงขึ้น loss มากขึ้นเท่า ๆ กับระยะเลย — "ความถี่สูงวิ่งได้ไม่ไกล" ที่อาจารย์พูดตั้งแต่ Week 3 ตอนนี้มีสูตรยืนยันแล้ว (5G ย่าน mmWave ถึงต้องตั้งเสาถี่ยิบ)</p>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — อ่านกราฟสไลด์ 39 ให้เป็น</span>
          อาจารย์ชี้กราฟ Loss–ระยะทาง (ขั้น 5 ใน animation): "ยิ่งความถี่สูง loss ยิ่งเยอะ · ระยะทางยิ่งไกล loss ยิ่งเยอะ" — เส้นทุกเส้นขนานกันหมดบนแกน log (ชัน 20 dB ต่อระยะ ×10 เท่ากัน) ต่างกันแค่ "ยกตัว" ตามความถี่ · ที่ความถี่สูงชดเชยได้ด้วยเกนสายอากาศที่สูงขึ้น (จานเล็กแต่เกนแรง — เห็นจาก Gain Lab แล้ว)</div>
        </Step>

        <!-- ============ 12 ============ -->
        <Step kind="deep" icon="🔗" title="สมการฟรีส (Friis) — ใส่เกนเข้าไป แล้ว Week 1 กลับมาครบวง" id="friis">
          <p>โลกจริงไม่ได้ใช้ isotropic — เสาส่งมีเกน Gₜ เสารับมีเกน Gᵣ สไลด์ 36 เขียนความสัมพันธ์กำลังส่ง-รับเป็น<b>สมการอวกาศว่างฟรีส (Friis free space equation)</b>:</p>
          <div class="formula">Pᵣ = Pₜ·Gₜ·Gᵣ·λ² / (4πd)²           และร่างทั่วไป:   Pᵣ = Pₜ·Gₜ·Gᵣ / L
→ Loss รวมเกน:  L_G = Pₜ·Gₜ·Gᵣ/Pᵣ … เขียนแบบแยกส่วนได้:  L_G = L_ISO / (Gₜ·Gᵣ)
ในหน่วย dB:      L_G(dB) = 20·log f + 20·log d − 147.56 − Gₜ(dB) − Gᵣ(dB)
                 = L_ISO(dB) − Gₜ(dB) − Gᵣ(dB)</div>
          <p>อ่านเป็นภาษาคน: <b>loss ตั้งต้นเท่าเดิม (เรขาคณิตไม่เปลี่ยน) แต่เกนของสองฝั่ง "หักคืน" ให้เป็น dB ตรง ๆ</b> — สังเกตว่านี่คือ<b>ตาราง link budget ของ Week 1 เป๊ะ ๆ</b>: เริ่มจากกำลังส่ง (dBW) → ลบ loss → บวกเกนเสา → ได้กำลังรับ ตอนนั้นเราได้ตัวเลข loss มาแบบ "โจทย์กำหนดให้" ตอนนี้เรา<b>คำนวณ loss เองได้แล้ว</b>จากระยะทางกับความถี่ — จิ๊กซอว์ต่อสนิท</p>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — สูตรไหนเป็นหลัก</span>
