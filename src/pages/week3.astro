---
import Base from '../layouts/Base.astro';
import Step from '../components/Step.astro';
import WeekNav from '../components/WeekNav.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sections = [
  { id: 'why', label: 'ทำไมไร้สายถึงยาก' },
  { id: 'em', label: 'สัญญาณแม่เหล็กไฟฟ้า' },
  { id: 'timedomain', label: 'โดเมนเวลา: ศัพท์ครบ' },
  { id: 'sinewave', label: '🎬 คลื่นไซน์ 3 ปุ่มหมุน' },
  { id: 'timedist', label: 'เวลา vs ระยะทาง' },
  { id: 'freqdomain', label: '🎬 โดเมนความถี่' },
  { id: 'bwdata', label: 'แบนด์วิดท์ vs ข้อมูล' },
  { id: 'datasig', label: 'ข้อมูล vs สัญญาณ' },
  { id: 'hwtable', label: '📝 การบ้านตาราง' },
  { id: 'transmission', label: '🎬 Amplifier vs Repeater' },
  { id: 'capacity', label: 'ความจุช่องสัญญาณ' },
  { id: 'nyquist', label: 'Nyquist' },
  { id: 'snr', label: 'SNR (คืนสู่ dB!)' },
  { id: 'shannon', label: 'Shannon' },
  { id: 'worked', label: '🧪 โจทย์เดินสด + เครื่องคิด' },
  { id: 'media', label: 'สื่อนำ/ไม่นำสัญญาณ' },
  { id: 'spectrum', label: 'สเปกตรัม: ใครใช้คลื่นไหน' },
  { id: 'mux', label: '🎬 Multiplexing FDM/TDM' },
  { id: 'fast', label: '⚡ คิดไวในห้องสอบ' },
  { id: 'code', label: '💻 โค้ดรันได้' },
  { id: 'exam', label: '✸ ข้อสอบจับเวลา' },
  { id: 'check', label: 'เช็กเข้าใจ' },
  { id: 'summary', label: 'สรุป' },
];
---
<Base title="Week 3 — คลื่นไร้สายของจริง">
  <main class="wrap">
    <div class="crumb"><a href={`${base}/`}>หน้าแรก</a> / Week 3</div>
    <h2>Week 3 · คลื่นไร้สายของจริง</h2>
    <p class="hint">สัญญาณ · โดเมนเวลา/ความถี่ · Bandwidth · Nyquist–Shannon · SNR · สเปกตรัม · Multiplexing — เรียบเรียงจาก<b>คาบบรรยายจริง + สไลด์ครบ 50 แผ่น</b> · กล่องส้ม 🎙 = ที่อาจารย์พูดนอกสไลด์ · สัปดาห์นี้คณิตจาก Week 1 (log, dB) กลับมาใช้จริงแบบเต็มๆ</p>

    <div class="shell">
      <WeekNav week={3} sections={sections} />
      <div class="lesson-main">

        <!-- ============ 1 ============ -->
        <Step kind="real" icon="🎯" title="จากมาร์โคนี่ถึง 5G — และทำไม 'ไร้สาย' ถึงโตช้ากว่าที่คิด" id="why">
          <p>สองสัปดาห์แรกเราได้เครื่องมือ (dB) กับแผนที่การเดินทางของข้อมูล (โพรโทคอล/สวิตชิง) — สัปดาห์นี้ลงไปที่ตัวจริงเสียงจริงของวิชา: <b>คลื่น</b> ที่แบกข้อมูลผ่านอากาศ มันหน้าตายังไง อัดข้อมูลได้เท่าไหร่ และอะไรคือเพดานที่ฟิสิกส์ยอมให้</p>
          <p>ประวัติย่อจากสไลด์ (ไล่เป็นเส้นเวลา):</p>
          <ul>
            <li><b>1896 — กูกลิเอลโม มาร์โคนี่ (Guglielmo Marconi)</b> ประดิษฐ์<b>โทรเลขไร้สาย</b>: เข้ารหัสตัวอักษรลงในสัญญาณแอนะล็อก และทำสำเร็จถึงขั้น<b>ส่งโทรเลขข้ามมหาสมุทรแอตแลนติก</b> — จุดเริ่มของทุกอย่างที่เรียนอยู่นี้</li>
            <li><b>ทศวรรษ 1960</b> — เริ่มยุค<b>ดาวเทียมสื่อสาร</b></li>
            <li>ความก้าวหน้าไล่มาเรื่อยๆ: วิทยุ โทรทัศน์ โทรศัพท์มือถือ ดาวเทียมสื่อสาร</li>
            <li><b>ปัจจุบัน</b>: การสื่อสารดาวเทียม เครือข่ายไร้สาย และ<b>เทคโนโลยีแบบรังผึ้ง (cellular)</b> — คำว่า "รังผึ้ง" คือระบบมือถือที่แบ่งพื้นที่เป็นเซลล์เล็กๆ ต่อกันเหมือนรังผึ้ง</li>
          </ul>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — วิวัฒนาการในมุม "ความถี่"</span>
          อาจารย์ชี้รูปวิวัฒนาการแล้วถามว่า HF, VHF, UHF, SHF ย่อมาจากอะไร — พวกนี้คือ<b>ชื่อช่วงความถี่วิทยุ</b> (High / Very High / Ultra High / Super High Frequency) และประเด็นที่อาจารย์อยากให้เห็นคือ: ยุคแรกๆ (โทรเลข วิทยุ AM) ใช้ความถี่<b>ต่ำ</b>ระดับ MHz แต่เทคโนโลยีใหม่ๆ ไล่ขึ้นความถี่<b>สูงขึ้นเรื่อยๆ</b> — ร้อย MHz ไปจนถึงระดับ GHz ที่ WiFi/4G/5G ใช้อยู่ทุกวันนี้ · ทำไม? เดี๋ยวหัวข้อแบนด์วิดท์จะตอบ: <b>ความถี่สูง = มีที่ว่างให้อัดข้อมูลมากกว่า</b></div>
          <p>สไลด์ "เทคโนโลยีไร้สายแบบบรอดแบนด์" สรุปจุดขายของไร้สาย: ให้อัตราส่งสูงขึ้นจนรับส่ง<b>กราฟิก วิดีโอ เสียง</b>ได้ + ข้อดีร่วมของบริการไร้สายทุกชนิด: <b>สะดวกและถูกลง</b> — เปิดใช้บริการได้เร็วกว่าแบบมีสาย (ไม่ต้องรอเดินสาย), <b>ไม่มีค่าใช้จ่ายสายเคเบิล</b>, และใช้ได้<b>ทุกที่</b></p>
          <p>แต่สไลด์ถัดมาก็ตบด้วยความจริง: ทำไมไร้สายถึง<b>โตช้า</b>? เพราะ<b>ความยากของข้อจำกัดทางเทคนิค + การเมือง + ไม่มีมาตรฐานที่เป็นสากล</b> — คำว่า "การเมือง" ตรงนี้คือเรื่องจริงจัง: คลื่นความถี่เป็น<b>ทรัพยากรของชาติ</b> ใครจะใช้ย่านไหนต้องจัดสรร/ประมูล (นึกถึงข่าวประมูลคลื่น 5G) และแต่ละประเทศจัดสรรไม่เหมือนกัน มาตรฐานเลยแตกกันง่าย</p>
        </Step>

        <!-- ============ 2 ============ -->
        <Step kind="intu" icon="🌊" title="สัญญาณแม่เหล็กไฟฟ้า — หนึ่งสัญญาณ มองได้สองมุม" id="em">
          <p>ข้อมูลไร้สายเดินทางในรูป<span class="term">สัญญาณแม่เหล็กไฟฟ้า (electromagnetic signal)</span> สไลด์เปิดด้วยประโยคสั้นแต่เป็นแกนของทั้งสัปดาห์:</p>
          <ul>
            <li>สัญญาณ<b>เป็นฟังก์ชันของเวลา</b> — มองเป็นกราฟค่าที่แกว่งขึ้นลงตามเวลา (มุมที่เราคุ้น)</li>
            <li>แต่<b>สามารถเขียนในรูปแบบของความถี่ได้ด้วย</b> — เพราะสัญญาณใดๆ <b>ประกอบด้วยส่วนย่อยๆ ของความถี่ที่แตกต่างกัน</b></li>
          </ul>
          <p class="why">เทียบกับดนตรี: เสียงคอร์ดกีตาร์หนึ่งเสียง มองแบบ "เวลา" คือคลื่นเสียงยึกยักหนึ่งเส้น แต่มองแบบ "ความถี่" คือโน้ต 3–4 ตัวที่ดังพร้อมกัน — เสียงเดียวกัน สองมุมมอง และมุม "ความถี่" นี่แหละที่จะพาไปเข้าใจคำว่าแบนด์วิดท์ ซึ่งเป็นหัวใจของวิชานี้ทั้งวิชา</p>
        </Step>

        <!-- ============ 3 ============ -->
        <Step kind="deep" icon="📖" title="โดเมนเวลา: ศัพท์ทุกคำที่ต้องพูดได้เอง (A, f, T, φ, λ)" id="timedomain">
          <p>สไลด์ "แนวความคิดของโดเมนเวลา" ให้นิยามชุดใหญ่ — ไล่ทีละคำ ช้าๆ ให้ครบ เพราะทุกคำจะถูกใช้ตลอดทั้งวิชา:</p>
          <p><b>สัญญาณแอนะล็อก (Analog signal)</b> — สัญญาณที่มีความ<b>ต่อเนื่อง</b>ตลอดเวลา ไม่มีการหยุดหรือขาดตอน (เส้นกราฟลากได้ไม่ต้องยกปากกา) เช่น คลื่นเสียงพูด</p>
          <p><b>สัญญาณดิจิทัล (Digital signal)</b> — สัญญาณที่<b>คงที่อยู่ระดับหนึ่งช่วงเวลาหนึ่ง แล้วกระโดดไปคงที่อีกระดับ</b> (กราฟขั้นบันได) เช่น พัลส์ไฟฟ้าแทนบิต 0/1</p>
          <p><b>สัญญาณเป็นคาบ (Periodic signal)</b> — สัญญาณ (แอนะล็อกหรือดิจิทัลก็ได้) ที่<b>รูปแบบซ้ำเดิม</b>บนแกนเวลา เขียนเป็นเงื่อนไขคณิตว่า <code>s(t + T) = s(t)</code> สำหรับทุกเวลา t — แปลว่า "มองที่เวลาไหน อีก T วินาทีถัดไปก็เห็นค่าเดิมเป๊ะ" โดย T คือ<b>คาบ</b>ของสัญญาณ · <b>สัญญาณไม่เป็นคาบ (Aperiodic)</b> = ไม่ซ้ำแบบนั้น</p>
          <p>ตัวแปรประจำตัวของคลื่น (ต้องได้ทั้งความหมาย + หน่วย — อาจารย์ไล่ถามหน่วยในห้อง):</p>
          <table class="tbl">
            <thead><tr><th>ตัวแปร</th><th>คือ</th><th>หน่วย</th></tr></thead>
            <tbody>
              <tr><td><b>แอมพลิจูดสูงสุด A</b><br/>(Peak amplitude)</td><td>ค่าสูงสุดของความแรงสัญญาณในช่วงเวลาหนึ่ง — "คลื่นสูงแค่ไหน"</td><td>โวลต์ (V)</td></tr>
              <tr><td><b>ความถี่ f</b><br/>(Frequency)</td><td>อัตราที่สัญญาณซ้ำตัวเอง — "สั่นกี่รอบต่อวินาที"</td><td>รอบ/วินาที = เฮิรตซ์ (Hz)</td></tr>
              <tr><td><b>คาบ T</b><br/>(Period)</td><td>เวลาที่คลื่นครบ 1 รอบ — <b>T = 1/f</b> (ส่วนกลับกันเป๊ะ: สั่นถี่ = รอบสั้น)</td><td>วินาที (s)</td></tr>
              <tr><td><b>มุมเฟส φ</b><br/>(Phase)</td><td>ตำแหน่งอ้างอิงบนแกนเวลาภายในหนึ่งรอบคลื่น — "รอบนี้เริ่มนับจากตรงไหน"</td><td>องศา หรือ เรเดียน</td></tr>
              <tr><td><b>ความยาวคลื่น λ</b><br/>(Wavelength)</td><td>ระยะทางของคลื่น 1 ลูก หรือระยะระหว่างสองจุดที่เฟสตรงกันในคลื่นติดกัน</td><td>เมตร (m)</td></tr>
            </tbody>
          </table>
          <p>และสมการเชื่อมโลกเวลา-ระยะทาง ที่ต้องจำให้ขึ้นใจ:</p>
          <div class="formula">c = f × λ        โดย c = ความเร็วแสง = 3 × 10⁸ m/s (ค่าคงที่)
→ รู้ f หา λ ได้เสมอ:  λ = c / f</div>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — โจทย์สดในห้อง</span>
          "คลื่นความถี่ <b>30 MHz</b> มีความยาวคลื่นเท่าไหร่? ตอบหน่วยเมตร" — วิธีคิด: λ = c/f = (3×10⁸) ÷ (30×10⁶) = <b>10 เมตร</b> · สังเกต insight ที่ซ่อนอยู่: ความถี่<b>ยิ่งสูง</b> คลื่น<b>ยิ่งสั้น</b> — คลื่น WiFi 2.4 GHz ยาวแค่ ~12.5 ซม. นี่คือเหตุผลที่เสาอากาศมือถือเล็กนิดเดียวแต่เสาวิทยุ AM ต้องสูงเป็นสิบเมตร (ขนาดเสาอากาศต้องสัมพันธ์กับ λ)</div>
        </Step>

        <!-- ============ 4 ============ -->
        <Step kind="anim" icon="🎛️" title="คลื่นไซน์ s(t) = A·sin(2πft + φ) — หมุน 3 ปุ่มเองเลย" id="sinewave">
          <p>คลื่นพื้นฐานที่สุดในจักรวาลสัญญาณคือ<span class="term">คลื่นไซน์ (sine wave)</span> เขียนเป็นสมการทั่วไป:</p>
          <div class="formula">s(t) = A · sin(2πft + φ)
A = แอมพลิจูด · f = ความถี่ · φ = มุมเฟส   (2π เรเดียน = 360° = 1 คาบพอดี)</div>
          <p>ทำไมต้องมี 2π? เพราะฟังก์ชัน sin ทำงานเป็น "มุม" — การคูณ 2πf เข้ากับเวลา คือการแปลง "เวลาที่ผ่านไป" ให้กลายเป็น "มุมที่หมุนไป": ผ่านไป 1/f วินาที (หนึ่งคาบ) มุมหมุนครบ 2π = 360° = คลื่นครบหนึ่งลูกพอดี</p>
          <p>รูป 2.3 ในสไลด์แสดงผลของการเปลี่ยนตัวแปรทีละตัว — แทนที่จะดูรูปนิ่ง กดปุ่มด้านล่างแล้ว<b>เลื่อนเอง</b>:</p>
          <div class="lab">
            <h4>🎛️ Sine Lab — เลื่อน 3 ตัวแปร ดูคลื่นเปลี่ยนสด</h4>
            <div class="sine-controls">
              <label>แอมพลิจูด A = <b><span id="lblA"></span></b><input type="range" id="sineA" min="0.2" max="1" step="0.1" value="1" /></label>
              <label>ความถี่ f (Hz) = <b><span id="lblF"></span></b><input type="range" id="sineF" min="0.5" max="4" step="0.5" value="1" /></label>
              <label>เฟส φ (องศา) = <b><span id="lblP"></span></b><input type="range" id="sineP" min="0" max="315" step="45" value="0" /></label>
            </div>
            <canvas id="sineCanvas"></canvas>
            <div class="enc-cap" id="sineOut"></div>
            <div class="btnrow">
              <button class="btn ghost" data-sine="1,1,0">(a) ตั้งต้น A=1, f=1, φ=0 → T=1s</button>
              <button class="btn ghost" data-sine="0.5,1,0">(b) ลด A=0.5</button>
              <button class="btn ghost" data-sine="1,2,0">(c) เพิ่ม f=2 → T=½s</button>
              <button class="btn ghost" data-sine="1,1,45">(d) เลื่อนเฟส φ=45° (π/4)</button>
            </div>
          </div>
          <p>สี่ปุ่มนั้นคือ 4 กรณีในรูป 2.3 ของสไลด์เป๊ะๆ: (a) คลื่นอ้างอิง (b) เตี้ยลงแต่จังหวะเดิม (c) ถี่ขึ้นเท่าตัว—คาบเหลือครึ่ง (d) รูปเดิมแต่<b>เริ่มเหลื่อมไป 45°</b> — อาจารย์ย้ำในห้องว่า 3 ตัวนี้ (A, f, φ) คือ "ปุ่มทั้งหมด" ที่คลื่นไซน์มี และการสื่อสารทั้งวงการก็คือศิลปะการ "ขยับปุ่มพวกนี้เพื่อฝากข้อมูล" (จะเจอเต็มๆ ตอนเรียนการมอดูเลต)</p>
        </Step>

        <!-- ============ 5 ============ -->
        <Step kind="deep" icon="📏" title="แกนนอนเป็น 'เวลา' หรือ 'ระยะทาง' — กราฟเดียวกันแต่คนละคำถาม" id="timedist">
          <p>สไลด์ "เวลา vs. ระยะทาง" ชี้จุดที่คนสับสนบ่อย: คลื่นวาดได้ 2 แบบ</p>
          <ul>
            <li><b>แกนนอนเป็นเวลา (กราฟ ก.)</b> — ยืนอยู่จุดเดียวในอวกาศ แล้วดูค่าสัญญาณ ณ จุดนั้น<b>เปลี่ยนตามเวลา</b> (เหมือนทุ่นลอยน้ำที่ขยับขึ้นลง) — ระยะห่างระหว่างยอดคลื่น = คาบ T (วินาที)</li>
            <li><b>แกนนอนเป็นระยะทาง (กราฟ ข.)</b> — หยุดเวลาไว้หนึ่งขณะ (ถ่ายรูป) แล้วดูค่าสัญญาณ<b>ตามระยะทาง</b>จากแหล่งกำเนิด — ระยะห่างระหว่างยอดคลื่น = ความยาวคลื่น λ (เมตร)</li>
          </ul>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์</span>
          สิ่งที่อาจารย์เสริมบนกราฟ ข.: ณ เวลาใดๆ <b>ความเข้มของสัญญาณจะลดลงตามระยะทางจากแหล่งกำเนิด</b> — "อยู่ใกล้เสาสัญญาณก็แรง ยิ่งไกลออกไปยิ่งอ่อนลง" คลื่นในรูปเลยวาดให้แอมพลิจูดค่อยๆ เตี้ยลงตามระยะ · คุ้นไหม? นี่คือ <b>path loss</b> ตัวเดียวกับที่เราหักลบเป็น dB ใน link budget ของ Week 1 — สองสัปดาห์นี้เพิ่งมาบรรจบกัน</div>
        </Step>

        <!-- ============ 6 ============ -->
        <Step kind="anim" icon="🧮" title="โดเมนความถี่: สัญญาณทุกตัวคือ 'ผลบวกของคลื่นไซน์' (ลองประกอบเอง)" id="freqdomain">
          <p>มาถึงไอเดียที่ลึกที่สุดของสัปดาห์ — สไลด์เขียนสั้นๆ ว่า:</p>
          <ul>
            <li><b>สัญญาณแม่เหล็กไฟฟ้าใดๆ</b> สามารถแสดงเป็น<b>ผลรวมของคลื่นไซน์หลายลูก</b>ที่มีแอมพลิจูด/ความถี่/เฟสต่างกัน</li>
            <li><b>ความถี่มูลฐาน (Fundamental frequency)</b> — เมื่อทุกส่วนประกอบความถี่ของสัญญาณเป็น<b>จำนวนเต็มเท่า</b>ของความถี่เดียวกัน ความถี่นั้นคือความถี่มูลฐาน (ตัวคูณของมันเรียกว่าฮาร์มอนิก) และ<b>คาบของสัญญาณรวมเท่ากับคาบของความถี่มูลฐาน</b></li>
          </ul>
          <p>ฟังดูนามธรรม? อาจารย์เดินเรื่องนี้ในห้องด้วยตัวอย่างคลาสสิก: เอาไซน์ความถี่ f มาบวกกับไซน์ความถี่ 3f (แล้ว 5f, 7f, …) ดูว่าเกิดอะไรขึ้น — กดเลื่อนเองเลย:</p>
          <div class="lab">
            <h4>🧮 Fourier Lab — ประกอบคลื่นเหลี่ยมจากคลื่นไซน์</h4>
            <label style="font-size:.9rem">จำนวนเทอม (ไซน์ความถี่คี่ 1f, 3f, 5f, …): <input type="range" id="fourierN" min="1" max="25" step="1" value="2" style="width:60%" /></label>
            <canvas id="fourierCanvas"></canvas>
            <div class="enc-cap" id="fourierOut"></div>
          </div>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — บทสรุปจากการเล่นนี้</span>
          บวกแค่ f กับ 3f ก็เริ่มเห็นทรงเหลี่ยม เติม 5f "สวยขึ้น" เติม 7f "เริ่มเป็นเหลี่ยมชัด" … และถ้าเติมได้ถึง<b>อนันต์</b> มันคือ <b>square wave สมบูรณ์</b> — สัญญาณดิจิทัล (ที่เป็นเหลี่ยม) แท้จริงคือ "ไซน์อนันต์ลูกซ้อนกัน" ผลรวมเขียนได้เป็น summation ของพจน์ (1/k)·sin(2πkft) เมื่อ k = 1, 3, 5, … — จุดนี้คือสะพานไปหัวข้อถัดไปเลย</div>
          <p>ศัพท์ชุดโดเมนความถี่จากสไลด์ (นิยามให้ครบ):</p>
          <ul>
            <li><b>สเปกตรัม (Spectrum)</b> — <b>ช่วงของความถี่</b>ที่สัญญาณนั้นมีส่วนประกอบอยู่ (ในแล็บข้างบน: จาก f ถึง kf ตัวสูงสุดที่ใช้)</li>
            <li><b>แบนด์วิดท์สัมบูรณ์ (Absolute bandwidth)</b> — <b>ความกว้าง</b>ของสเปกตรัมทั้งหมด หน่วยเฮิรตซ์ (ของ square wave แท้ = กว้างไม่จำกัด เพราะฮาร์มอนิกไปถึงอนันต์)</li>
            <li><b>แบนด์วิดท์ประสิทธิผล (Effective bandwidth)</b> หรือเรียกสั้นๆ ว่า<b>แบนด์วิดท์</b> — แถบความถี่<b>แคบลงมาที่เก็บพลังงานส่วนใหญ่</b>ของสัญญาณไว้ · เหตุที่ต้องมีคำนี้: absolute bandwidth มักกว้างเกินใช้จริง แต่พลังงานเกือบทั้งหมดกองอยู่ในช่วงแคบๆ (สังเกตในแล็บ: แท่ง 1f สูงสุด แท่งยิ่งความถี่สูงยิ่งเตี้ยลงเร็วมาก ตาม 1/k) เราเลยตัดเอาเฉพาะช่วงที่ "เนื้อๆ" มาใช้งานได้</li>
          </ul>
          <div class="note">⚠️ <b>คำเตือนหน่วยจากอาจารย์:</b> ในวิชาเครือข่ายทั่วไปคุณอาจชินกับ "แบนด์วิดท์" หน่วย <b>bps</b> (ความเร็วเน็ต) แต่<b>ในวิชานี้แบนด์วิดท์มีหน่วยเป็นเฮิรตซ์ (Hz)</b> — มันคือความกว้างของ "ย่านความถี่" ไม่ใช่อัตราบิต สองอย่างนี้<b>เกี่ยวข้องกัน</b> (Nyquist/Shannon คือสูตรแปลงระหว่างกัน!) แต่<b>ไม่ใช่สิ่งเดียวกัน</b> — สอบอย่าสลับหน่วยเด็ดขาด</div>
        </Step>

        <!-- ============ 7 ============ -->
        <Step kind="deep" icon="💰" title="แบนด์วิดท์ vs อัตราข้อมูล — ทำไมสัญญาณดิจิทัล 'เพี้ยนเสมอ'" id="bwdata">
          <p>สไลด์ "ความสัมพันธ์ระหว่างอัตราข้อมูลและแบนด์วิดท์" สรุป 4 ประโยคที่ร้อยกันเป็นเหตุเป็นผล (ลองไล่ตามด้วยความรู้จาก Fourier Lab):</p>
          <ol>
            <li><b>แบนด์วิดท์ยิ่งมาก ความจุที่จะใส่ข้อมูลก็ยิ่งมาก</b> — มีย่านความถี่กว้าง = มีที่ให้สัญญาณแกว่งเร็วๆ ได้ = ยัดบิตได้ถี่ขึ้น</li>
            <li><b>รูปคลื่นดิจิทัลใดๆ มีแบนด์วิดท์ไม่จำกัด</b> — เพิ่งเห็นกับตา: ขอบเหลี่ยมคมๆ ต้องใช้ฮาร์มอนิกถึงอนันต์</li>
            <li><b>แต่ระบบส่งจริงจำกัดแบนด์วิดท์เสมอ</b> — สายทองแดง อากาศ อุปกรณ์ ทุกอย่างส่งผ่านได้แค่ช่วงความถี่หนึ่ง และ<b>สำหรับสื่อใดๆ ยิ่งใช้แบนด์วิดท์มาก ราคายิ่งแพง</b> (คลื่นความถี่ต้องประมูล อุปกรณ์ย่านกว้างต้องดีขึ้น)</li>
            <li>ผลลัพธ์: <b>การจำกัดแบนด์วิดท์ทำให้สัญญาณผิดรูป (distortion)</b> — ฮาร์มอนิกสูงๆ ถูกตัดทิ้ง เหลี่ยมเลยกลายเป็นมน (ในแล็บ: เลื่อนจำนวนเทอมลง = สิ่งที่ช่องสัญญาณแคบทำกับสัญญาณเรา!) ระบบต้องออกแบบให้ "มนแค่ไหนก็ยังอ่านบิตออก"</li>
          </ol>
          <p class="why">นี่คือ trade-off เงินล้านของวงการ: อยากส่งเร็ว → ต้องใช้แบนด์วิดท์กว้าง → แพง · อยากประหยัด → แบนด์แคบ → สัญญาณเพี้ยน/ช้า — วิศวกรรมสื่อสารทั้งศาสตร์คือการหาจุดพอดีตรงนี้ และอีกสามหัวข้อ Nyquist กับ Shannon จะให้ "สูตรคำนวณเพดาน" ของเกมนี้แบบเป๊ะๆ</p>
        </Step>

        <!-- ============ 8 ============ -->
        <Step kind="deep" icon="🔤" title="ข้อมูล vs สัญญาณ vs การส่ง + จับคู่ 4 แบบ (โมเด็มกับ Codec มาจากไหน)" id="datasig">
          <p>สามคำที่สไลด์ให้นิยามแยกกันชัดๆ ("คำสำคัญในการสื่อสารข้อมูล"):</p>
          <ul>
            <li><b>ข้อมูล (data)</b> — สิ่งที่มีความหมาย/สารสนเทศ ที่เราอยากส่ง (ตัวเนื้อหา)</li>
            <li><b>สัญญาณ (signal)</b> — การ<b>แทนที่</b>ข้อมูลด้วยสัญญาณไฟฟ้าหรือแม่เหล็กไฟฟ้า (ตัวพาหนะ)</li>
            <li><b>การส่ง (transmission)</b> — การสื่อสารข้อมูลโดยการแพร่กระจายและประมวลผลสัญญาณ (ตัวการเดินทาง)</li>
          </ul>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์</span> "ข้อมูลกับสัญญาณต่างกันยังไง?" — ข้อมูลคือ<b>สิ่งที่เราต้องการจะส่ง</b> ส่วนสัญญาณคือ<b>ตัวที่พาข้อมูลไป</b> เช่น เสียงดีเจ (ข้อมูล) ฝากไปกับคลื่นวิทยุ FM (สัญญาณ) เพื่อให้เดินทางได้ไกลขึ้น แล้วเครื่องรับปลายทางค่อยแกะข้อมูลออกจากสัญญาณ</div>
          <p>ทั้งข้อมูลและสัญญาณต่างก็เป็นได้ทั้งแอนะล็อกและดิจิทัล — ตัวอย่างข้อมูลจากสไลด์: แอนะล็อก = <b>วิดีโอ, เสียง</b> · ดิจิทัล = <b>ข้อความ (text), จำนวนเต็ม (integer)</b></p>
          <p>คุณสมบัติของสัญญาณสองแบบ (สไลด์ 24–25 — เก็บครบทุกข้อ เพราะออกสอบเทียบกันบ่อย):</p>
          <table class="tbl">
            <thead><tr><th></th><th>สัญญาณแอนะล็อก</th><th>สัญญาณดิจิทัล</th></tr></thead>
            <tbody>
              <tr><td>คือ</td><td>คลื่นแม่เหล็กไฟฟ้าเปลี่ยนค่าต่อเนื่อง</td><td>ลำดับของพัลส์แรงดันไฟฟ้า (voltage pulse)</td></tr>
              <tr><td>สื่อที่ใช้ได้</td><td>หลายสื่อขึ้นกับความถี่: สายทองแดง ใยแก้ว อากาศ/อวกาศ</td><td>ปกติส่งในสายทองแดง</td></tr>
              <tr><td>ราคา</td><td>—</td><td><b>ถูกกว่า</b></td></tr>
              <tr><td>ความทนต่อคลื่นรบกวน</td><td>—</td><td><b>ทนกว่า</b> (เดี๋ยวเห็นเหตุผลใน Repeater)</td></tr>
              <tr><td>การลดทอน (attenuation)</td><td>—</td><td><b>โดนลดทอนแรงกว่า</b> — คือจุดอ่อนหลัก</td></tr>
              <tr><td>ขนข้อมูลได้</td><td>ทั้งแอนะล็อกและดิจิทัล</td><td>ทั้งแอนะล็อกและดิจิทัล</td></tr>
            </tbody>
          </table>
          <p>บรรทัดสุดท้ายของตารางสำคัญมาก: ข้อมูลกับสัญญาณ<b>จับคู่ข้ามกันได้ทั้ง 4 แบบ</b> และสไลด์ "เหตุผลสำหรับการเลือกใช้" บอกว่าทำไมแต่ละคู่ถึงมีที่ใช้:</p>
          <ul>
            <li><b>ข้อมูลดิจิทัล + สัญญาณดิจิทัล</b> — อุปกรณ์เข้ารหัส<b>ถูกกว่า</b>อุปกรณ์แปลงดิจิทัลเป็นแอนะล็อก (ถ้าสื่อรองรับ ก็ตรงไปตรงมาสุด)</li>
            <li><b>ข้อมูลแอนะล็อก + สัญญาณดิจิทัล</b> — แปลงเพื่อให้ใช้<b>อุปกรณ์ส่ง/สวิตชิงสมัยใหม่</b>ได้ (ระบบดิจิทัลจัดการง่ายกว่า)</li>
            <li><b>ข้อมูลดิจิทัล + สัญญาณแอนะล็อก</b> — เพราะ<b>สื่อบางชนิดส่งได้เฉพาะสัญญาณแอนะล็อก</b> เช่น <b>สายใยแก้วนำแสง และสื่อไร้สาย</b></li>
            <li><b>ข้อมูลแอนะล็อก + สัญญาณแอนะล็อก</b> — แปลงกันได้<b>ง่าย</b>ที่สุด (แทบไม่ต้องประมวลผล)</li>
          </ul>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — ประโยคที่ควรสะดุด</span>
          อาจารย์ถามในห้อง: "ใยแก้วนำแสงส่งสัญญาณอะไร?" — <b>แอนะล็อก</b> (ตัวสัญญาณคือแสง ซึ่งเป็นคลื่นต่อเนื่อง) · "แล้ว wireless ทั้งหมดล่ะ?" — <b>แอนะล็อกทั้งหมด!</b> คลื่นวิทยุเป็นคลื่นแม่เหล็กไฟฟ้าต่อเนื่องเสมอ · เพราะฉะนั้น "WiFi ดิจิทัล" ที่จริงคือ <b>ข้อมูล</b>ดิจิทัล ขี่อยู่บน<b>สัญญาณ</b>แอนะล็อก — แม้แต่มือถือเรา: เสียงพูด (แอนะล็อก) → แปลงเป็นดิจิทัลก่อน → แล้วส่งออกอากาศเป็นคลื่นแอนะล็อก ครบทุกการแปลงในเครื่องเดียว</div>
        </Step>

        <!-- ============ 9 ============ -->
        <Step kind="check" icon="📝" title="การบ้านของอาจารย์ (สไลด์ 28): เติมตาราง ข้อมูล × สัญญาณ" id="hwtable">
          <p>สไลด์ "ตารางสรุป ข้อมูล และ สัญญาณ" จงใจ<b>เว้นว่าง 3 คอลัมน์</b>: เทคนิคในการเข้ารหัส / อุปกรณ์ที่ใช้ / ระบบที่ใช้ — อาจารย์เฉลยปากเปล่าในห้องผ่านการถามตอบ (โมเด็มย่อมาจากอะไร? Codec คืออะไร?) เรารวบมาให้ครบแล้ว แต่<b>ลองเติมเองก่อน</b>: กดที่ช่องเพื่อวนตัวเลือก แล้วกดตรวจ</p>
          <div class="lab">
            <h4>📝 กดช่องเพื่อเลือกคำตอบ → ครบแล้วกดตรวจ</h4>
            <table class="tbl" id="dsTable">
              <thead><tr><th style="text-align:left">ข้อมูล → สัญญาณ</th><th>เทคนิคเข้ารหัส</th><th>อุปกรณ์ที่ใช้</th><th>ระบบที่ใช้จริง</th></tr></thead>
              <tbody></tbody>
            </table>
            <div class="btnrow">
              <button class="btn" id="dsCheck">✓ ตรวจคำตอบ</button>
              <button class="btn ghost" id="dsReset">↺ ล้างตาราง</button>
            </div>
            <div class="enc-cap" id="dsOut"></div>
          </div>
          <div class="lect"><span class="who">🎙 เฉลยชื่อย่อ 2 ตัวที่อาจารย์ให้ถอดในห้อง</span>
          <b>Modem</b> = <b>MO</b>dulator + <b>DEM</b>odulator (ตัวมอดูเลต/ถอดมอดูเลต — พาข้อมูลดิจิทัลขี่คลื่นแอนะล็อก) · <b>Codec</b> = <b>CO</b>der + <b>DEC</b>oder (ตัวเข้า/ถอดรหัส — แปลงข้อมูลแอนะล็อกเป็นสัญญาณดิจิทัล เช่นในระบบโทรศัพท์ดิจิทัลและแผ่น CD)</div>
        </Step>

        <!-- ============ 10 ============ -->
        <Step kind="anim" icon="🔁" title="ส่งให้ไกล: Amplifier vs Repeater — เหตุผลที่โลกย้ายมาดิจิทัล" id="transmission">
          <p>สัญญาณทุกชนิดเดินทางแล้ว<b>อ่อนลง (ลดทอน/attenuation)</b> — อยากส่งไกลต้องมีตัวช่วยกลางทาง แต่สองโลกใช้ตัวช่วยคนละแบบ และความต่างนี้คือหัวใจของสไลด์ "การส่งสัญญาณแอนะล็อก/ดิจิทัล":</p>
          <ul>
            <li><b>การส่งสัญญาณแอนะล็อก</b> — ส่งโดย<b>ไม่สนใจเนื้อหาข้างใน</b> การลดทอนจำกัดความยาวสาย จึงใช้<b>เครื่องขยายสัญญาณ (amplifier)</b> เรียงต่อกันเพื่อไปไกล — แต่การขยายแบบไม่รู้เนื้อหา<b>ทำให้เกิดการเพี้ยน (distortion) สะสม</b>: ข้อมูลแอนะล็อก (เสียง) พอทนได้ แต่<b>ข้อมูลดิจิทัลจะเกิด error</b></li>
            <li><b>การส่งสัญญาณดิจิทัล</b> — <b>สนใจรูปคลื่น</b>: การลดทอนทำลายความคงสภาพ (integrity) ของข้อมูลได้ จึงใช้<b>รีพีทเตอร์ (repeater)</b> ที่<b>กู้คืน</b>รูปสัญญาณเดิมแล้วส่งต่อ → ไปได้ไกลโดยไม่สะสมความเพี้ยน · แม้แต่กรณีสัญญาณแอนะล็อกที่ขนข้อมูลดิจิทัล อุปกรณ์ส่งต่อก็กู้ข้อมูลดิจิทัลออกมาแล้ว<b>สร้างสัญญาณแอนะล็อกลูกใหม่ที่สะอาด</b>ได้</li>
          </ul>
          <div class="lab">
            <h4>🎬 เทียบกันชัดๆ — สัญญาณเดินทาง 2 ช่วง ผ่านตัวช่วยกลางทาง</h4>
            <div class="btnrow">
              <button class="btn" data-amp="amp">Amplifier (โลกแอนะล็อก)</button>
              <button class="btn ghost" data-amp="rep">Repeater (โลกดิจิทัล)</button>
            </div>
            <canvas id="ampCanvas"></canvas>
            <div class="enc-cap" id="ampCap"></div>
          </div>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — คำอธิบายที่เคลียร์สุด</span>
          Amplifier "แค่ทำให้ใหญ่ขึ้น ไม่ได้ฉลาดอะไรเลย" — สัญญาณที่รับมาพร้อม noise มันก็<b>ขยาย noise ไปด้วยทั้งก้อน</b> · ส่วน Repeater ฉลาดกว่า: รูปแบบดิจิทัลมันเดาได้ว่าต้องเป็น 0 หรือ 1 (มีฟังก์ชันตีความ) มันเลย<b>สร้างสัญญาณใหม่เอี่ยม</b>ส่งต่อ ทำให้ "สะอาดกว่า" — แต่ถ้า noise หนักจน<b>ตีความผิด ก็ผิดเลย</b>ถาวรเหมือนกัน</div>
        </Step>

        <!-- ============ 11 ============ -->
        <Step kind="deep" icon="🚰" title="ความจุช่องสัญญาณ + 4 คำที่ต้องแม่น (และ noise ทำบิตพลิกยังไง)" id="capacity">
          <p>คำถามใหญ่ต่อมา: ช่องสัญญาณหนึ่งช่อง <b>อัดข้อมูลได้เร็วสุดเท่าไหร่?</b> สไลด์นิยาม <span class="term">ความจุช่องสัญญาณ (channel capacity)</span> = <b>อัตราสูงสุดที่ข้อมูลถูกส่งผ่านช่องทางสื่อสารได้ ภายใต้เงื่อนไขที่กำหนด</b> — ตัวการที่กดเพดานคือ<b>ความบกพร่อง (impairments)</b> โดยเฉพาะ<b>สัญญาณรบกวน (noise)</b></p>
          <p>4 คำที่เกี่ยวพันกัน (สไลด์ 32) — สังเกตหน่วยให้ดี:</p>
          <table class="tbl">
            <thead><tr><th>คำ</th><th>คือ</th><th>หน่วย</th></tr></thead>
            <tbody>
              <tr><td><b>อัตราการส่งข้อมูล (data rate)</b></td><td>อัตราที่ข้อมูลสื่อสารได้จริง</td><td>bps (บิต/วินาที)</td></tr>
              <tr><td><b>แบนด์วิดท์ (bandwidth)</b></td><td>ความกว้างย่านความถี่ของสัญญาณที่ส่ง — ถูกจำกัดโดยตัวส่ง+ธรรมชาติของสื่อ</td><td><b>Hz</b> (ย้ำอีกรอบ!)</td></tr>
              <tr><td><b>สัญญาณรบกวน (noise)</b></td><td>ระดับ noise <b>เฉลี่ยตลอดเส้นทาง</b>สื่อสาร</td><td>วัตต์ (วัดที่<b>ตัวรับ</b> — อาจารย์เน้น)</td></tr>
              <tr><td><b>อัตราความผิดพลาด (error rate)</b></td><td>อัตราที่บิตพลิก: <b>ส่ง 1 ได้ 0 หรือส่ง 0 ได้ 1</b></td><td>—</td></tr>
            </tbody>
          </table>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — กลไกที่ noise ทำให้บิตพลิก (สไลด์ 33 เป็นรูปล้วน อาจารย์อธิบายปากเปล่า)</span>
          ระบบดิจิทัลมี<b>เส้นแบ่งกึ่งกลาง</b>ของสัญญาณ: ค่าที่รับมา<b>สูงกว่าเส้น = ตีความเป็น 1, ต่ำกว่า = เป็น 0</b> · noise คือตัวที่มาบวกเพิ่ม/ลบออกจากสัญญาณระหว่างทาง — ถ้า noise เบา ค่าที่รับยังอยู่ฝั่งเดิมของเส้น = <b>ไม่เกิด error</b> แต่ถ้า noise แรงจนดันค่า<b>ข้ามเส้นไปฝั่งตรงข้าม</b> บิตพลิกทันที = error · ภาพนี้จะทำให้สูตร Shannon ที่มี SNR โผล่มา "มีเหตุผล" ขึ้นมาก: ยิ่งสัญญาณแรงเทียบกับ noise เส้นแบ่งยิ่งปลอดภัย ยิ่งกล้าอัดข้อมูลถี่ขึ้น</div>
        </Step>

        <!-- ============ 12 ============ -->
        <Step kind="deep" icon="📈" title="Nyquist — เพดานเมื่อโลกไร้ noise: C = 2B log₂M" id="nyquist">
          <p>สูตรแรก (สไลด์ "แบนด์วิดท์ไนควิสท์") ตอบคำถาม: ถ้าช่องสัญญาณกว้าง B เฮิรตซ์ และ<b>สมมุติอุดมคติว่าไม่มี noise เลย</b> จะส่งได้เร็วสุดเท่าไหร่?</p>
          <div class="formula">สัญญาณ 2 ระดับ (binary):   C = 2B
สัญญาณ M ระดับ:            C = 2B · log₂M
C = ความจุช่องสัญญาณ (bps) · B = แบนด์วิดท์ (Hz) · M = จำนวนระดับแรงดันไฟฟ้า</div>
          <p>ที่มาของแต่ละชิ้น (เข้าใจแล้วไม่ต้องท่อง):</p>
          <ul>
            <li><b>ทำไม 2B?</b> — ไนควิสท์พิสูจน์ว่าช่องที่กว้าง B เฮิรตซ์ ยอมให้สัญญาณ "เปลี่ยนค่า" ได้เร็วสุด <b>2B ครั้งต่อวินาที</b>โดยฝั่งรับยังแยกแต่ละค่าออก — เร็วกว่านั้นสัญลักษณ์จะเบลอซ้อนกัน (เพราะฮาร์มอนิกที่ต้องใช้ถูกช่องตัดทิ้ง — เชื่อมกับ Fourier Lab ตรงๆ) ถ้าแต่ละครั้งส่งได้ 1 บิต (2 ระดับ) ก็ได้ C = 2B</li>
            <li><b>ทำไม log₂M?</b> — ถ้าสัญญาณมี M ระดับ การส่ง 1 ครั้งแยกได้ M กรณี = ขนข้อมูลได้ <b>log₂M บิต</b>ต่อครั้ง (เช่น 4 ระดับ = 2 บิต/ครั้ง, 16 ระดับ = 4 บิต/ครั้ง — นี่คือ log ฐาน 2 จาก Week 1 กลับมาทำงาน) คูณกับ 2B ครั้ง/วินาที ก็ได้สูตรเต็ม</li>
            <li><b>แล้วทำไมไม่เพิ่ม M ไปเรื่อยๆ ให้ C พุ่งอนันต์?</b> — คำถามเงินล้าน! เพราะยิ่ง M มาก ระดับยิ่ง<b>ชิดกัน</b> แล้วโลกจริงมี noise… ระดับที่ชิดกันจะถูก noise ดันข้ามเส้นได้ง่าย — คนที่ตอบว่า "เพิ่มได้ถึงไหน" คือ Shannon ในอีกสองหัวข้อ</li>
          </ul>
        </Step>

        <!-- ============ 13 ============ -->
        <Step kind="deep" icon="🔊" title="SNR — คณิต Week 1 กลับมาแล้ว (สัญญาณดังกว่าเสียงรบกวนกี่เท่า)" id="snr">
          <p><span class="term">Signal-to-Noise Ratio (SNR หรือ S/N)</span> = อัตราส่วนของ<b>กำลังงานสัญญาณ</b>ต่อ<b>กำลังงานสัญญาณรบกวน</b>ที่มีอยู่ในช่วงการส่ง — เป็นค่า<b>ไม่มีหน่วย</b> (วัตต์หารวัตต์ ตัดกันหมด — จำกฎ "ระวังหน่วย" ของ Week 1 ได้ไหม):</p>
          <div class="formula">SNR = S / N        (S = กำลังสัญญาณ, N = กำลัง noise — หน่วยวัตต์ทั้งคู่ วัดที่เครื่องรับ)
SNR_dB = 10 · log₁₀(SNR)     ← สูตร dB เดิมจาก Week 1 เป๊ะๆ</div>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — SNR ฉบับห้องเรียน</span>
          เสียงอาจารย์ที่กำลังสอน = <b>สัญญาณ</b> ส่วนเสียงแอร์+เสียงคนคุยหลังห้อง = <b>noise</b> — อยากให้การสื่อสารรู้เรื่อง เอาอะไรมาก? เอา S มากๆ N น้อยๆ = SNR สูงๆ · แล้วสังเกตว่า noise เราไปสั่งให้มันเงียบไม่ได้ (มันมากับธรรมชาติ/อุปกรณ์) ทางปฏิบัติเลยมักไปเพิ่ม S แทน</div>
          <p>สองประโยคปิดท้ายจากสไลด์ (โยงกลับของเก่าทั้งคู่):</p>
          <ul>
            <li><b>SNR สูง = คุณภาพสัญญาณสูง = จำนวนรีพีทเตอร์ที่ต้องใช้ก็น้อยลง</b> — สัญญาณยังแยกแยะออกแม้เดินทางไกล ไม่ต้องรีบกู้บ่อยๆ</li>
            <li><b>SNR เป็นตัวกำหนดอัตราการส่งข้อมูลที่เป็นไปได้</b> — ประโยคนี้คือตัวอย่างงานของสูตรถัดไปเลย</li>
          </ul>
        </Step>

        <!-- ============ 14 ============ -->
        <Step kind="deep" icon="🏔️" title="Shannon — เพดานที่แท้จริงเมื่อมี noise: C = B log₂(1 + SNR)" id="shannon">
          <p>สูตรที่ดังที่สุดของทฤษฎีสารสนเทศ (สไลด์ "สูตรความจุของแชนนอน"):</p>
          <div class="formula">C = B · log₂(1 + SNR)
C = ความจุสูงสุดตามทฤษฎี (bps) · B = แบนด์วิดท์ (Hz) · SNR = อัตราส่วนสัญญาณต่อ noise (ไม่ใช่ค่า dB!)</div>
          <p>อ่านสูตรให้ "เห็น" ความหมาย: ความเร็วสูงสุดมาจากสองก๊อก — <b>B</b> (ความกว้างถนน) คูณกับ <b>log₂(1+SNR)</b> (ความชัดของสัญญาณ = กล้าใช้กี่ระดับ) · ถ้าเทียบกับ Nyquist จะเห็นว่า Shannon คือคนที่มาบอกว่า "M ที่เธอเพิ่มได้จริง ถูกจำกัดด้วย SNR นะ" — สองสูตรเป็นคู่หูกัน ไม่ใช่คู่แข่ง</p>
          <p>ข้อควรระวังที่สไลด์ย้ำ (ประเด็นข้อสอบทฤษฎี): ค่า C จากสูตรนี้คือ<b>เพดานทางทฤษฎีสูงสุด</b> — <b>ในทางปฏิบัติอัตราส่งจริงต่ำกว่านั้นมาก</b> เพราะสูตรตั้งสมมุติฐานแบบใจดี:</p>
          <ul>
            <li>คิดเฉพาะ<b>สัญญาณรบกวนขาว (white noise / thermal noise)</b> — noise พื้นฐานจากความร้อนที่กระจายสม่ำเสมอ</li>
            <li><b>ไม่ได้คิด noise แบบชั่วคราว</b> (impulse noise — สัญญาณกระชากเป็นจังหวะ เช่น ฟ้าผ่า มอเตอร์เปิด)</li>
            <li><b>ไม่ได้คิดการผิดรูปจากการลดทอน (attenuation distortion) และการเพี้ยนประวิง (delay distortion)</b> — อย่างหลังคือความถี่ต่างๆ เดินทางถึง<b>ไม่พร้อมกัน</b> (ข้อมูลมาช้ากว่าปกติ) ทำให้รูปคลื่นเบี้ยว</li>
          </ul>
        </Step>

        <!-- ============ 15 ============ -->
        <Step kind="check" icon="🧪" title="โจทย์ที่อาจารย์เดินสดในห้อง + เครื่องคิดให้เล่นเอง" id="worked">
          <p>โจทย์จากสไลด์ (อาจารย์ทำทีละขั้นบนกระดาน — และแซวว่า "อาจารย์ใจดีไม่ให้พวกคุณงง"): <b>สเปกตรัมของช่องสัญญาณอยู่ระหว่าง 3 MHz กับ 4 MHz และ SNR<sub>dB</sub> = 24 dB จงหาอัตราส่งสูงสุด</b> แล้วต่อด้วย: <b>ต้องใช้สัญญาณกี่ระดับถึงจะได้อัตรานั้น?</b></p>
          <p>เดินตามที่อาจารย์ทำบนกระดานทีละขั้น (ทุกขั้นใช้ของที่เรียนมาแล้วทั้งนั้น — นี่คือรูปแบบที่ควรเขียนลงกระดาษคำตอบ):</p>
          <div id="walk-shannon"></div>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์</span> ระหว่างทำอาจารย์หยุดถามทั้งห้องตรงขั้นเปลี่ยนฐาน: "เครื่องคิดเลขมี log₂ ไหม? ไม่มี! แล้วทำไง?" — ต้องใช้ <b>log₁₀ หารด้วย log₁₀2</b> — นี่คือเหตุผลที่ Week 1 บังคับให้แม่นสมบัติเปลี่ยนฐาน มันโผล่ในข้อสอบผ่านโจทย์แบบนี้แหละ ไม่ได้มาถามตรงๆ</div>
          <div class="lab">
            <h4>🧪 เครื่องคิด Nyquist–Shannon — ลองขยับเองว่าอะไรมีผลแค่ไหน</h4>
            <div class="sine-controls" style="grid-template-columns:1fr 1fr">
              <label>แบนด์วิดท์ B = <b><span id="lblB"></span> MHz</b><input type="range" id="capB" min="0.5" max="10" step="0.5" value="1" /></label>
              <label>SNR = <b><span id="lblS"></span> dB</b><input type="range" id="capSNR" min="0" max="40" step="1" value="24" /></label>
            </div>
            <div class="enc-cap" id="capOut" style="min-height:6em"></div>
          </div>
          <p class="why">เล่นแล้วให้สังเกต 2 อย่าง: (1) เพิ่ม B ผลตรงๆ เป็นเส้นตรง — ถนนกว้างขึ้นเท่าไหร่ก็ได้เท่านั้น (2) เพิ่ม SNR ผล "หน่วง" ลงเรื่อยๆ เพราะมันอยู่ใน log — อัดกำลังส่งเพิ่ม 2 เท่า ไม่ได้ทำให้เน็ตเร็วขึ้น 2 เท่า! นี่คือเหตุผลเชิงฟิสิกส์ที่ค่าย 5G วิ่งไปหา "ย่านความถี่ใหม่ๆ ที่กว้าง" (เพิ่ม B) มากกว่านั่งเร่งกำลังส่ง (เพิ่ม SNR)</p>
        </Step>

        <!-- ============ 16 ============ -->
        <Step kind="deep" icon="🧵" title="สื่อส่งสัญญาณ: มีตัวนำ vs ไม่มีตัวนำ (และไร้สายส่งกันท่าไหน)" id="media">
          <p>สไลด์ "การแบ่งสื่อที่ใช้ในการส่งสัญญาณ": <b>สื่อที่ใช้ส่ง (transmission medium)</b> = เส้นทางการส่งทางกายภาพระหว่างตัวส่งกับตัวรับ แบ่งสองค่าย:</p>
          <ul>
            <li><b>สื่อมีตัวนำ (guided media)</b> — คลื่น/สัญญาณถูก "นำ" อยู่<b>ภายในสื่อแข็ง</b>: <b>สายคู่บิดเกลียว (UTP)</b>, <b>สายโคแอ็กซ์ (coaxial)</b>, <b>สายใยแก้วนำแสง (optical fiber)</b> — ตรงกับชุดสายที่อาจารย์ให้ไล่ชื่อไว้ตั้งแต่ Week 2</li>
            <li><b>สื่อไม่มีตัวนำ (unguided media)</b> — ส่งได้โดย<b>ไม่ต้องมีตัวนำ</b> คือปล่อยคลื่นแม่เหล็กไฟฟ้าออกไปใน<b>อากาศและอวกาศ</b> — ส่วนใหญ่หมายถึง<b>การส่งสัญญาณไร้สาย</b>นั่นเอง (ตัววิชาเรา!)</li>
          </ul>
          <p>สำหรับสื่อไม่มีตัวนำ การส่ง-รับสำเร็จได้ด้วย<b>สายอากาศ (antenna)</b> และมี 2 ท่าใหญ่ (สไลด์ 40) ที่จะเป็นเกณฑ์แบ่งการใช้คลื่นในหัวข้อถัดไป:</p>
          <ul>
            <li><b>แบบมีทิศทาง (Directional)</b> — โฟกัสลำคลื่นพุ่งเป้าไปทางเดียว (เหมือนไฟฉาย) — ต้องเล็งกัน แต่ไปไกลและแรง</li>
            <li><b>แบบรอบทิศทางในระนาบเดี่ยว (Omnidirectional)</b> — แผ่ออกทุกทิศรอบตัว (เหมือนหลอดไฟ) — ไม่ต้องเล็ง ใครอยู่แถวนั้นรับได้หมด</li>
          </ul>
        </Step>

        <!-- ============ 17 ============ -->
        <Step kind="deep" icon="📡" title="สเปกตรัม 3 ย่านที่ต้องรู้ + ไมโครเวฟ/ดาวเทียม/วิทยุ ใช้งานจริงยังไง" id="spectrum">
          <p>สไลด์ "ช่วงความถี่ทั่วไป" แบ่งย่านที่ใช้ในโทรคมนาคมเป็น 3 ช่วงหลัก — โยงกับ directional/omni ที่เพิ่งเรียน:</p>
          <table class="tbl">
            <thead><tr><th>ย่าน</th><th>ช่วงความถี่</th><th>ลักษณะ</th><th>เหมาะกับ</th></tr></thead>
            <tbody>
              <tr><td><b>คลื่นวิทยุ (radio)</b></td><td>30 MHz – 1 GHz</td><td>เหมาะกับการใช้แบบ<b>รอบทิศทาง (omni)</b></td><td>กระจายเสียง/ภาพให้คนหมู่มาก</td></tr>
              <tr><td><b>ไมโครเวฟ (microwave)</b></td><td>1 GHz – 40 GHz</td><td>ทำ<b>ลำคลื่นเฉพาะทาง (directional beam)</b> ได้</td><td>เชื่อมจุดต่อจุด + สื่อสารดาวเทียม</td></tr>
              <tr><td><b>อินฟราเรด (infrared)</b></td><td>~3×10¹¹ – 2×10¹⁴ Hz</td><td>ทะลุกำแพงไม่ได้</td><td>พื้นที่จำกัด + จุดต่อจุดระยะสั้น (เช่น รีโมต)</td></tr>
            </tbody>
          </table>
          <p>สามระบบใช้งานจริงจากสไลด์ 43–45 (เก็บรายละเอียดครบ):</p>
          <p><b>1. ไมโครเวฟภาคพื้นดิน (terrestrial microwave)</b> — สายอากาศส่วนใหญ่เป็น<b>จานพาราโบลา (โค้ง) เส้นผ่านศูนย์กลางราว 3 เมตร</b> ติดตั้ง<b>อยู่กับที่</b> โฟกัสลำคลื่น<b>แคบ</b> ต้องมี<b>แนวเส้นสายตา (Line-of-Sight — LOS)</b> ถึงสายอากาศฝั่งรับ (มีอะไรมาบังคือจบ) จึงต้องติดตั้ง<b>สูงกว่าระดับพื้นดิน</b>มากๆ · ใช้งาน: บริการโทรคมนาคม<b>ระยะไกล</b> และลิงก์<b>จุดต่อจุดระหว่างอาคาร</b></p>
          <p><b>2. ไมโครเวฟสำหรับดาวเทียม (satellite microwave)</b> — ดาวเทียมสื่อสารคือ<b>สถานีรีเลย์ (ทวนสัญญาณ) ลอยฟ้า</b>: เชื่อมสถานีภาคพื้นดิน 2 สถานีขึ้นไป โดย<b>รับสัญญาณขาขึ้นที่ความถี่หนึ่ง (uplink) → ขยาย/ทวนสัญญาณ → ส่งลงมาอีกความถี่หนึ่ง (downlink)</b></p>
          <p class="why">ทำไม uplink/downlink ต้อง<b>คนละความถี่</b>? เพราะดาวเทียมรับและส่งพร้อมกัน — ถ้าใช้ความถี่เดียว สัญญาณส่งอันแรงจี๊ดของตัวเองจะกลบสัญญาณรับที่แผ่วมากจากพื้นโลกทันที (นึกถึง SNR!) แยกความถี่ = แยกช่องหูกับปาก · ใช้งานจริง: <b>กระจายสัญญาณโทรทัศน์ · โทรศัพท์ทางไกล · เครือข่ายธุรกิจส่วนตัว</b></p>
          <p><b>3. การถ่ายทอดสัญญาณวิทยุ (broadcast radio)</b> — ใช้เสาแบบ<b>รอบทิศทาง</b> สายอากาศ<b>ไม่จำเป็นต้องเป็นจาน ไม่ต้องยึดแน่นหนาหรือตั้งมุมเป๊ะ</b> (ต่างจากไมโครเวฟชัดๆ — เพราะไม่ต้องเล็ง) · ครอบคลุมแถบ <b>VHF และบางส่วนของ UHF: 30 MHz ถึง 1 GHz</b> ซึ่งรวม<b>วิทยุ FM และโทรทัศน์ UHF/VHF</b> — ย่าน FM 88–108 MHz ที่อาจารย์ใช้สอน FDM เมื่อสัปดาห์ก่อนก็อยู่ในนี้</p>
        </Step>

        <!-- ============ 18 ============ -->
        <Step kind="anim" icon="🚌" title="Multiplexing — สายเส้นเดียว ทำไมให้หลายคนใช้พร้อมกันได้ (FDM/TDM ฉบับเต็ม)" id="mux">
          <p>ปิดท้ายด้วยเรื่องที่ Week 2 ค้างไว้ว่า "เดี๋ยว Week 3 เจอเต็มๆ" — <span class="term">การมัลติเพลกซ์ (Multiplexing)</span> เกิดจากข้อสังเกตง่ายๆ ในสไลด์: <b>ความจุของสื่อส่วนใหญ่ "เกิน" ความจุที่สัญญาณเดี่ยวต้องการ</b> — ลากใยแก้วมาทั้งเส้นแต่ให้คนคุยคนเดียว = เปลืองมหาศาล จึง<b>รวมหลายสัญญาณส่งในสื่อเดียว</b>ให้คุ้ม → ใช้สื่ออย่างมีประสิทธิภาพ</p>
          <p>สไลด์ "เหตุผลสำหรับการใช้อย่างแพร่หลาย" ให้เหตุผลเชิงเศรษฐศาสตร์ 3 ข้อ:</p>
          <ul>
            <li><b>ราคาต่อ kbps ถูกลง เมื่อเพิ่มอัตราการส่ง</b> — ระบบใหญ่หารเฉลี่ยถูกกว่า (economy of scale)</li>
            <li><b>ราคาอุปกรณ์รับ-ส่งต่อหน่วยก็ถูกลง</b> เมื่ออัตราส่งสูงขึ้น</li>
            <li><b>อุปกรณ์แต่ละชิ้นส่วนใหญ่ต้องการอัตราส่งไม่มาก</b> — คนเดียวใช้ไม่หมดอยู่แล้ว ยิ่งควรแชร์</li>
          </ul>
          <p>สองเทคนิคหลัก (สไลด์ 48) — นิยามแบบเป๊ะๆ ว่าแต่ละแบบ "กินของเหลือ" คนละแกน:</p>
          <ul>
            <li><b>FDM (Frequency-Division Multiplexing)</b> — ใช้ข้อดีของความจริงที่ว่า <b>แบนด์วิดท์ของสื่อ เกินกว่า แบนด์วิดท์ที่สัญญาณหนึ่งต้องการ</b> → ซอยย่านความถี่แจกคนละช่อง ทุกคนส่ง<b>พร้อมกันตลอดเวลา</b> คนละความถี่ (วิทยุ FM 88–108 MHz คือ FDM ธรรมชาติ)</li>
            <li><b>TDM (Time-Division Multiplexing)</b> — ใช้ข้อดีของความจริงที่ว่า <b>อัตราส่งข้อมูลของสื่อ เกินกว่า อัตราที่สัญญาณดิจิทัลเดี่ยวต้องการ</b> → ทุกคนได้ใช้<b>ทั้งย่าน</b>แต่<b>ผลัดกันเป็นช่องเวลา</b>สั้นๆ วนไป</li>
          </ul>
          <div class="lab">
            <h4>🎬 FDM vs TDM — ดูคู่กันชัดๆ</h4>
            <canvas id="mux3Canvas"></canvas>
          </div>
          <p>สไลด์สุดท้าย (Synchronous TDM System) แสดงระบบ TDM แบบ<b>ซิงโครนัส</b>: แต่ละแหล่งข้อมูลมีบัฟเฟอร์ ตัวมัลติเพลกเซอร์<b>สแกนแจกช่องเวลาให้ตายตัว</b>เวียนเป็นรอบๆ (เฟรม) — ฝั่งรับก็รู้เลยว่าช่องที่ 1 ของทุกรอบเป็นของผู้ใช้คนที่ 1 เสมอ · จุดอ่อนที่มองเห็นได้จากนิยาม: ถ้าผู้ใช้บางคน<b>ไม่มีอะไรจะส่ง ช่องเวลาของเขาก็ว่างเปล่า</b> (จองไว้แต่ไม่ใช้ — กลิ่นเดียวกับ circuit switching ของ Week 2 เลยใช่ไหม)</p>
          <p class="why">มองย้อนทั้ง 3 สัปดาห์ — Week 2 เจอ FDM/TDM ในลิงก์ระหว่างโหนดสวิตช์ · Week 3 เข้าใจมันจากมุมฟิสิกส์ของแบนด์วิดท์ · และแนวคิด "แบ่งทรัพยากรคลื่น" นี้คือบรรพบุรุษตรงๆ ของเทคโนโลยีที่มือถือคุณใช้อยู่ตอนนี้ (4G/5G ใช้ลูกผสมที่ซอยทั้งความถี่และเวลาพร้อมกัน)</p>
        </Step>

        <!-- ============ 18.5 คิดไว ============ -->
        <Step kind="check" icon="⚡" title="วิธีคิดไว ๆ สำหรับห้องสอบ — โจทย์คำนวณของบทนี้มีอยู่ 3 ทรง" id="fast">
          <p><span class="plus">เสริมจากผู้เขียน</span> โจทย์เลขของ Week 3 วนอยู่ 3 ทรง: หา λ · Nyquist · Shannon(+Nyquist ย้อน) — เก็บสูตรลัดต่อทรง:</p>

          <p><b>① หา λ เร็ว</b> — จำเลขเดียว: <b>λ(เมตร) = 300 ÷ f(MHz)</b> (มาจาก c = 3×10⁸ = 300 × 10⁶):</p>
          <div class="formula">30 MHz → 300/30 = 10 m (โจทย์ครู ✓)   ·   100 MHz → 3 m   ·   300 MHz → 1 m
2.4 GHz = 2400 MHz → 300/2400 = 0.125 m = 12.5 cm (WiFi)
เช็กทิศ: ความถี่ยิ่งสูง λ ยิ่งสั้น — ถ้าคำตอบสวนทางนี้ = หารกลับด้านแน่นอน</div>

          <p><b>② เลือกสูตรให้ถูกใน 5 วินาที</b>:</p>
          <table class="tbl">
            <thead><tr><th>โจทย์พูดถึง…</th><th>ใช้</th><th>สูตร</th></tr></thead>
            <tbody>
              <tr><td>"ไม่มี noise" / ให้จำนวนระดับ M มา / ถามจำนวนระดับ</td><td><b>Nyquist</b></td><td>C = 2B·log₂M</td></tr>
              <tr><td>ให้ SNR หรือ SNR_dB มา / "ตามทฤษฎีสูงสุด"</td><td><b>Shannon</b></td><td>C = B·log₂(1+SNR)</td></tr>
              <tr><td>ให้ SNR แล้ว<b>ถามจำนวนระดับ</b></td><td><b>ทั้งคู่ต่อกัน</b></td><td>Shannon หา C → Nyquist ย้อนหา M</td></tr>
            </tbody>
          </table>

          <p><b>③ ลำดับกดเครื่องโจทย์ Shannon</b> (ทรงเดียวกับโจทย์ครูทุกข้อ):</p>
          <div class="formula">1. B = ขอบบน − ขอบล่าง                    ← "สเปกตรัม 3–4 MHz" คือความกว้าง 1 MHz ไม่ใช่ 4!
2. SNR = 10^(SNR_dB ÷ 10)                 ← ถอด dB: หารสิบ แล้ว 10^x
3. C = B × [ log(1+SNR) ÷ log(2) ]        ← เครื่องไม่มี log₂ → เปลี่ยนฐานด้วย log ปุ่มเดียวกัน
4. ถ้าถามระดับ: log₂M = C ÷ 2B → M = 2^นั้น</div>
          <p><b>ทริคตรวจเลขไว</b>: SNR+1 มักถูกตั้งให้ใกล้กำลังของ 2 — เจอ SNR_dB = 18 → SNR ≈ 63 → 63+1 = <b>64 = 2⁶</b> → log₂ = 6 จบในหัว
            · เจอ 24 dB → 251+1 = 252 ≈ 256 = 2⁸ → log₂ ≈ 8 (เป๊ะ ๆ คือ 7.98) · เจอ 30 dB → 1001 ≈ 1024 = 2¹⁰ → log₂ ≈ 10</p>
          <table class="tbl">
            <thead><tr><th>สถานการณ์</th><th>ทำอะไร</th><th>งบเวลา</th></tr></thead>
            <tbody>
              <tr><td>หา λ / f / T</td><td>λ = 300/f(MHz) · T = 1/f — จบในหัวหรือกดครั้งเดียว</td><td>~30 วิ</td></tr>
              <tr><td>Nyquist ตรง ๆ</td><td>C = 2B·log₂M (M เป็นกำลัง 2 เสมอ → log₂ นับเอา)</td><td>~1 นาที</td></tr>
              <tr><td>Shannon เต็มทรง (เหมือนโจทย์ครู)</td><td>ไล่ 4 ขั้นตาม ③ — เขียนทุกขั้นลงกระดาษ</td><td>~5 นาที</td></tr>
              <tr><td>ถามหน่วยแบนด์วิดท์</td><td><b>Hz เสมอในวิชานี้</b> (ไม่ใช่ bps!) — อย่าหลุด</td><td>~5 วิ</td></tr>
            </tbody>
          </table>
        </Step>

