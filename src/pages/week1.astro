---
import Base from '../layouts/Base.astro';
import Step from '../components/Step.astro';
import WeekNav from '../components/WeekNav.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// เฉลยการบ้านครั้งที่ 1 — kim สั่งเปิดขึ้นเว็บทั้งหมด (11 ก.ค. 2569) · flag เก็บไว้เผื่ออยากซ่อนการบ้านชุดหน้า
const showHw1 = true;
const sections = [
  { id: 'why', label: 'ทำไมวิศวกรไม่บวกเลขธรรมดา' },
  { id: 'log', label: 'Logarithm จากราก' },
  { id: 'props', label: 'สมบัติ log + quiz' },
  { id: 'db', label: 'Decibel (dB)' },
  { id: 'units', label: 'dBW / dBm' },
  { id: 'linkbudget', label: 'Link budget (โจทย์หลัก)' },
  { id: 'calc', label: 'เครื่องคิด link budget' },
  { id: 'fast', label: 'คิดไวในห้องสอบ' },
  { id: 'code', label: 'โค้ดรันได้' },
  { id: 'exam', label: 'ข้อสอบจำลองจับเวลา' },
  ...(showHw1 ? [{ id: 'hw', label: '📝 การบ้านครั้งที่ 1 (ของจริง)' }] : []),
  { id: 'summary', label: 'Quick reference' },
];
---
<Base title="Week 1 — Logarithm + Decibel (dB) ให้เห็นภาพ">
  <main class="wrap">
    <div class="crumb"><a href={`${base}/`}>หน้าแรก</a> / Week 1</div>
    <h2>Week 1 · Basic Math — Logarithm + Decibel</h2>
    <p class="hint">ภาษากลางของวิศวกรสื่อสารทั้งวงการ — <b>ออกสอบเยอะ</b> และเป็นฐานของทุกสัปดาห์ถัดไป
      เราจะเรียนจากราก: ทำไม log เปลี่ยนคูณเป็นบวก → ทำไม dB มีเลข 10 → เดินโจทย์ link budget ครบ 3 วิธีตามสไลด์</p>
    <div class="formula" style="max-width:730px">เส้นทางของบทนี้:  50 W ─▸ ×0.5 ─▸ ×20 ─▸ ×10⁻¹⁰ ─▸ ×20 ─▸ ×0.5 ─▸ 0.5 µW
คิดแบบวัตต์ = คูณเลขยักษ์ 5 ครั้ง   ·   คิดแบบ dB = 17−3+13−100+13−3 = −63 จบ</div>

    <div class="shell">
      <WeekNav week={1} sections={sections} />

      <div class="lesson-main">

        <!-- ════════════ 0 · ทำไมต้องเรียน ════════════ -->
        <Step kind="real" icon="🎯" title="ทำไมวิศวกรไม่บวกเลขธรรมดา" id="why">
          <p>เปิดหน้าจอมือถือแล้วกดดูความแรงสัญญาณ จะเจอเลขประมาณ <code>−90 dBm</code> — เลขนี้แปลว่าโทรศัพท์กำลังรับพลังงานอยู่จริง ๆ แค่
            <code>0.000000000001 วัตต์</code> (10⁻¹² W) ขณะที่เสาส่งปล่อยออกมาหลายสิบวัตต์
            → ค่าที่วิศวกรสื่อสารเจอในงานเดียวกัน <b>ต่างกันเป็นสิบล้านล้านเท่า</b></p>
          <p>จะจดจะพูดจะคำนวณเลขแบบนี้ตรง ๆ ไม่ไหว: คูณเลข 13 หลักผิดจุดทศนิยมนิดเดียวก็เพี้ยนเป็นสิบเท่า
            วิศวกรเลยตกลงใช้เครื่องมือเดียวกันทั้งวงการ — <span class="term">Logarithm</span> บีบเลขมหาศาลให้เหลือสองหลัก (กลายเป็น <span class="term">dB</span>)
            แล้วการ<b>คูณ/หาร</b>ทั้งหมดจะกลายเป็น<b>บวก/ลบ</b></p>
          <p class="why">สัปดาห์นี้คือ "คณิตล้วน" บทเดียวของวิชา และ<b>ทุกบทหลังจากนี้ใช้มันตลอด</b>: SNR ของ Shannon (W3) เป็น dB,
            path loss เป็น dB, spec อุปกรณ์ทุกชิ้นในโลกเขียนเป็น dB — ลงทุนเข้าใจตรงนี้ครั้งเดียว ใช้ยาวทั้งเทอม (และทั้งอาชีพ)</p>

          <div class="lab">
            <h4>🎬 ทำไมไม้บรรทัดธรรมดาถึงพัง — แล้ว log ช่วยยังไง</h4>
            <div id="viz-scale"></div>
          </div>
        </Step>

        <!-- ════════════ 1 · Logarithm จากราก ════════════ -->
        <Step kind="intu" icon="💡" title="Logarithm จากราก — มันคือ “เครื่องถามหาเลขชี้กำลัง”" id="log">
          <p>นิยามทางการ (สไลด์ 2):</p>
          <div class="formula">y = log_b(x)   ⟺   b^y = x        โดยที่ x &gt; 0,  b &gt; 0,  b ≠ 1</div>
          <p>แปลเป็นภาษาคน: <b>"ต้องเอาฐาน b ยกกำลังเท่าไหร่ ถึงจะได้ x"</b> — log ไม่ใช่การคำนวณแปลกใหม่
            มันคือ<b>การยกกำลังที่ถามกลับด้าน</b>:</p>
          <div class="formula">ยกกำลังถาม:  10³ = ?        → ตอบ 1000
log ถาม:     10^? = 1000    → ตอบ 3     ← log₁₀(1000) = 3 "นับว่ายกกี่ครั้ง"</div>
          <ul>
            <li><b>ทำไม x &gt; 0:</b> ฐานบวกยกกำลังอะไรก็ได้ค่าบวกเสมอ — ไม่มีเลขชี้กำลังไหนให้ 0 หรือค่าลบได้ → log ของ 0/ค่าลบ ไม่มีนิยาม (ดูขั้นที่ 4 ใน animation: เส้นดิ่งลง −∞ ตรงขอบซ้าย)</li>
            <li><b>ทำไม b ≠ 1:</b> 1 ยกกำลังอะไรก็ได้ 1 ตลอด — ถามว่า "1 ยกกี่ครั้งได้ 8" ไม่มีคำตอบ ฐานนี้ใช้ไม่ได้</li>
          </ul>
          <p><b>ทำไมมีหลายฐาน?</b> เพราะแต่ละงานนับ "การคูณ" คนละแบบ:</p>
          <table class="tbl">
            <thead><tr><th>ฐาน</th><th>นับอะไร</th><th>ใช้ที่ไหนในวิชานี้</th></tr></thead>
            <tbody>
              <tr><td><b>10</b></td><td>นับ "คูณสิบกี่ครั้ง" (นับศูนย์)</td><td><b>dB — เรื่องหลักของบทนี้</b></td></tr>
              <tr><td><b>2</b></td><td>นับ "คูณสองกี่ครั้ง" (นับบิต)</td><td>สูตร Shannon / จำนวนระดับสัญญาณ (Week 3)</td></tr>
              <tr><td><b>e</b> (ln)</td><td>การเติบโตต่อเนื่อง</td><td>โผล่ในแคลคูลัส/ทฤษฎี ไม่ใช่ตัวเด่นของวิชานี้</td></tr>
            </tbody>
          </table>

          <div class="lab">
            <h4>🎬 กราฟ y = log_b(x) สามฐาน (รูปเดียวกับสไลด์ 2 — แต่กดเดินดูได้)</h4>
            <div id="viz-logcurve"></div>
          </div>
        </Step>

        <!-- ════════════ 2 · สมบัติ log ════════════ -->
        <Step kind="deep" icon="📐" title="สมบัติของ log — ห้ามท่องลอย ๆ ต้องรู้ว่ามาจากไหน + ใช้ตอนไหน" id="props">
          <p>สมบัติทุกข้อ (สไลด์ 3) งอกมาจากความจริงข้อเดียว: <b>คูณเลขฐานเดียวกัน = บวกเลขชี้กำลัง</b> (b² × b³ = b⁵)
            พอ log คือ "เครื่องอ่านเลขชี้กำลัง" มันเลยเห็นการคูณเป็นการบวกโดยอัตโนมัติ:</p>
          <div class="formula">ให้  x = b^m  และ  y = b^n     (นั่นคือ m = log_b x,  n = log_b y)
x·y = b^m · b^n = b^(m+n)      → log_b(x·y) = m + n = log_b(x) + log_b(y)  ∎
เหตุผลเดียวกัน: x/y = b^(m−n) → log หาร = ลบ  ·  xⁿ = b^(m·n) → log ยกกำลัง = คูณ n</div>
          <table class="tbl">
            <thead><tr><th>สมบัติ (สไลด์ 3)</th><th>สูตร</th><th>ใช้ทำอะไรจริงในวิชานี้</th></tr></thead>
            <tbody>
              <tr><td>การคูณ</td><td>log_b(xy) = log_b(x) + log_b(y)</td><td><b>หัวใจ link budget</b>: gain/loss คูณกัน = dB บวกกัน</td></tr>
              <tr><td>การหาร</td><td>log_b(x/y) = log_b(x) − log_b(y)</td><td>SNR = S÷N → คิดเป็น dB คือลบกัน (W3)</td></tr>
              <tr><td>การยกกำลัง</td><td>log_b(xⁿ) = n·log_b(x)</td><td>×10⁻¹⁰ → −10×10 = −100 dB ในพริบตา</td></tr>
              <tr><td>การเปลี่ยนฐาน</td><td>log_b(x) = log_a(x) / log_a(b)</td><td>เครื่องคิดเลขมีแต่ log₁₀ → ใช้หา log₂ ได้ (ดูกล่อง 🎙️)</td></tr>
              <tr><td>การผกผัน</td><td>log_b(bˣ) = x และ b^(log_b x) = x</td><td>"ถอด dB กลับเป็นเท่า": ยกกำลังลบล้าง log</td></tr>
            </tbody>
          </table>

          <div class="note">⚠️ <b>ข้อควรระวังจากสไลด์ (กับดักข้อสอบคลาสสิก):</b><br>
            <code>log_a(x + y) ≠ log_a x + log_a y</code> &nbsp;·&nbsp; <code>log_a(x − y) ≠ log_a x − log_a y</code><br>
            log แยกได้เฉพาะ<b>คูณ/หาร</b>ข้างใน — <b>บวก/ลบข้างในแยกไม่ได้เด็ดขาด</b>
            (ลองแทนเลขดู: log(10+10) = log 20 ≈ 1.3 แต่ log 10 + log 10 = 2 — ไม่เท่ากันชัด ๆ)</div>

          <div class="lect">
            <span class="who">🎙️ อาจารย์ใช้ของพวกนี้จริงกลางห้อง <span class="from">จากเลคเชอร์สัปดาห์ 3</span></span>
            ตอนทำโจทย์ Shannon อาจารย์ต้องหา log₂(252) แล้วถามทั้งห้องว่า <i>"เครื่องคิดเลขมี log₂ ไหม? …ไม่มี! ถ้าไม่มีทำยังไง"</i>
            คำตอบคือสมบัติ<b>เปลี่ยนฐาน</b>ที่เรียนตรงนี้แหละ: <code>log₂(252) = log₁₀(252) ÷ log₁₀(2) ≈ 7.98</code>
            — สมบัติข้อนี้ไม่ใช่ของประดับชีท มันคือ<b>ทางรอดตอนกดเครื่องคิดเลขในห้องสอบ</b>
          </div>

          <div class="lab">
            <h4>✍️ Examples จากสไลด์ 4 — กดตอบเองก่อน แล้วเทียบเฉลยสไลด์ 5</h4>
            <p class="hint" style="margin:0 0 10px">ค่าพิเศษพวกนี้ออกสอบบ่อยสุด เพราะใช้เช็กว่าเข้าใจนิยามจริงไหม</p>
            <div id="logquiz"></div>
          </div>
        </Step>

        <!-- ════════════ 3 · Decibel ════════════ -->
        <Step kind="intu" icon="🔊" title="Decibel (dB) — เอา log มาใช้วัดกำลังงาน" id="db">
          <p>นิยามจากสไลด์ 6: <span class="term">Decibel (dB)</span> = หน่วยที่อยู่ในรูปของล็อกการิทึม
            ใช้ระบุ<b>อัตราส่วน</b>ของกำลังงานหรือความเข้ม เทียบกับระดับอ้างอิง:</p>
          <div class="formula">Loss_dB = 10·log₁₀(P_t / P_r)      ← ส่งไป P_t เหลือ P_r "เสียไปกี่ dB"
Gain_dB = 10·log₁₀(P_out / P_in)   ← เข้า P_in ออก P_out "ขยายกี่ dB"</div>
          <p><b>ทำไมต้องคูณ 10?</b> <span class="plus">เสริมจากผู้เขียน</span> หน่วยดั้งเดิมคือ <i>bel</i> (ตั้งตามชื่อ Alexander Graham Bell):
            1 bel = log₁₀ ของอัตราส่วน = "ต่างกันสิบเท่า" — หยาบเกินไปสำหรับงานจริง เลยหั่นเป็นสิบส่วน:
            <b>deci-bel = 1/10 ของ bel</b> → ต้องคูณ 10 เข้าไปในสูตร ผลพลอยได้คือเลขสวย: ×10 = 10 dB, ×100 = 20 dB</p>
          <p>สังเกตว่าทั้งสองสูตรจงใจเอา<b>ตัวใหญ่ตั้ง หารตัวเล็ก</b> เพื่อให้ค่าออกมาเป็นบวก แล้วชื่อ (Loss/Gain) บอกทิศแทน
            — เวลาใช้ใน link budget เราจะติดเครื่องหมายเอง: gain = +dB, loss = −dB แล้วบวกยาวรวดเดียว</p>

          <div class="note">⚠️ <b>คำเตือนตัวแดงในสไลด์ (อาจารย์เน้น): "ระวังเรื่องหน่วยให้ดี"</b><br>
            เดซิเบลเป็น<b>ค่ากลาง</b> — ขึ้นอยู่ว่านำไปใช้เปรียบเทียบกับค่าใด และค่าก่อนเข้า log ต้อง<b>ไม่มีหน่วย</b>
            (เป็นอัตราส่วนล้วน ๆ เช่น W÷W หรือ mW÷mW) → ห้ามเอา W ตั้งหารด้วย mW โดยไม่แปลงก่อน
            — นี่คือจุดที่คะแนนหายบ่อยที่สุดของบทนี้</div>

          <div class="lect">
            <span class="who">🎙️ ทักษะ "ถอด dB กลับ" ที่อาจารย์ใช้สด <span class="from">จากเลคเชอร์สัปดาห์ 3</span></span>
            โจทย์ Shannon ให้ SNR มาเป็น <b>24 dB</b> อาจารย์เดินสมการกลับให้ดูทั้งห้อง:
            <code>24 = 10·log₁₀(SNR)</code> → เอา 10 หารสองฝั่ง → <code>2.4 = log₁₀(SNR)</code> → ยกกำลังถอด log →
            <code>SNR = 10^2.4 ≈ 251 ≈ 250 เท่า</code> — ข้อสอบชอบให้ dB มาแล้วต้องแปลงกลับเป็น "กี่เท่า" ก่อนใช้สูตรอื่นเสมอ
            จำวงจรนี้ให้คล่อง: <b>÷10 → ยกกำลัง 10</b>
          </div>
        </Step>

        <!-- ════════════ 4 · dBW / dBm ════════════ -->
        <Step kind="deep" icon="⚖️" title="dBW กับ dBm — dB เพียว ๆ บอกแค่ “กี่เท่า” ต้องปักหมุดอ้างอิงถึงบอก “กี่วัตต์”" id="units">
          <p>ประโยค "สัญญาณแรง 20 dB" ยังตอบไม่ได้ว่ากี่วัตต์ — 20 dB บอกแค่ "×100" แต่ <b>×100 ของอะไร?</b>
            พอเลือกจุดอ้างอิงตายตัว dB ก็กลายเป็นหน่วยวัดกำลังจริงได้ (สไลด์ 7):</p>
          <div class="formula">P_dBW = 10·log₁₀(P / 1 W)                    ← ปักหมุดที่ 1 วัตต์
P_dBm = 10·log₁₀(P / 1 mW) = 10·log₁₀(P / 10⁻³ W)   ← ปักหมุดที่ 1 มิลลิวัตต์
Note:  P มีหน่วยเป็นวัตต์  ·  P_dBm = P_dBW + 30</div>
          <p><b>เลข 30 มาจากไหน?</b> จุดอ้างอิงสองตัวต่างกัน 1,000 เท่า (1 W = 1,000 mW = ต่างกัน 3 ศูนย์)
            → log ต่างกัน 3 → คูณ 10 ได้ <b>30 dB เป๊ะ ๆ เสมอ</b> — ค่าเดียวกันมองผ่านไม้บรรทัดสองอัน:</p>
          <div class="formula">ตัวอย่างจากสไลด์ 7:   1 mW  = −30 dBW = 0 dBm      (1 mW คือ "ศูนย์" ของราง dBm)
                      100 W = +20 dBW = +50 dBm</div>
          <p class="why">ทำไมนิยมใช้ dBm มากกว่า dBW ในงานวิทยุ: อุปกรณ์รับส่งจริงเล่นกันระดับ mW ถึง pW
            — ปักหมุดที่ 1 mW แล้วเลขส่วนใหญ่ที่เจอจะอยู่แถว ๆ ศูนย์พอดี (WiFi ส่ง +20 dBm, มือถือรับ −90 dBm)</p>

          <div class="lab">
            <h4>🔬 บันไดสองราง dBW / dBm — เลื่อนดูเองว่า “ห่าง 30 ตลอด”</h4>
            <div id="viz-ladder"></div>
          </div>

          <p>ตารางเต็มจากสไลด์ 8 (ไล่ครบทุกขั้น ×10 — คอลัมน์ dB ขยับทีละ 10 และต่างกัน 30 ตลอด):</p>
          <table class="tbl">
            <thead><tr><th>P (วัตต์)</th><th>อ่านว่า</th><th>dBW</th><th>dBm</th></tr></thead>
            <tbody>
              <tr><td>0.000001</td><td>1 µW (ไมโครวัตต์)</td><td>−60</td><td>−30</td></tr>
              <tr><td>0.00001</td><td>10 µW</td><td>−50</td><td>−20</td></tr>
              <tr><td>0.0001</td><td>100 µW</td><td>−40</td><td>−10</td></tr>
              <tr><td>0.001</td><td>1 mW (มิลลิวัตต์)</td><td>−30</td><td>0</td></tr>
              <tr><td>0.01</td><td>10 mW</td><td>−20</td><td>+10</td></tr>
              <tr><td>0.1</td><td>100 mW</td><td>−10</td><td>+20</td></tr>
              <tr><td>1</td><td>1 W (วัตต์)</td><td>0</td><td>+30</td></tr>
              <tr><td>10</td><td>10 W</td><td>+10</td><td>+40</td></tr>
              <tr><td>100</td><td>100 W</td><td>+20</td><td>+50</td></tr>
              <tr><td>1,000</td><td>1 kW (กิโลวัตต์)</td><td>+30</td><td>+60</td></tr>
