---
import Base from '../layouts/Base.astro';
import Step from '../components/Step.astro';
import WeekNav from '../components/WeekNav.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sections = [
  { id: 'why', label: 'กด Enter แล้วเกิดอะไร' },
  { id: 'elements', label: 'องค์ประกอบการสื่อสาร' },
  { id: 'protocol', label: 'โพรโทคอล 3 ฟีเจอร์' },
  { id: 'layers', label: 'ทำไมต้องแบ่งชั้น' },
  { id: 'tcpip', label: 'TCP/IP 5 ชั้น (ลึก)' },
  { id: 'addressing', label: 'ที่อยู่ 3 ระดับ' },
  { id: 'enc', label: '🎬 ห่อ–แกะ ผ่าน router' },
  { id: 'osi', label: 'OSI 7 ชั้น (ลึก)' },
  { id: 'versus', label: 'OSI vs TCP/IP' },
  { id: 'terms', label: 'ES/IS/bridge/router' },
  { id: 'nettypes', label: 'LAN / MAN / WAN' },
  { id: 'switchnet', label: '🎬 เครือข่ายสวิตช์' },
  { id: 'circuit', label: '🎬 Circuit switching' },
  { id: 'packet', label: '🎬 Packet switching' },
  { id: 'dgvc', label: '🎬 Datagram vs VC' },
  { id: 'timing', label: '🎬 ใครเร็วกว่า (timing)' },
  { id: 'psize', label: '🧪 ขนาดแพ็กเก็ต' },
  { id: 'hw', label: '📝 การบ้านอาจารย์' },
  { id: 'check', label: 'เช็กเข้าใจ' },
  { id: 'summary', label: 'สรุป' },
];
---
<Base title="Week 2 — ข้อมูลเดินทางยังไง">
  <main class="wrap">
    <div class="crumb"><a href={`${base}/`}>หน้าแรก</a> / Week 2</div>
    <h2>Week 2 · ข้อมูลเดินทางยังไง</h2>
    <p class="hint">โพรโทคอล · TCP/IP · OSI · Switching — เรียบเรียงจาก<b>คาบบรรยายจริง + สไลด์ครบทั้ง 68 แผ่น</b> ไม่ข้ามหัวข้อ · กล่องสีส้ม = สิ่งที่อาจารย์พูดในห้องซึ่งไม่มีในสไลด์ · ป้าย "เสริม" = ส่วนที่เราเพิ่มให้เพื่อความเข้าใจ (นอกเหนือเนื้อหาวิชา)</p>

    <div class="shell">
      <WeekNav week={2} sections={sections} />
      <div class="lesson-main">

        <!-- ============ 1. เปิดเรื่อง ============ -->
        <Step kind="real" icon="🎯" title="กด Enter ส่งข้อความ แล้วเกิดอะไรขึ้น?" id="why">
          <p>สัปดาห์ที่แล้วเราคุยเรื่อง "พลังของสัญญาณ" (dB, link budget) — คือฟิสิกส์ของการส่ง แต่สัปดาห์นี้คือคำถามที่ใหญ่กว่า: <b>ข้อมูล</b> ที่เราพิมพ์ เดินทางจากเครื่องเราไปโผล่ที่เครื่องเพื่อนอีกซีกโลก <b>ได้ยังไง</b> ทั้งที่สองเครื่องไม่เคยรู้จักกัน คนละยี่ห้อ คนละระบบปฏิบัติการ ต่ออินเทอร์เน็ตคนละแบบ (เราใช้ WiFi เพื่อนใช้สายแลน)?</p>
          <p>คำตอบสั้นๆ คือ <b>"เพราะทุกเครื่องยอมเล่นตามกติกาเดียวกัน"</b> — กติกานั้นเรียกว่า <span class="term">โพรโทคอล (protocol)</span> และเพื่อไม่ให้กติกาซับซ้อนเกินไป โลกเครือข่ายจึงหั่นงานใหญ่เป็น "ชั้นๆ" (layers) แล้วให้แต่ละชั้นรับผิดชอบงานเดียว — สัปดาห์นี้เราจะไล่ตั้งแต่กติกา → ชั้น → อุปกรณ์ → ไปจนถึง "ปรัชญาการเดินทางของข้อมูล" สองสำนักใหญ่ (จองสาย vs หั่นเป็นก้อน) ที่เป็นเหตุผลว่าทำไมโทรศัพท์บ้านกับอินเทอร์เน็ตทำงานคนละแบบ</p>
          <p class="why">เปรียบง่ายสุด: การส่งข้อมูล = <b>การส่งพัสดุ</b> ของจริงต้องใส่กล่อง → จ่าหน้า → ผ่านศูนย์คัดแยกหลายศูนย์ → ผู้รับแกะกล่อง ทุกขั้นมี "กติกา" ของมัน (กล่องขนาดไหน จ่าหน้าตรงไหน ศูนย์ไหนคัดยังไง) — จำภาพนี้ไว้ เพราะทั้งสัปดาห์นี้คือพัสดุเวอร์ชันดิจิทัลเป๊ะๆ</p>
        </Step>

        <!-- ============ 2. องค์ประกอบการสื่อสาร ============ -->
        <Step kind="intu" icon="🧩" title="องค์ประกอบของการสื่อสาร — ขาด 1 ใน 5 = คุยกันไม่ได้" id="elements">
          <p>ก่อนพูดเรื่องเทคนิค ต้องเห็นก่อนว่า "การสื่อสารข้อมูล" ต้องมีอะไรบ้าง สไลด์แรกของอาจารย์ให้ครบ 5 ตัว ลองไล่ทีละตัวพร้อมถามว่า <i>ถ้าไม่มีตัวนี้จะเกิดอะไร</i>:</p>
          <p><b>1. ผู้ส่งข้อมูล (Sender)</b> — ฝ่ายที่ทำหน้าที่ส่งข้อมูลออกไป เช่น มือถือของเราตอนกดส่งข้อความ · ไม่มีผู้ส่ง = ไม่มีอะไรเกิดขึ้นเลย</p>
          <p><b>2. ผู้รับข้อมูล (Receiver)</b> — ฝ่ายที่ทำหน้าที่รับ เช่น เครื่องเพื่อน · ไม่มีผู้รับ = ส่งไปก็เหมือนตะโกนใส่ความว่างเปล่า</p>
          <p><b>3. ข้อมูล (Data)</b> — สิ่งที่ผู้ส่งอยากให้ถึงผู้รับ ซึ่ง<b>ไม่จำเป็นต้องเป็นข้อความ</b> อาจเป็นเสียง ภาพนิ่ง วิดีโอ/ภาพเคลื่อนไหว — ประเด็นสำคัญที่จะเจอตลอดวิชานี้คือ ไม่ว่าข้อมูลหน้าตาแบบไหน สุดท้ายมันถูกแปลงเป็น "บิต" (0/1) เหมือนกันหมด</p>
          <p><b>4. สื่อนำข้อมูล (Medium)</b> — ตัวกลางที่พาข้อมูลเดินทาง เช่น สายเคเบิล ใยแก้วนำแสง หรือ<b>อากาศ</b> (นี่แหละที่ทำให้วิชานี้ชื่อ Wireless — สื่อของเราคืออากาศ/คลื่นวิทยุ) · ไม่มีสื่อ = ข้อมูลไม่มีทางไป</p>
          <p><b>5. โพรโทคอล (Protocol)</b> — <b>กฎหรือวิธีที่ถูกกำหนดขึ้น</b>เพื่อให้การสื่อสารเป็นรูปแบบเดียวกัน ตามที่ผู้ส่งกับผู้รับ "ตกลงกันไว้ก่อน" · ตัวนี้สำคัญสุดและมองไม่เห็นด้วยตา: มีครบ 4 ข้อแรกแต่ไม่มีข้อ 5 ก็เหมือนคนไทยโทรหาคนฝรั่งเศสแล้วต่างคนต่างพูดภาษาตัวเอง — สัญญาณถึงกันแต่<b>สื่อสารกันไม่ได้</b></p>
          <p class="why">ลองแมปกับการส่ง LINE: ผู้ส่ง = มือถือเรา · ผู้รับ = มือถือเพื่อน · ข้อมูล = สติกเกอร์ · สื่อ = อากาศ (WiFi) ต่อด้วยสายใยแก้วของ ISP · โพรโทคอล = กติกาที่แอป LINE, ระบบปฏิบัติการ, เราเตอร์ และเซิร์ฟเวอร์ทุกตัวตกลงใช้ร่วมกัน ครบ 5 อย่างเป๊ะ</p>
        </Step>

        <!-- ============ 3. โพรโทคอล ============ -->
        <Step kind="deep" icon="📜" title="โพรโทคอลต้องกำหนดอะไรบ้าง — Syntax · Semantics · Timing" id="protocol">
          <p>คำว่า "กติกาการสื่อสาร" ฟังดูลอยๆ สไลด์ของอาจารย์เจาะให้ว่า กติกาที่สมบูรณ์ต้องตอบ 3 เรื่อง (นี่คือ "ฟีเจอร์หลักของโพรโทคอล"):</p>
          <p><b>1. Syntax (วากยสัมพันธ์/รูปแบบ)</b> — เกี่ยวกับ<b>รูปแบบของบล็อกข้อมูล</b>: ก้อนข้อมูลหน้าตาเป็นยังไง อะไรอยู่ตรงไหน กี่บิต เรียงยังไง — เหมือน "แบบฟอร์มราชการ" ที่บังคับว่าชื่ออยู่บรรทัดแรก ที่อยู่บรรทัดสอง ทุกคนกรอกเหมือนกัน เครื่องอ่านจึงรู้ว่าต้องไปดึงข้อมูลจากตรงไหน · ตัวอย่างจริง: เฮดเดอร์ IP กำหนดว่า 32 บิตตรงนี้คือที่อยู่ปลายทาง เครื่องทุกยี่ห้อจึงอ่านตรงกัน</p>
          <p><b>2. Semantics (ความหมาย)</b> — <b>ข้อมูลควบคุม</b>สำหรับดูแลการทำงานร่วมกัน และการจัดการ<b>ข้อผิดพลาด</b>: บิตก้อนนี้ "แปลว่าอะไร" และต้องทำอะไรต่อ — รู้รูปแบบ (syntax) แต่ไม่รู้ความหมายก็ทำงานไม่ได้ เหมือนอ่านแบบฟอร์มออกแต่ไม่รู้ว่าช่องนี้กรอกไปทำไม · ตัวอย่างจริง: ได้รับสัญญาณ "ตอบรับ (ACK)" ต้องแปลว่าอีกฝั่งได้รับแล้ว จะได้ส่งก้อนถัดไป / ถ้าเจอรหัสบอก error ต้องรู้ว่าจัดการยังไง</p>
          <p><b>3. Timing (จังหวะเวลา)</b> — สองเรื่องย่อย: <b>การแม็ตช์ความเร็ว (speed matching)</b> และ<b>การเรียงลำดับ (sequencing)</b> — เครื่องส่งเร็วคุยกับเครื่องรับช้า ถ้าไม่คุมจังหวะ ฝั่งรับจะ "รับไม่ทัน" ข้อมูลล้นทิ้งหมด และถ้าข้อมูลหลายก้อนถึงไม่เรียงกัน ต้องรู้ว่าจะเรียงกลับยังไง · เหมือนการคุยโทรศัพท์ที่ต้องผลัดกันพูด ไม่พูดพร้อมกัน และเล่าเรื่องตามลำดับ</p>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ (ไม่อยู่ในสไลด์)</span>
          อาจารย์สรุปในห้องว่า "โพรโทคอลที่เราพูดถึง มันมี 3 ส่วนหลักๆ คือแบบนี้" แล้วชี้ว่าเรื่อง timing คือเรื่อง "การแม็ตชิ่งความเร็ว" กับ "การเรียงลำดับ" ซึ่งจะโผล่มาอีกทีตอนเรียน TCP (เรียงลำดับแพ็กเก็ต) — สังเกตว่า 3 ฟีเจอร์นี้ไม่ใช่ท่องเปล่าๆ มันคือโครงที่ทุกโพรโทคอลจริงต้องมีครบ</div>
          <p>สไลด์ถัดมา ("ตัวแปรที่เกี่ยวข้องในการสื่อสาร") ชี้ว่าการสื่อสารเกิดขึ้นพร้อมกัน 3 ระดับ ซึ่งแต่ละระดับมีหน้าที่ของตัวเอง:</p>
          <ul>
            <li><b>ระดับแอปพลิเคชัน</b> — แลกเปลี่ยนข้อมูลระหว่างคอมพิวเตอร์ (เช่น อีเมล): คุยกันเรื่อง "เนื้อหา"</li>
            <li><b>ระดับคอมพิวเตอร์</b> — เครื่องต้องเชื่อมต่อเข้าเครือข่ายให้ได้ก่อน</li>
            <li><b>ระดับเครือข่าย</b> — การโอนถ่ายข้อมูลจากเครื่องหนึ่งไปยังอีกเครื่องหนึ่ง: งาน "ขนส่ง" ล้วนๆ</li>
          </ul>
          <p class="why">เห็นเค้าลางไหม? การแยก 3 ระดับนี้คือ "เชื้อ" ของความคิดเรื่องการแบ่งชั้น (layering) ที่กำลังจะเจอ — งานคนละเรื่องไม่ควรกองในที่เดียว</p>
        </Step>

        <!-- ============ 4. ทำไมต้องแบ่งชั้น ============ -->
        <Step kind="intu" icon="🥞" title="ทำไมต้องแบ่งชั้น? — แนวคิด TCP/IP 5 ชั้น" id="layers">
          <p>ลองคิดว่าถ้าต้องเขียนโปรแกรมเดียวที่ทำ<b>ทุกอย่าง</b>: จัดรูปแบบอีเมล + หั่นข้อมูล + หาเส้นทางข้ามโลก + คุมแรงดันไฟบนสาย… โปรแกรมนั้นจะมหึมา แก้จุดเดียวพังทั้งระบบ และเปลี่ยนไปใช้ WiFi แทนสายแลนทีก็ต้องเขียนใหม่หมด — วิศวกรจึงใช้ท่าคลาสสิกของคนคอม: <b>divide and conquer</b> หั่นงานเป็นชั้น (layer) แต่ละชั้นทำหน้าที่เดียว เสร็จแล้วส่งต่อให้ชั้นถัดไป</p>
          <p>ผลพลอยได้ที่สำคัญมาก 2 ข้อ:</p>
          <ul>
            <li><b>เปลี่ยนชั้นหนึ่งโดยไม่กระทบชั้นอื่น</b> — สลับจากสายแลนเป็น WiFi กระทบแค่ชั้นล่างสุด แอป LINE ข้างบนไม่ต้องรู้ด้วยซ้ำ</li>
            <li><b>ต่างยี่ห้อคุยกันได้</b> — ขอแค่แต่ละชั้นทำตามกติกาของชั้นตัวเอง ใครผลิตอุปกรณ์ก็เสียบเข้าระบบเดียวกันได้</li>
          </ul>
          <p>แบบจำลองที่ใช้งานจริงบนอินเทอร์เน็ตทุกวันนี้คือ <span class="term">TCP/IP</span> แบ่งเป็น <b>5 ชั้น</b> (บน → ล่าง):</p>
          <div class="formula">5. Application  — แอป/บริการที่ผู้ใช้ใช้ (อีเมล เว็บ ไฟล์)
4. Transport (Host-to-Host) — คุมการส่งถึงกัน "ครบ ถูก เรียง" (TCP)
3. Internet     — หาเส้นทางข้ามเครือข่าย (IP)
2. Network Access — คุยกับเครือข่ายที่เครื่องต่ออยู่ (เช่น Ethernet)
1. Physical     — ส่งบิตจริงลงสาย/อากาศ</div>
          <p>ข้อควรรู้จากสไลด์: ชั้น Physical มีเครื่องหมาย ** กำกับว่า <b>"แล้วแต่หนังสือ"</b> — บางตำรานับรวม Physical เข้ากับ Network Access เหลือ 4 ชั้น บางตำราแยกเป็น 5 ชั้น สาระเท่ากัน แค่วิธีนับต่างกัน (อาจารย์ใช้ 5 ชั้นเป็นหลัก ถ้าไปอ่านหนังสือแล้วเจอ 4 ชั้นไม่ต้องงง)</p>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ (สำคัญ — ไม่อยู่ในสไลด์)</span>
          อาจารย์เชื่อมโยงชั้นกับ<b>อุปกรณ์จริง</b>ให้ตั้งแต่ต้นคาบ: <b>Router ทำงานถึงชั้น 3</b> (Internet layer — เพราะมันต้องเปิดอ่านที่อยู่ IP เพื่อหาเส้นทาง) ส่วน <b>Switch ทำงานแค่ชั้น 2</b> (มันดูแค่ที่อยู่ในวง LAN ไม่รู้จัก IP) — ประโยคสั้นๆ นี้คือกุญแจไขคำถามคลาสสิก "router กับ switch ต่างกันยังไง" และจะถูกใช้ซ้ำตอนเรียนเรื่อง bridge/router ข้างล่าง จำแม่นๆ</div>
        </Step>

        <!-- ============ 5. TCP/IP ทีละชั้น ============ -->
        <Step kind="deep" icon="🔍" title="TCP/IP ทีละชั้น — แต่ละชั้นมีหน้าที่อะไร ทำไมต้องมี" id="tcpip">
          <p>ไล่จากล่างขึ้นบน (ตามลำดับสไลด์ของอาจารย์) — อ่านแต่ละชั้นแล้วให้ถามตัวเองว่า "ถ้าตัดชั้นนี้ทิ้ง อะไรพัง?"</p>

          <p><b>ชั้นที่ 1 — Physical layer:</b> ครอบคลุม<b>อินเทอร์เฟซทางกายภาพ</b>ระหว่างอุปกรณ์ส่งข้อมูลกับสื่อที่ใช้ส่ง หน้าที่คือส่ง "บิต" ลงสายหรืออากาศจริงๆ สิ่งที่ชั้นนี้ต้องระบุ: <b>คุณลักษณะของสื่อที่ใช้ส่ง</b> (สายทองแดง? ใยแก้ว? คลื่นวิทยุ?), <b>ธรรมชาติของสัญญาณ</b> (ไฟกี่โวลต์แทน 0/1? คลื่นความถี่เท่าไหร่?), <b>อัตราการส่งข้อมูล</b> (กี่บิตต่อวินาที) และเรื่องกายภาพอื่นๆ ที่เกี่ยวข้อง · ถ้าตัดทิ้ง: ไม่มีอะไรออกจากเครื่องได้เลย — โลกดิจิทัลทั้งใบจอดอยู่บนชั้นนี้</p>

          <p><b>ชั้นที่ 2 — Network Access layer:</b> ระบุวิธี<b>แลกเปลี่ยนข้อมูลระหว่างระบบปลายทาง (end system) กับ "เครือข่ายที่มันต่ออยู่"</b> — คีย์เวิร์ดคือ "เครือข่ายที่ต่ออยู่": ชั้นนี้รู้จักแค่เครือข่ายตรงหน้า ไม่รู้จักโลกทั้งใบ ซอฟต์แวร์ของชั้นนี้จึง<b>ขึ้นอยู่กับชนิดของเครือข่าย</b>ที่ใช้ เช่น เครือข่าย circuit switching, เครือข่าย packet switching (เช่น X.25), เครือข่าย LAN (เช่น Ethernet) ฯลฯ — เปลี่ยนชนิดเครือข่าย เปลี่ยนซอฟต์แวร์ชั้นนี้ แต่ชั้นบนอยู่เหมือนเดิม · ถ้าตัดทิ้ง: เครื่องส่งบิตได้แต่ไม่รู้ธรรมเนียมของเครือข่ายที่ตัวเองเสียบอยู่ (ใครพูดได้ตอนไหน จ่าหน้าในวงยังไง)</p>

          <p><b>ชั้นที่ 3 — Internet layer:</b> ใช้<b>โพรโทคอลไอพี (IP)</b> ให้บริการ<b>ค้นหาเส้นทาง (routing)</b> เพื่อให้ข้อมูลวิ่ง<b>ข้ามหลายเครือข่ายที่เชื่อมต่อกัน</b>ไปถึงปลายทางได้ — นี่คือชั้นที่ทำให้ "inter-net" (ระหว่างเครือข่าย) เกิดขึ้นจริง จุดที่ต้องจำ: ชั้นนี้ถูกใช้<b>ทั้งในระบบปลายทาง (end system) และในเราเตอร์ (router)</b> — เพราะ router คือคนกลางที่ต้องอ่านที่อยู่ IP เพื่อตัดสินใจส่งต่อ · ถ้าตัดทิ้ง: คุยได้แค่ในวง LAN ตัวเอง ออกไปเครือข่ายอื่นไม่ได้ — ไม่มีอินเทอร์เน็ต</p>

          <p><b>ชั้นที่ 4 — Transport (Host-to-Host) layer:</b> โดยปกติใช้ <b>TCP (Transmission Control Protocol)</b> ให้บริการที่<b>มีความน่าเชื่อถือ (reliable)</b> ในการแลกเปลี่ยนข้อมูล ซึ่งแปลว่ารับประกัน 2 อย่าง: <b>ความสมบูรณ์ถูกต้อง</b> (ครบทุกก้อน ไม่เพี้ยน) และ<b>การเรียงลำดับ</b> (ก้อนที่ 1,2,3 ต้องถึงมือแอปเป็น 1,2,3)</p>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — ตัวอย่างที่ทำให้คำว่า "น่าเชื่อถือ" จับต้องได้</span>
          อาจารย์ยกตัวอย่างในห้อง: สมมติส่งไป <b>3 แพ็กเก็ต</b> แต่ถึงปลายทางแค่ <b>2</b> — แบบนี้ "สมบูรณ์ไหม? ไม่สมบูรณ์" TCP ต้องตรวจเจอและจัดการ (ขอส่งซ้ำ) · หรือส่ง 1,2,3 แต่ดันถึงเป็น <b>3,1,2</b> — จะส่งขึ้นชั้นบนเลยได้ไหม? ไม่ได้! ต้อง<b>เรียงกลับเป็น 1,2,3 ก่อน</b>แล้วค่อยส่งขึ้นไป นี่แหละคือความน่าเชื่อถือ · แล้วอาจารย์ถามต่อ: มีโพรโทคอลคู่กันของ TCP ชื่ออะไร? — <b>UDP</b> ซึ่ง<b>ไม่มี</b>บริการพวกนี้เลย = โพรโทคอลที่ "ไม่น่าเชื่อถือ" (unreliable) — ฟังดูแย่ แต่มันแลกกับความเร็ว/ความเบา (ไม่ต้องรอตรวจรอเรียง) จึงเหมาะกับงานที่ช้าไม่ได้แต่หายนิดหน่อยได้ เช่น สตรีมสด เกมออนไลน์</div>
          <p>· ถ้าตัด Transport ทิ้ง: IP ส่งของถึงบ้านได้ แต่ไม่มีใครเช็กว่าของครบไหม สลับกล่องไหม และไม่รู้จะส่งให้ "แอปไหน" ในเครื่อง</p>

          <p><b>ชั้นที่ 5 — Application layer:</b> ให้บริการ<b>สนับสนุนแอปพลิเคชันของผู้ใช้</b> โดยใช้<b>โมดูลแยกกันตามประเภทของแอป</b> — อีเมลใช้โมดูลหนึ่ง โอนไฟล์ใช้อีกโมดูล ไม่ปนกัน ตัวอย่างโพรโทคอลบนชั้นนี้ (สไลด์ "แอปพลิเคชันทั่วไปของ TCP/IP"):</p>
          <table class="tbl">
            <thead><tr><th>โพรโทคอล</th><th>ให้บริการ</th><th>ที่เจอในชีวิตจริง</th></tr></thead>
            <tbody>
              <tr><td><b>SMTP</b><br/>(Simple Mail Transfer Protocol)</td><td>ส่งอิเล็กทรอนิกส์เมล</td><td>อยู่เบื้องหลัง Gmail ทุกครั้งที่กดส่ง (อาจารย์เชื่อมให้ในห้อง)</td></tr>
              <tr><td><b>FTP</b><br/>(File Transfer Protocol)</td><td>ส่งไฟล์จากระบบหนึ่งไปอีกระบบ</td><td>อัปโหลดไฟล์ขึ้นเซิร์ฟเวอร์</td></tr>
              <tr><td><b>TELNET</b></td><td>ล็อกอินเข้าเครื่องจากระยะไกล (remote login)</td><td>สั่งงานเซิร์ฟเวอร์โดยไม่ต้องเดินไปหน้าเครื่อง</td></tr>
            </tbody>
          </table>
          <p><span class="plus">เสริมจากผู้เขียน</span> ปัจจุบันงานจริงแทบไม่ใช้ TELNET แล้ว เพราะมันส่งทุกอย่าง (รวมรหัสผ่าน!) เป็นข้อความล้วนไม่เข้ารหัส — โลกจริงใช้ <b>SSH</b> ที่ทำงานแบบเดียวกันแต่เข้ารหัสทั้งหมด ซึ่งตรงกับที่อาจารย์เปรยในห้องว่ามีตัวที่ "ทำแบบเดียวกันได้แต่ปลอดภัยกว่า"</p>
        </Step>

        <!-- ============ 6. ที่อยู่ 3 ระดับ ============ -->
        <Step kind="deep" icon="🏷️" title="ที่อยู่ 3 ระดับ: MAC · IP · Port — คนละคำถาม คนละชั้น" id="addressing">
          <p>ในสไลด์เรื่องมาตรฐาน OSI มีหัวข้อ "การทำแอดเดรสซิ่ง (addressing)" บอกว่าแต่ละหน่วยงาน (entity) ถูกอ้างอิงด้วย <span class="term">จุดเข้าถึงบริการ (Service Access Point — SAP)</span> — ฟังดูนามธรรม แต่อาจารย์แปลงเป็นรูปธรรมในห้องได้เคลียร์มาก:</p>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — address ของแต่ละชั้น</span>
          "แอดเดรส" ไม่ได้มีตัวเดียว — <b>ชั้น 2 (link) ใช้ MAC address · ชั้น 3 (Internet) ใช้ IP address · ชั้น 4 (Transport) ใช้ port</b> — สามตัวนี้ตอบคำถามคนละข้อ:</div>
          <table class="tbl">
            <thead><tr><th>ที่อยู่</th><th>ของชั้น</th><th>ตอบคำถามว่า…</th><th>เทียบพัสดุ</th></tr></thead>
            <tbody>
              <tr><td><b>MAC address</b></td><td>2 · Network Access</td><td>"เครื่องไหน" ในเครือข่ายวงเดียวกัน (hop ถัดไป)</td><td>บ้านเลขที่ในซอยเดียวกัน</td></tr>
              <tr><td><b>IP address</b></td><td>3 · Internet</td><td>"เครื่องไหน" ในโลกทั้งใบ (ปลายทางสุดท้าย)</td><td>ที่อยู่เต็มบนหน้ากล่อง</td></tr>
              <tr><td><b>Port</b></td><td>4 · Transport</td><td>"แอปไหน" ในเครื่องนั้น (เว็บ? เมล? เกม?)</td><td>ชื่อคนรับในบ้านหลังนั้น</td></tr>
            </tbody>
          </table>
          <p class="why">ทำไมต้องมีตั้ง 3 ตัว? เพราะการเดินทางมี 3 โจทย์ซ้อนกัน: ในวง LAN ส่งต่อกันด้วย MAC (ซอยนี้บ้านไหน) · ข้ามโลกนำทางด้วย IP (เมืองไหน ถนนไหน) · ถึงเครื่องแล้วต้องรู้ว่ายื่นให้โปรแกรมไหน (คนไหนในบ้าน) — ใช้ตัวเดียวแทนกันไม่ได้ เช่น IP บอกเครื่องแต่ไม่บอกแอป: เครื่องเดียวเปิดทั้งเว็บและเกมพร้อมกัน ข้อมูลมาถึงแล้วให้ใคร? ต้องดู port</p>
        </Step>

        <!-- ============ 7. Encapsulation ============ -->
        <Step kind="anim" icon="🎬" title="การห่อ–แกะข้อมูล (Encapsulation) เดินทางจริงผ่าน Router" id="enc">
          <p>ทีนี้มาดู "กลไก" ที่ทุกชั้นทำงานร่วมกัน เวลาข้อมูลเดินทาง ขาลง (ฝั่งส่ง) แต่ละชั้นจะ<b>เติมหัว (header) ของตัวเอง</b>ครอบก้อนข้อมูลจากชั้นบน เรียกว่า <span class="term">Encapsulation (การห่อ)</span> — ก้อนข้อมูลที่แต่ละชั้นสร้างขึ้นมีชื่อเรียกรวมว่า <span class="term">PDU (Protocol Data Unit)</span> โดยแต่ละชั้นมีชื่อเฉพาะของมัน: ก้อนของ TCP เรียก <b>segment</b>, ของ IP เรียก <b>datagram</b>, ของชั้น link เรียก <b>frame</b> — ฝั่งรับก็ทำย้อนกลับ <span class="term">Decapsulation (การแกะ)</span> ทีละชั้น</p>
          <p>สไลด์ชุด TCP/IP EXAMPLE (fig 4.6–4.7 ในตำรา) เดินตัวอย่างจริงที่<b>ละเอียดมากและออกสอบบ่อย</b>: เครื่อง Server ต่ออยู่กับเครือข่าย ATM ส่งข้อมูลผ่าน <b>Router</b> ไปหา Workstation ที่ต่ออยู่กับ LAN (IEEE 802) — สองฝั่งอยู่<b>คนละชนิดเครือข่าย</b> แล้วข้อมูลข้ามไปได้ยังไง? กดดูทีละขั้น:</p>
          <div class="lab">
            <h4>🎬 เส้นทางเต็ม: Server → (ATM) → Router → (LAN) → Workstation</h4>
            <div class="enc3">
              <div class="enc-side" id="sendStack">
                <div class="cap">ผู้ส่ง (Server) — ห่อลงทีละชั้น</div>
                <div class="lyr" data-l="app">Application</div>
                <div class="lyr" data-l="tp">Transport · TCP</div>
                <div class="lyr" data-l="ip">Internet · IP</div>
                <div class="lyr" data-l="na">Network Access · ATM</div>
                <div class="lyr" data-l="phy">Physical</div>
              </div>
              <div class="enc-side" id="rtrStack">
                <div class="cap">Router — แกะถึงแค่ IP แล้วห่อใหม่</div>
                <div class="lyr small" data-l="ip0">IP (ดูที่อยู่ → เลือกเส้นทาง)</div>
                <div class="lyr-split">
                  <div class="lyr small" data-l="na1">ATM (ขาเข้า)</div>
                  <div class="lyr small" data-l="na2">LLC+MAC (ขาออก)</div>
                </div>
                <div class="lyr-split">
                  <div class="lyr small" data-l="phy1">Physical เข้า</div>
                  <div class="lyr small" data-l="phy2">Physical ออก</div>
                </div>
              </div>
              <div class="enc-side" id="recvStack">
                <div class="cap">ผู้รับ (Workstation) — แกะขึ้นทีละชั้น</div>
                <div class="lyr" data-l="phy">Physical</div>
                <div class="lyr" data-l="na">Network Access · LAN</div>
                <div class="lyr" data-l="ip">Internet · IP</div>
                <div class="lyr" data-l="tp">Transport · TCP</div>
                <div class="lyr" data-l="app">Application</div>
              </div>
            </div>
            <div class="enc-pkt-row">
              <div class="packet" id="encPacket"></div>
              <div class="enc-cap" id="encCap"></div>
            </div>
            <div class="btnrow">
              <button class="btn" id="encNext">ทีละขั้น →</button>
              <button class="btn ghost" id="encRun">▶ เล่นอัตโนมัติ</button>
            </div>
          </div>
          <p>จุดที่ต้องเก็บจากแอนิเมชันนี้ (ตรงกับขั้น 1–13 ใน fig 4.6/4.7 ของสไลด์):</p>
          <ul>
            <li><b>TCP ใส่เลขลำดับ + ตัวตรวจ error และเก็บสำเนาไว้</b> — เผื่อก้อนไหนหาย/พัง จะได้ส่งซ้ำได้ (นี่คือกลไกเบื้องหลัง "ความน่าเชื่อถือ" ที่คุยกันไป)</li>
            <li><b>Router แกะถึงแค่ชั้น IP</b> — อ่านที่อยู่ปลายทาง ตัดสินใจเส้นทาง แล้วห่อใหม่ <b>ไม่เคยแตะ TCP/DATA</b> — เห็นภาพเลยว่าทำไมพูดว่า "router ทำงานที่ Layer 3"</li>
            <li><b>เฟรมขาเข้ากับขาออกคนละชนิดกัน</b> (ATM เข้า → LAN ออก) แต่ IP datagram ข้างในคือก้อนเดิม — นี่คือเวทมนตร์ของการแบ่งชั้น: IP เป็น "ภาษากลาง" ที่ลอยข้ามเครือข่ายต่างชนิดได้</li>
            <li>เฟรม LAN ขาออกมีทั้ง <b>LLC</b> (Logical Link Control — เลขลำดับ+ที่อยู่) และ <b>MAC</b> (หัว = ที่อยู่บน LAN, ท้าย = frame check sequence ตัวตรวจ error) — LAN แบ่งชั้น 2 ออกเป็น 2 ชั้นย่อยนี้</li>
          </ul>
          <p class="why">ทำไมทุกชั้นต้องมี "ตัวตรวจ error" ของตัวเอง? เพราะแต่ละชั้นรับผิดชอบคนละช่วง: frame check ของชั้น 2 ตรวจว่าเฟรม<b>ข้ามลิงก์เดียว</b>มาไม่พัง ส่วน TCP ตรวจว่า<b>ปลายถึงปลาย</b>ครบและถูก — เหมือนไปรษณีย์เช็กพัสดุทุกศูนย์คัดแยก แต่คนรับก็ยังเปิดกล่องนับของเองอีกรอบ</p>
        </Step>

        <!-- ============ 8. OSI ============ -->
        <Step kind="deep" icon="🏛️" title="OSI 7 ชั้น — แบบจำลองตำรา ที่ต้องรู้จักทุกชั้น" id="osi">
          <p>อีกแบบจำลองที่ทุกตำราเครือข่ายต้องพูดถึงคือ <span class="term">OSI (Open Systems Interconnection)</span> แบ่งงานละเอียดกว่า: <b>7 ชั้น</b> ไล่จากบนลงล่าง — สไลด์ของอาจารย์ให้หน้าที่ของแต่ละชั้นไว้ครบ เก็บให้หมดทีละชั้น:</p>

          <p><b>7. Application</b> — ให้ผู้ใช้<b>เข้าถึงสภาพแวดล้อมของ OSI</b> (OSI environment) และให้บริการข้อมูลแบบกระจาย (distributed information services) — พูดง่ายๆ คือประตูที่โปรแกรมของผู้ใช้ใช้เรียกบริการเครือข่ายทั้งหมด</p>
          <p><b>6. Presentation</b> — ทำให้กระบวนการของแอป<b>เป็นอิสระจากความแตกต่างในการแสดงผลของข้อมูล (syntax)</b> — เครื่องสองฝั่งอาจเก็บข้อมูลคนละรูปแบบ (การเข้ารหัสตัวอักษร รูปแบบตัวเลข) ชั้นนี้แปลงให้เข้าใจตรงกันโดยแอปไม่ต้องรับรู้
            <span class="lect" style="display:block; margin-top:8px;"><span class="who">🎙 จากปากอาจารย์</span> อาจารย์เสริมว่างานอีกอย่างของชั้นนี้คือ<b>การเข้ารหัส/ถอดรหัสข้อมูล (encryption)</b> — จะเข้ารหัสก่อนส่งหรือถอดก่อนแสดงผล ก็เป็นเรื่อง "รูปแบบของข้อมูล" เหมือนกัน</span></p>
          <p><b>5. Session</b> — ให้<b>โครงสร้างการควบคุม</b>สำหรับการสื่อสารระหว่างแอปพลิเคชัน: <b>สร้าง จัดการ และยกเลิก</b>การเชื่อมต่อ (session) ระหว่างแอปที่คุยกัน
            <span class="lect" style="display:block; margin-top:8px;"><span class="who">🎙 จากปากอาจารย์</span> ตัวอย่างที่อาจารย์ยก: เวลาเปิดเว็บ/ดู YouTube การ "เปิดการเชื่อมต่อ–คุยกัน–ปิดการเชื่อมต่อ" กับเซิร์ฟเวอร์แต่ละรอบนั่นแหละคือ session — มีคนคอยเปิด/ปิด/จัดการให้เป็นเรื่องเป็นราว</span></p>
          <p><b>4. Transport</b> — โอนถ่ายข้อมูลระหว่างจุดปลายแบบ<b>น่าเชื่อถือและโปร่งใส</b> ("โปร่งใส" = ผู้ใช้ไม่ต้องรู้สึกว่าเบื้องหลังทำอะไรบ้าง มันจัดการให้เอง) พร้อม<b>การกู้คืนข้อผิดพลาด (error recovery)</b> และ<b>การควบคุมการไหล (flow control)</b> ที่ปลายทางทั้งสองฝั่ง — บทบาทเดียวกับ TCP ฝั่ง TCP/IP</p>
          <p><b>3. Network</b> — ให้บริการชั้นบน<b>โดยเป็นอิสระจากเทคโนโลยีการส่ง/การสวิตช์</b>ที่ใช้เชื่อมระบบ (ชั้นบนไม่ต้องรู้ว่าล่างเป็นเครือข่ายแบบไหน) และรับผิดชอบ<b>สร้าง รักษา และยกเลิก</b>การเชื่อมต่อข้ามเครือข่าย — บทบาทเดียวกับ IP</p>
          <p><b>2. Data link</b> — ทำให้การส่งข้อมูล<b>ผ่านลิงก์กายภาพเส้นหนึ่ง</b>น่าเชื่อถือ: ส่งเป็น<b>บล็อกที่เรียกว่าเฟรม (frame)</b> พร้อม <b>synchronization</b> (คุมจังหวะส่ง–รับให้ตรงกัน) + <b>error control</b> + <b>flow control</b> — สังเกตว่าฟังก์ชันคล้าย Transport แต่ขอบเขตคนละระดับ: Data link ดูแล "ลิงก์เดียว" (เครื่อง↔สวิตช์) ส่วน Transport ดูแล "ปลายถึงปลาย" (เครื่องเรา↔เซิร์ฟเวอร์อีกทวีป)</p>
          <p><b>1. Physical</b> — ดูแลการส่ง<b>สายบิตที่ไม่มีโครงสร้าง</b> (unstructured bit stream — บิตดิบล้วนๆ ไม่มีความหมายอะไรแฝง) บนสื่อกายภาพ โดยต้องกำหนดคุณลักษณะ 4 ด้าน:</p>
          <ul>
            <li><b>ทางกลศาสตร์ (mechanical)</b> — รูปทรงหัวต่อ ปลั๊ก จำนวนขา (ทำไม LAN เสียบกับ HDMI ไม่ได้ = ต่างกันตั้งแต่กลศาสตร์)</li>
            <li><b>ทางไฟฟ้า (electrical)</b> — ระดับแรงดัน กี่โวลต์คือ 0 กี่โวลต์คือ 1</li>
            <li><b>ทางหน้าที่ใช้งาน (functional)</b> — สายเส้นไหน/ขาไหน ทำหน้าที่อะไร (ส่ง รับ กราวด์)</li>
            <li><b>ทางกระบวนงาน (procedural)</b> — ลำดับขั้นตอนการใช้งาน ต้องทำอะไรก่อน-หลังเพื่อเริ่มส่ง</li>
          </ul>
        </Step>

        <!-- ============ 9. OSI vs TCP/IP ============ -->
        <Step kind="deep" icon="⚖️" title="OSI vs TCP/IP — ทำไมโลกจริงใช้ TCP/IP" id="versus">
          <p>เทียบชั้นของสองแบบจำลอง (สไลด์ "การเปรียบเทียบการแบ่งชั้น"):</p>
          <table class="tbl">
            <thead><tr><th>OSI (7 ชั้น)</th><th>≈ TCP/IP (5 ชั้น)</th><th>หมายเหตุ</th></tr></thead>
            <tbody>
              <tr><td>Application + Presentation + Session</td><td><b>Application</b></td><td>สามชั้นบนถูก "ยุบรวม" เป็นชั้นเดียว</td></tr>
              <tr><td>Transport</td><td><b>Transport</b></td><td>ตรงกัน</td></tr>
              <tr><td>Network</td><td><b>Internet</b></td><td>ตรงกัน (IP)</td></tr>
              <tr><td>Data link</td><td><b>Network Access</b></td><td>ตรงกัน</td></tr>
              <tr><td>Physical</td><td><b>Physical</b></td><td>ตรงกัน</td></tr>
            </tbody>
          </table>
          <p>แล้ว<b>ทำไม TCP/IP ถึง "ชนะ"</b>? สไลด์ "ความเด่นกว่าของสถาปัตยกรรม TCP/IP" ให้เหตุผล 2 ข้อ ซึ่งอาจารย์ขยายความในห้องจนเห็นภาพ:</p>
          <ul>
            <li><b>TCP/IP เติบโตเร็วกว่า</b> — เมื่อโลกต้องการให้เครือข่ายทำงานร่วมกัน TCP/IP <b>ใช้งานได้จริงทันที</b> (มันถูกใช้รันเครือข่ายจริงมาก่อนแล้ว) ส่วน OSI ยังเป็นมาตรฐานบนกระดาษ</li>
            <li><b>OSI ซับซ้อนโดยไม่จำเป็น</b> — ต้องทำครบทั้ง 7 ชั้น ทั้งที่ TCP/IP ทำงานแบบเดียวกันได้ด้วยจำนวนชั้นที่น้อยกว่า</li>
          </ul>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — why เบื้องหลัง 2 บรรทัดนั้น</span>
          <b>(1) ใครเกิดก่อน:</b> TCP/IP เกิดและถูกใช้งานจริงก่อน OSI เกิดทีหลัง — OSI เป็น <b>framework</b> ที่สร้างขึ้นเพื่อ "จัดระเบียบความคิด" แบ่งหน้าที่แต่ละชั้นให้ชัดเจนสวยงามตามทฤษฎี เหมาะเอาไว้เรียน/อ้างอิง แต่อินเทอร์เน็ตที่รันอยู่ทุกวันนี้คือ TCP/IP · <b>(2) ชั้นเยอะ = แบกเยอะ:</b> ทุกชั้นที่เพิ่มเข้ามาต้องเติม header ของตัวเอง — 7 ชั้นก็ 7 header, 5 ชั้นก็ 5 header — ยิ่งชั้นเยอะ ข้อมูลส่วนที่เป็น "ค่าขนส่ง" ยิ่งบาน ประสิทธิภาพยิ่งหด — นี่คือเหตุผลเชิงวิศวกรรมที่ทฤษฎีสวยๆ แพ้ของจริงที่เรียบกว่า</div>
          <p>สไลด์สุดท้ายของช่วงนี้ ("ส่วนประกอบของมาตรฐานภายในเฟรมเวิร์ก OSI") บอกว่ามาตรฐานของ<b>แต่ละชั้น</b>ต้องนิยาม 3 อย่าง — อ่านแล้วจะเข้าใจว่า "เขียนมาตรฐานเครือข่าย" คือเขียนอะไร:</p>
          <ul>
            <li><b>รายละเอียดโพรโทคอล (protocol specification)</b> — รูปแบบของ PDU ที่แลกกัน, ความหมาย (semantics) ของทุกฟิลด์, และลำดับของ PDU ที่อนุญาต (อะไรส่งก่อน-หลังได้บ้าง)</li>
            <li><b>นิยามของการบริการ (service definition)</b> — ชั้นนี้ให้บริการ<b>อะไร</b>แก่ชั้นบน — โดยจงใจ<b>ไม่</b>บอกว่าทำ<b>อย่างไร</b> (เพื่อให้แต่ละเจ้า implement วิธีของตัวเองได้ ตราบใดที่บริการครบตามสัญญา)</li>
            <li><b>การทำแอดเดรสซิ่ง (addressing)</b> — อ้างถึงหน่วยงานต่างๆ ผ่าน SAP (ที่เราแปลงร่างเป็น MAC/IP/port ให้ดูแล้วข้างบน)</li>
          </ul>
        </Step>

        <!-- ============ 10. ศัพท์เครือข่าย ============ -->
        <Step kind="deep" icon="🔌" title="ศัพท์ที่ต้องพูดได้เอง: Internet · Intranet · ES · IS · Bridge · Router" id="terms">
          <p>ก่อนไปเรื่อง switching สไลด์ให้ชุดศัพท์ "การเชื่อมต่อเครือข่าย" — พวกนี้คือคำที่จะโผล่ในทุกวิชาเครือข่ายจากนี้ไป นิยามแต่ละคำแบบเข้าใจได้:</p>
          <p><b>เครือข่ายสื่อสาร (communication network)</b> — สิ่งอำนวยความสะดวกที่ให้บริการ<b>โอนถ่ายข้อมูล</b>ระหว่างอุปกรณ์ที่เชื่อมต่อกับมัน — คำกลางๆ ใช้เรียกเครือข่ายอะไรก็ได้</p>
          <p><b>อินเทอร์เน็ต (Internet)</b> — <b>การรวมกันของหลายเครือข่าย</b>สื่อสารที่เชื่อมถึงกันโดยใช้บริดจ์หรือเราเตอร์ — ชื่อมันบอกตรงตัว: inter (ระหว่าง) + net (เครือข่าย) ไม่ใช่เครือข่ายเดียวยักษ์ๆ แต่คือ "เครือข่ายของเครือข่าย"</p>
          <p><b>อินทราเน็ต (Intranet)</b> — อินเทอร์เน็ต (เทคโนโลยีเดียวกันเป๊ะ) ที่องค์กรใช้<b>เพื่อวัตถุประสงค์ภายใน</b>: ให้บริการแอปแบบเดียวกับอินเทอร์เน็ต (เว็บ อีเมล) แต่<b>สามารถแยกตัวเป็นเอกเทศ</b>จากอินเทอร์เน็ตภายนอกได้เลยถ้าต้องการ
            <span class="lect" style="display:block; margin-top:8px;"><span class="who">🎙 จากปากอาจารย์</span> อาจารย์ย้ำว่า intranet คือ "เน็ตที่ใช้เฉพาะภายในองค์กร" เช่น ระบบภายในมหาวิทยาลัย/บริษัท — บางที่ตัดขาดจากอินเทอร์เน็ตภายนอกจริงๆ เพื่อความปลอดภัย</span></p>
          <p><b>ระบบสุดท้าย (End system — ES)</b> — อุปกรณ์<b>ปลายทาง</b>ที่รันแอป/บริการของผู้ใช้ — คอมของเรา มือถือ เซิร์ฟเวอร์ · อาจารย์เสริมว่าอีกชื่อที่เจอบ่อยคือ <b>Host</b></p>
          <p><b>ระบบกลางทาง (Intermediate system — IS)</b> — อุปกรณ์ที่ใช้<b>เชื่อมเครือข่าย 2 เครือข่าย</b>เข้าด้วยกัน — เป็นคำแม่ของ bridge และ router: ทั้งคู่คือ IS แต่ทำงานคนละชั้น</p>
          <p><b>บริดจ์ (Bridge)</b> — IS ที่เชื่อม<b>เครือข่ายเฉพาะที่ (LAN) 2 เครือข่าย</b>เข้าด้วยกัน ทำงานอยู่ใน<b>ชั้นลิงก์ข้อมูล (Data link — ชั้น 2)</b> พฤติกรรมเหมือน<b>ตัวกรองที่อยู่</b> (address filter): ดูที่อยู่ปลายทางของเฟรม ถ้าอยู่ฝั่งโน้นก็ปล่อยข้าม ถ้าอยู่ฝั่งเดิมก็ไม่ต้องข้ามให้รกสาย</p>
          <p><b>เราเตอร์ (Router)</b> — IS ที่เชื่อมเครือข่ายเข้าด้วยกัน โดยเครือข่ายสองฝั่ง<b>จะเหมือนหรือต่างชนิดกันก็ได้</b> (LAN↔ATM ก็ได้ อย่างในแอนิเมชันข้างบน) ทำงานอยู่ใน<b>ชั้นเครือข่าย (Network — ชั้น 3)</b> เพราะต้องอ่าน IP เพื่อหาเส้นทาง</p>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — bridge ในโลกปัจจุบัน</span>
          อาจารย์บอกตรงๆ ว่า bridge เป็น<b>เทคโนโลยีเก่า</b>: สมัยก่อนแต่ละ LAN อาจใช้โพรโทคอลต่างกัน เลยต้องมีตัวกลางแปลงให้ แต่ปัจจุบันชั้นเครือข่ายเหลือโพรโทคอลหลักตัวเดียวคือ IP — อุปกรณ์ที่ทำหน้าที่แบบ bridge ทุกวันนี้ก็คือ <b>Switch</b> นั่นเอง (ทำงานชั้น 2 เหมือนกัน) — เพราะงั้นถ้าเจอคำถาม "switch ทำงานชั้นไหน" ให้นึกถึง bridge: <b>ชั้น 2 · Data link</b></div>
        </Step>

        <!-- ============ 11. หน้าที่ router ============ -->
        <Step kind="deep" icon="🧭" title="Router ต้องเก่งแค่ไหน — หน้าที่ + 4 ความต่างที่ต้องเกลี่ยให้เรียบ" id="router">
          <p>สไลด์ "หน้าที่ของเราเตอร์" สรุปงาน 3 อย่าง:</p>
          <ul>
            <li>ให้บริการ<b>ลิงก์เชื่อมต่อระหว่างเครือข่าย</b> (เป็นสะพานข้ามเครือข่าย)</li>
            <li>ให้บริการ<b>ค้นหาเส้นทาง (routing) และรับ-ส่งข้อมูล</b>ระหว่างโพรเซสบนระบบปลายที่อยู่คนละเครือข่าย</li>
            <li>ทำทั้งหมดนั้น<b>โดยไม่บังคับให้เครือข่ายย่อยที่มาต่อ ต้องแก้สถาปัตยกรรมของตัวเอง</b> — ข้อนี้ลึกและสวยมาก: LAN ที่ออฟฟิศไม่ต้องรื้อระบบเพื่อต่ออินเทอร์เน็ต แค่เสียบผ่าน router ตัวเดียว</li>
          </ul>
          <p>แต่การ "เชื่อมเครือข่ายต่างชนิด" ไม่ใช่แค่เสียบสายสองเส้นเข้าหากัน — สไลด์ถัดมาไล่ <b>4 ความแตกต่าง</b>ระหว่างเครือข่ายที่ router ต้องจัดการให้เหมาะสม:</p>
          <table class="tbl">
            <thead><tr><th>ความต่าง</th><th>ปัญหา</th><th>router จัดการยังไง</th></tr></thead>
            <tbody>
              <tr><td><b>แบบแผนของที่อยู่</b><br/>(addressing scheme)</td><td>แต่ละเครือข่ายจ่าหน้าที่อยู่คนละแบบ</td><td>ใช้ IP เป็นที่อยู่ "ภาษากลาง" คุยข้ามได้หมด</td></tr>
              <tr><td><b>ขนาดแพ็กเก็ตใหญ่สุด</b><br/>(maximum packet size)</td><td>เครือข่าย A ยอมรับก้อนใหญ่ B รับได้แต่ก้อนเล็ก</td><td>ต้อง<b>แบ่งส่วน (segmentation)</b> — หั่นก้อนใหญ่เป็นก้อนเล็กก่อนส่งเข้าเครือข่ายที่รับก้อนเล็ก</td></tr>
              <tr><td><b>อินเทอร์เฟซ</b> (interface)</td><td>ฮาร์ดแวร์/ซอฟต์แวร์การเชื่อมต่อคนละแบบ</td><td>router มีขา (พอร์ต) หลายชนิด แต่ละขาคุยภาษาของเครือข่ายนั้น</td></tr>
              <tr><td><b>ความน่าเชื่อถือ</b> (reliability)</td><td>บางเครือข่ายให้บริการแบบ<b>ไม่รับประกัน (unreliable)</b> — ของหายได้</td><td>ปล่อยให้ปลายทาง (TCP) เป็นคนตรวจ/ขอส่งซ้ำ — router ไม่แบกเอง</td></tr>
            </tbody>
          </table>
          <p class="why">ตรรกะการออกแบบตรงนี้คือหลักคิดสำคัญของอินเทอร์เน็ต: <b>ตัวกลางทำน้อยที่สุด ปลายทางรับผิดชอบความถูกต้อง</b> — router แค่ส่งต่อให้เร็ว ส่วนเช็กครบ/เรียง เป็นงานของ TCP ที่ปลายทาง แบ่งงานแบบนี้ระบบถึงขยายใหญ่ระดับโลกได้</p>
        </Step>

        <!-- ============ 12. LAN/MAN/WAN ============ -->
        <Step kind="deep" icon="🌐" title="ชนิดของเครือข่าย: LAN · MAN · WAN — ต่างที่ขนาด เจ้าของ และความเร็ว" id="nettypes">
          <p>สไลด์ "ชนิดของเครือข่ายสื่อสาร" แบ่งสองยุค: <b>แบบดั้งเดิม</b> (LAN, WAN) กับ<b>แบบความเร็วสูง</b> (high-speed LAN, MAN, high-speed WAN) — แกนที่ใช้แบ่งคือ<b>ระยะทางครอบคลุม</b>: ห้อง/อาคาร → เมือง → ประเทศ/โลก ไล่ดูทีละตัวพร้อมตัวเลขจากสไลด์ (ตัวเลขพวกนี้อาจารย์ใช้ถามในห้อง):</p>

          <p><b>เครือข่ายบริเวณกว้าง (WAN — Wide Area Network)</b></p>
          <ul>
            <li>ครอบคลุม<b>พื้นที่ทางภูมิศาสตร์ขนาดใหญ่</b> (ระดับประเทศ/ข้ามประเทศ — อาจารย์ยกตัวอย่างเครือข่ายระดับประเทศ)</li>
            <li>วงจรให้บริการโดย<b>ผู้ให้บริการร่วมกัน (common carrier)</b> — องค์กรทั่วไปไม่ลากสายข้ามจังหวัดเอง แต่เช่าจากผู้ให้บริการ</li>
            <li>ข้างในประกอบด้วย <b>switching node</b> เชื่อมต่อกันเป็นทอดๆ (เดี๋ยวเจอเต็มๆ ในหัวข้อ switching)</li>
            <li>WAN ดั้งเดิมความจุ<b>ค่อนข้างน้อย</b>: ปกติ 64,000 bps (64 kbps) ธุรกิจที่ซื้อบริการมักใช้ <b>T-1 = 1.544 Mbps</b></li>
            <li>WAN ความเร็วสูงใช้<b>สายใยแก้วนำแสง</b> + เทคนิคการส่งแบบ <b>ATM (Asynchronous Transfer Mode)</b> ได้ราวๆ 10–100 Mbps</li>
          </ul>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์</span> ตัวเลขในสไลด์เป็นของยุคตำรา — อาจารย์บอกว่า<b>ปัจจุบันเร็วกว่านั้นมาก</b> (คิดถึงเน็ตบ้านใยแก้วหลัก Gbps) แต่หลักการโครงสร้าง WAN ยังเป็นแบบเดิม: เช่าวงจรผู้ให้บริการ + โยงด้วย switching node</div>

          <p><b>เครือข่ายท้องถิ่น (LAN — Local Area Network)</b></p>
          <ul>
            <li>เหมือน WAN ตรงที่เชื่อมอุปกรณ์หลายชนิดให้แลกเปลี่ยนข้อมูลกันได้ — ต่างที่<b>ขอบเขต</b></li>
            <li>LAN ดั้งเดิม: <b>1–20 Mbps</b> · LAN ความเร็วสูง: <b>100 Mbps – 10 Gbps</b></li>
          </ul>
          <p>ความแตกต่าง LAN vs WAN ที่สไลด์เน้น 3 ข้อ (ชุดนี้ตอบข้อสอบได้เลย):</p>
          <ol>
            <li><b>ขอบเขตเล็กกว่า</b> — LAN เชื่อมอุปกรณ์ภายในอาคารเดียวหรือกลุ่มอาคารใกล้กัน</li>
            <li><b>เจ้าของคนเดียว</b> — อุปกรณ์เชื่อมต่อของ LAN ส่วนใหญ่<b>องค์กรเดียวเป็นเจ้าของทั้งหมด</b> ส่วน WAN อุปกรณ์กระจายอยู่กับหลายเจ้าของ (ผู้ให้บริการ ฯลฯ)</li>
            <li><b>อัตราส่งภายในสูงกว่ามาก</b> — สายในตึกตัวเองสั้นและคุมเองได้ ย่อมอัดความเร็วได้มากกว่าลิงก์ข้ามประเทศ</li>
          </ol>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — สาย LAN มีกี่แบบ? (ถามในห้อง)</span>
          อาจารย์ให้นักศึกษาช่วยกันไล่ชนิดสายที่ใช้ในเครือข่าย: <b>UTP</b> (คู่บิดเกลียวไม่หุ้มฉนวนกันคลื่น — สายแลนที่เราเสียบกันทุกวัน), <b>STP</b> (คู่บิดเกลียวแบบมี<b>ชีลด์</b> — S มาจาก Shielded หุ้มกันสัญญาณรบกวน), <b>สาย Coaxial</b> (แบบสายอากาศทีวี), และ<b>ใยแก้วนำแสง (fiber optic)</b> — เรียงความเร็ว/ราคาจากถูกไปแพงโดยประมาณ: UTP → STP → coax → fiber</div>

          <p><b>เครือข่ายขนาดกลาง (MAN — Metropolitan Area Network)</b> — สไลด์ "ความต้องการของเครือข่ายขนาดกลาง" อธิบาย<b>ว่าทำไมต้องมีตัวนี้เกิดมา</b>:</p>
          <ul>
            <li>เทคนิคแบบจุดต่อจุด (point-to-point) และแบบสวิตช์ดั้งเดิมที่ใช้ใน WAN <b>ไม่เพียงพอ</b>กับการเติบโตขององค์กร — องค์กรต้องการ<b>ความจุสูงขึ้นแต่ราคาถูกลง</b>ตามพื้นที่ที่กว้างขึ้น</li>
            <li>MAN จึงมาอุดช่องว่าง "ใหญ่กว่า LAN แต่เล็กกว่า WAN": ให้บริการลูกค้า<b>ในตัวเมือง</b> ต้องการ<b>ความจุสูง</b> และ<b>ถูกกว่า/มีประสิทธิภาพสูงกว่า</b>บริการเทียบเท่าจากบริษัทโทรศัพท์</li>
          </ul>
          <p class="why">วิธีจำที่ไม่ต้องท่อง: <b>L</b>ocal = ตึกเรา (เราเป็นเจ้าของ) · <b>M</b>etro = เมือง (ผู้ให้บริการระดับเมือง) · <b>W</b>ide = ประเทศ/โลก (เช่าสายผู้ให้บริการรายใหญ่) — พอ scale เปลี่ยน เจ้าของเปลี่ยน เทคโนโลยีก็เปลี่ยนตาม</p>
        </Step>

        <!-- ============ 13. เครือข่ายสวิตช์ ============ -->
        <Step kind="anim" icon="🕸️" title="เครือข่ายสวิตช์: สถานี · โหนดสวิตช์ + ทำไมโหนด-โหนดต้องรวมสัญญาณ (FDM/TDM)" id="switchnet">
          <p>เข้าสู่ครึ่งหลังของคาบ: ข้อมูลใน WAN เดินทางผ่าน "ตัวกลาง" อะไร — สไลด์ "คำศัพท์ทางสวิตช์" ให้ 3 คำ:</p>
          <ul>
            <li><b>โหนดสวิตช์ (switching node)</b> — อุปกรณ์สวิตช์ที่อยู่ตรงกลาง ทำหน้าที่<b>เคลื่อนย้ายข้อมูล</b>จากลิงก์หนึ่งไปลิงก์หนึ่ง โดย<b>ไม่สนใจเนื้อหาภายในข้อมูล</b> (มันเป็นบุรุษไปรษณีย์ ไม่ใช่คนอ่านจดหมาย)</li>
            <li><b>สถานี (station)</b> — อุปกรณ์<b>ปลายทาง</b>ที่ต้องการสื่อสาร (คอม เซิร์ฟเวอร์ เมนเฟรม โทรศัพท์) แต่ละสถานีต้อง<b>เชื่อมเข้ากับโหนดสวิตช์</b>สักตัว</li>
            <li><b>เครือข่ายสื่อสาร</b> — มองในบริบทนี้ = <b>การรวมกันของโหนดสวิตช์</b>ทั้งหลายนั่นเอง</li>
          </ul>
          <p>รูป Simple Switching Network ในสไลด์ (ภาพ 3.3 ของตำรา) มีสถานี A–F เกาะอยู่รอบ "ก้อนเมฆ" ของโหนดสวิตช์หมายเลข 1–7 — เราวาดใหม่ให้เป็นอินเทอร์แอกทีฟ (กดปุ่มในหัวข้อ Datagram vs VC ข้างล่าง มันจะมีแพ็กเก็ตวิ่งบนรูปนี้จริงๆ):</p>
          <div class="lab">
            <h4>🗺️ เครือข่ายสวิตช์ (วาดตามภาพ 3.3): สถานี = เหลี่ยมส้ม · โหนดสวิตช์ = วงกลม</h4>
            <div id="graphAnim"></div>
            <div class="enc-cap" id="graphCap">สังเกตโครงสร้างตามข้อสังเกตของสไลด์ด้านล่าง แล้วค่อยไปกดปุ่มส่งแพ็กเก็ตในหัวข้อ "Datagram vs Virtual Circuit"</div>
            <div class="btnrow">
              <button class="btn" id="btnDG">▶ ส่งแบบ Datagram (A → D)</button>
              <button class="btn" id="btnVC">▶ ส่งแบบ Virtual Circuit (A → D)</button>
            </div>
          </div>
          <p>สไลด์ "ข้อสังเกตจากภาพ 3.3" ให้ 5 ข้อ — เทียบกับรูปข้างบนได้เลย:</p>
          <ul>
            <li>โหนดบางโหนด<b>เชื่อมต่อกับโหนดด้วยกันเท่านั้น</b> (เช่น โหนด 5 กับ 7) — งานของมันคือส่งต่อภายในเครือข่ายล้วนๆ</li>
            <li>บางโหนดมี<b>สถานีมาเกาะหนึ่งตัวหรือมากกว่า</b> (เช่น โหนด 3 กับ 6) — เป็น "ประตูทางเข้า" ของผู้ใช้</li>
            <li>ลิงก์<b>โหนด↔สถานี</b> ปกติเป็นลิงก์<b>จุดต่อจุดที่อุทิศให้</b> (dedicated point-to-point — สายตรงของคุณคนเดียว)</li>
            <li>ลิงก์<b>โหนด↔โหนด</b> ปกติใช้<b>การรวมสัญญาณ (multiplexing)</b>: <b>FDM</b> หรือ <b>TDM</b> — เพราะสายระหว่างโหนดต้องแบกข้อมูลของผู้ใช้จำนวนมากพร้อมกัน จะลากสายแยกให้ทุกคู่สนทนาไม่ไหว</li>
            <li><b>ไม่มีการเชื่อมต่อโดยตรงระหว่างทุกคู่สถานี</b> — อยากคุยกันต้องฝากเครือข่ายส่ง (อาจารย์ถามในห้อง: "สถานีต่อตรงถึงสถานีได้ไหม?" — ไม่ได้ ต้องผ่านโหนดสวิตช์เสมอ) ทำไมออกแบบงี้? ถ้าให้ทุกคู่ต่อตรง สถานี n ตัวต้องมีสายราว n²/2 เส้น — ล้านเครื่องคือห้าแสนล้านสาย เป็นไปไม่ได้</li>
          </ul>
          <div class="lab">
            <h4>🎬 FDM vs TDM — สองวิธี "แชร์สายเส้นเดียว" ให้หลายคนใช้พร้อมกัน</h4>
            <canvas id="muxCanvas"></canvas>
          </div>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — ตัวอย่าง FDM ที่เห็นภาพสุด</span>
          <b>FDM (Frequency Division Multiplexing)</b> = แบ่ง "ย่านความถี่" กันใช้ — ตัวอย่างคือ<b>วิทยุ FM</b>: ย่าน FM อยู่ราว <b>88–108 MHz</b> (กว้าง 20 MHz) ถูกซอยเป็นสถานีย่อยๆ แต่ละสถานีได้ความถี่ของตัวเอง <b>ทุกสถานีออกอากาศพร้อมกันได้</b>โดยไม่ชนกัน เพราะอยู่คนละความถี่ · ส่วน <b>TDM (Time Division Multiplexing)</b> = แบ่ง "เวลา" กันใช้ — แต่ละคนได้ใช้<b>ทั้งย่านความถี่</b>แต่ผลัดกันเป็นช่วงเวลาสั้นๆ วนไป · อาจารย์ทิ้งท้าย: ระบบโทรศัพท์<b>สมัยเก่าเป็น FDM สมัยใหม่เป็น TDM</b> — เรื่องนี้จะเรียนลึกอีกทีใน Week 3</div>
        </Step>

        <!-- ============ 14. Circuit switching ============ -->
        <Step kind="anim" icon="☎️" title="Circuit Switching — จองสายทั้งเส้นก่อนคุย (แบบโทรศัพท์)" id="circuit">
          <p>สไลด์ "เทคนิคที่ใช้ในเครือข่ายสวิตช์" เปิดด้วยการแบ่งใหญ่ 2 ค่าย ที่เป็นแกนของครึ่งคาบหลัง:</p>
          <ul>
            <li><b>การสลับวงจร (Circuit switching)</b> — <b>อุทิศช่องทางสื่อสาร</b>ระหว่าง 2 สถานีให้คู่นั้นทั้งการสนทนา · ตัวอย่าง: เครือข่ายโทรศัพท์สาธารณะ</li>
            <li><b>การสลับกลุ่มข้อมูล (Packet switching)</b> — <b>หั่นข้อความเป็นลำดับของแพ็กเก็ต</b> แล้วให้แต่ละโหนดตัดสินใจส่งต่อทีละแพ็กเก็ต</li>
          </ul>
          <p><span class="term">Circuit switching</span> ทำงานเป็น <b>3 เฟส</b>เสมอ (สไลด์ "เฟสของ Circuit switching") — กดปุ่มดูทีละเฟส:</p>
          <div class="lab">
            <h4>🎬 โทรศัพท์บ้าน: A โทรหา B ผ่านชุมสาย 2 แห่ง</h4>
            <div class="phone-net">
              <div class="pn-node"><div class="ic">📞</div>A<br/><small>ผู้เช่า (subscriber)</small></div>
              <div class="pn-seg" id="csL1"><span class="tag">สายผู้เช่า / local loop</span></div>
              <div class="pn-node exch"><div class="ic">🏢</div>ชุมสายต้นทาง<br/><small>(end office)</small></div>
              <div class="pn-seg trunk" id="csTrunk"><span class="tag">สายผ่าน (trunk)</span></div>
              <div class="pn-node exch"><div class="ic">🏢</div>ชุมสายปลายทาง</div>
              <div class="pn-seg" id="csL2"><span class="tag">สายผู้เช่า</span></div>
              <div class="pn-node"><div class="ic">📞</div>B</div>
            </div>
            <div class="pn-flow" id="csFlow"></div>
            <div class="enc-cap" id="csCap"></div>
            <div class="btnrow"><button class="btn" id="csPhase">▶ เฟส 1 · ยกหู–กดเบอร์ (สร้างวงจร)</button></div>
          </div>
          <p>สามเฟสตามสไลด์ พร้อมเหตุผลว่าแต่ละเฟสมีไว้ทำไม:</p>
          <ol>
            <li><b>เริ่มเชื่อมต่อวงจร (circuit establishment)</b> — วงจรปลายถึงปลายถูก<b>สร้างขึ้นผ่านโหนดสวิตช์</b>ก่อนจะส่งข้อมูลใดๆ: กดเบอร์ = ส่งคำขอ, ชุมสายจองช่องทางเป็นทอดๆ จนถึงปลายทาง, กริ่งดัง, อีกฝั่งรับสาย = วงจรพร้อม</li>
            <li><b>โอนถ่ายข้อมูล (data transfer)</b> — ข้อมูลวิ่งบนวงจรที่จองไว้ ตัวข้อมูลจะเป็น<b>เสียงแอนะล็อก เสียงดิจิทัล หรือข้อมูลไบนารี</b>ก็ได้ (วงจรไม่สนว่าขนอะไร)</li>
            <li><b>สิ้นสุดวงจร (circuit disconnect)</b> — วางสาย วงจรถูกปลด <b>แต่ละโหนดเคลียร์ทรัพยากรคืน</b> พร้อมรับการเชื่อมต่อของคู่อื่นต่อไป</li>
          </ol>
          <p>ศัพท์ส่วนประกอบของเครือข่ายโทรศัพท์สาธารณะ (สไลด์ 48 — โผล่ในรูปข้างบนครบทุกคำ):</p>
          <table class="tbl">
            <tbody>
              <tr><td><b>ผู้เช่า (Subscriber)</b></td><td>อุปกรณ์ที่ต่อเข้าเครือข่าย — ส่วนใหญ่คือเครื่องโทรศัพท์</td></tr>
              <tr><td><b>สายผู้เช่า (Subscriber line)</b></td><td>ลิงก์จากผู้เช่าเข้าเครือข่าย · ชื่ออื่น: <b>subscriber loop / local loop</b></td></tr>
              <tr><td><b>ชุมสาย (Exchange)</b></td><td>ศูนย์รวมการสวิตช์ (switching center) · ชุมสายที่ให้บริการผู้เช่าโดยตรงเรียก <b>ชุมสายปลายทาง (end office)</b> — ถ้าคู่สนทนาอยู่คนละชุมสาย ต้องวิ่งข้ามชุมสายกันไป (อาจารย์: โทรในชุมสายเดียวกันก็ต่อภายในได้เลย)</td></tr>
              <tr><td><b>สายผ่าน (Trunk)</b></td><td>สายเชื่อม<b>ระหว่างชุมสาย</b> — แบกหลายวงจรพร้อมกัน (ใช้ FDM/TDM ที่เพิ่งเรียน!)</td></tr>
            </tbody>
          </table>
          <p>คุณลักษณะของ circuit switching (สไลด์ 47) — ส่วนนี้คือ "ทำไมอินเทอร์เน็ตไม่ใช้วิธีนี้เป็นหลัก":</p>
          <ul>
            <li><b>ประสิทธิภาพน้อย</b> — ความจุช่องสัญญาณถูก<b>อุทิศให้ตลอดช่วงการเชื่อมต่อ</b> แม้จังหวะที่ไม่มีใครพูด ก็ไม่มีใครอื่นเอาไปใช้ได้ → <b>ใช้งานจริงไม่ถึง 100%</b> (คิดดู: การคุยโทรศัพท์มีช่วงเงียบ ช่วงฟัง เกินครึ่ง)</li>
            <li><b>มีความหน่วงก่อนเริ่มส่ง</b> — ต้องรอสร้างวงจรเสร็จก่อน (เฟส 1) ถึงจะเริ่มพูดได้</li>
            <li><b>ข้อดีหลังวงจรพร้อม</b>: ผู้ใช้ไม่ต้องสนใจเครือข่ายอีกเลย (เหมือนได้สายส่วนตัว) ข้อมูลวิ่งด้วย<b>อัตราส่งคงที่</b>และ<b>ความหน่วงการแพร่สัญญาณ (propagation delay) คงที่</b> — เหมาะกับเสียงพูดที่ต้องการจังหวะสม่ำเสมอ ขาดๆ หายๆ ไม่ได้</li>
          </ul>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — ตัวอย่างที่ทำให้เห็น "ข้อจำกัดร้ายแรง"</span>
          สมมติชุมสายมี <b>10 คู่สาย</b> แล้วมีคนโทรพร้อมกัน 10 คู่เต็มพอดี — <b>เครื่องที่ 11 โทรได้ไหม? ไม่ได้เลย</b> (เจอสัญญาณไม่ว่าง โดน "บล็อก" ทันที) · แต่ถ้าเป็น packet switching ล่ะ? เครื่องที่ 11 (หรือ 30) <b>ยังใช้งานได้</b> — ทุกคนแค่ช้าลงหน่อยเพราะแชร์กัน ไม่มีใครถูกปฏิเสธ · นี่คือความต่างเชิงปรัชญา: circuit = จองขาด ใครมาก่อนได้ ใครมาหลังอด / packet = แชร์กัน ทุกคนได้ แต่ความเร็วผันแปร</div>
        </Step>

        <!-- ============ 15. Packet switching ============ -->
        <Step kind="anim" icon="📦" title="Packet Switching — หั่นเป็นก้อน แชร์สาย store-and-forward" id="packet">
          <p><span class="term">Packet switching</span> ทำงานยังไง (สไลด์ "แพกเก็ตสวิตช์ทำงานอย่างไร") — ไล่ทีละประโยคของสไลด์แล้วขยาย:</p>
          <ul>
            <li>ข้อมูลถูกส่งเป็น<b>บล็อก (block)</b> เรียกว่า <b>แพ็กเก็ต (packet)</b> — ก่อนส่ง ข้อความทั้งก้อนถูก<b>แตกเป็นลำดับของแพ็กเก็ต</b></li>
            <li>ความยาวแพ็กเก็ตโดยปกติราว <b>1,000 octets (ไบต์)</b> — คำว่า octet = 8 บิต ก็คือไบต์ในบริบทเครือข่าย</li>
            <li>แต่ละแพ็กเก็ต = <b>ข้อมูลบางส่วน + แพ็กเก็ตเฮดเดอร์ (header)</b> ที่ใส่<b>ข้อมูลควบคุม</b>ไว้ข้างใน (ที่อยู่ปลายทาง เลขลำดับ ฯลฯ — จำเรื่อง encapsulation ได้ไหม นี่ไง)</li>
            <li>ที่<b>ทุกโหนดระหว่างทาง</b>: แพ็กเก็ตถูก<b>รับเข้ามา → เก็บชั่วคราว (store) → ส่งต่อ (forward)</b> ไปโหนดถัดไป — ท่านี้มีชื่อว่า <span class="term">store-and-forward</span> และอาจารย์เน้นว่ามันคือหัวใจของ packet switching</li>
          </ul>
          <div class="lab">
            <h4>🎬 Store-and-forward: 3 แพ็กเก็ตวิ่ง A → R1 → R2 → B</h4>
            <div class="netrow" id="netRow">
              <div class="snode">A</div><div class="slink"></div>
              <div class="snode">R1</div><div class="slink"></div>
              <div class="snode">R2</div><div class="slink"></div>
              <div class="snode">B</div>
            </div>
            <div class="enc-cap" id="swCap">กดส่งแล้วดูว่าแพ็กเก็ตหลายตัว "ไล่กัน" บนสายเดียวยังไง</div>
            <button class="btn" id="swRun">▶ ส่ง 3 แพ็กเก็ต</button>
          </div>
          <p><b>ข้อดีของแพ็กเก็ตสวิตช์</b> (สไลด์ 55) — สี่ข้อ พร้อมคำอธิบายว่าทำไมถึงจริง:</p>
          <ul>
            <li><b>ใช้สายมีประสิทธิภาพมากกว่า</b> — หลายแพ็กเก็ต (ของหลายคู่สนทนา) <b>แชร์ลิงก์ระหว่างโหนดร่วมกันได้</b> ช่วงที่เราเงียบ คนอื่นใช้สายต่อทันที ไม่มีความจุนอนเปล่าแบบ circuit</li>
            <li><b>แปลงอัตราการส่งได้ (data rate conversion)</b> — สถานีเร็วคุยกับสถานีช้าได้ เพราะโหนดกลางเก็บพักข้อมูลไว้ก่อน (store!) แล้วปล่อยตามความเร็วของฝั่งรับ</li>
            <li><b>traffic แน่นก็ไม่ปฏิเสธใคร</b> — circuit switching เจอสายเต็มคือ<b>บล็อกการโทร</b>เลย แต่ packet switching <b>ยังรับแพ็กเก็ตอยู่</b> แค่ความหน่วงในการส่งเพิ่มขึ้น (ระบบ "ช้าแต่ไม่ล่ม")</li>
            <li><b>ใช้ priority ได้</b> — โหนดจัดคิวได้ว่าแพ็กเก็ตประเภทไหนสำคัญให้ไปก่อน (เช่น เสียงสำคัญกว่าโหลดไฟล์)</li>
          </ul>
          <p><b>ข้อเสียของแพ็กเก็ตสวิตช์</b> (สไลด์ 56) — ของฟรีไม่มีในโลก แลกมากับ:</p>
          <ul>
            <li><b>ความหน่วงที่ทุกโหนด</b> — store-and-forward แปลว่าทุกโหนดต้อง "รับให้ครบก้อนก่อน" ค่อยส่งต่อ ผ่านกี่โหนดก็บวกความหน่วงเท่านั้นรอบ</li>
            <li><b>ความหน่วงรวมแปรผันได้มาก — jitter</b> — สาเหตุ: ขนาดแพ็กเก็ตไม่เท่ากัน + เส้นทางที่เลือกต่างกัน + คิวในแต่ละสวิตช์ยาวไม่เท่ากัน
              <span class="lect" style="display:block; margin-top:8px;"><span class="who">🎙 จากปากอาจารย์</span> เคยดู YouTube แล้ว<b>กระตุก</b>ไหม? นั่นแหละอาการของ jitter — แพ็กเก็ตวิดีโอมาถึงไม่สม่ำเสมอ บางก้อนมาช้าจนเฟรมต่อไม่ทัน ภาพเลยค้าง (ปัจจุบันเน็ตเร็วขึ้นเลยเจอน้อยลง แต่หลักการยังอยู่)</span></li>
            <li><b>เสียความจุให้ header</b> — ทุกแพ็กเก็ตต้องพกข้อมูลปลายทาง + การเรียงลำดับไปด้วย ยิ่งหั่นเยอะ ยิ่งแบก header เยอะ (เดี๋ยวเจอเต็มๆ ใน lab ขนาดแพ็กเก็ต)</li>
            <li><b>งานประมวลผลที่โหนดมากขึ้น</b> — ทุกโหนดต้องอ่าน header ตัดสินใจ จัดคิว ให้ทุกแพ็กเก็ต</li>
          </ul>
        </Step>

        <!-- ============ 16. Datagram vs VC ============ -->
        <Step kind="anim" icon="🛣️" title="สองสำนักของ Packet Switching: Datagram vs Virtual Circuit" id="dgvc">
          <p>ใน packet switching เอง ยังแบ่งเป็น 2 วิธีคิด ต่างกันที่คำถามเดียว: <b>"ใครเป็นคนเลือกเส้นทาง และเลือกเมื่อไหร่"</b> — เลื่อนกลับขึ้นไปกดปุ่ม 2 ปุ่มบนรูปเครือข่ายสวิตช์ (หัวข้อ 🕸️) เพื่อดูสองแบบนี้วิ่งจริงบนกราฟ แล้วกลับมาอ่านสรุปนี้:</p>
          <p><b>เดทาแกรม (Datagram)</b> — สไลด์ 57–58:</p>
          <ul>
            <li>แต่ละแพ็กเก็ตถูกดูแล<b>แยกกันโดยอิสระ</b> ไม่อ้างอิงแพ็กเก็ตก่อนหน้า (ต่างคนต่างเดินทาง)</li>
            <li><b>แต่ละโหนดเลือกโหนดถัดไป</b>ให้แพ็กเก็ตทุกตัวที่ผ่านมา — ตัดสินใจสดๆ ตามสภาพเครือข่ายตอนนั้น</li>
            <li>ผลคือแพ็กเก็ต<b>ไม่จำเป็นต้องเดินเส้นทางเดิม</b> และ<b>อาจถึงปลายทางไม่เรียงลำดับ</b></li>
            <li><b>โหนดขาออก/ปลายทางรับผิดชอบ</b>: รวบรวมเรียงลำดับกลับให้ถูก + <b>ตรวจจับแพ็กเก็ตที่หาย</b>และกู้คืน (ขอส่งซ้ำ)</li>
            <li><b>ข้อดี</b>: ไม่มีเฟส setup (ส่งก้อนแรกได้ทันที — ข้อความสั้นๆ ชนะเลย) · <b>ยืดหยุ่นกว่า</b> (โหนดไหนแออัด/ตายกลางทาง แพ็กเก็ตหลังเลี่ยงไปทางอื่นได้) · การส่งถึงปลายทางจึง<b>น่าเชื่อถือกว่า</b>ในแง่ที่ระบบล้มยาก</li>
          </ul>
          <p><b>วงจรเสมือน (Virtual Circuit — VC)</b> — สไลด์ 59–62:</p>
          <ul>
            <li><b>เส้นทางถูกวางแผนล่วงหน้า</b>ก่อนส่งแพ็กเก็ตจริง (ส่ง call request ไปจองเส้นทาง — "เสมือน" การสร้างวงจรของ circuit switching)</li>
            <li><b>ทุกแพ็กเก็ตของคู่สนทนานี้วิ่งตามเส้นทางเดิม</b> → โหนดไม่ต้องตัดสินใจเส้นทางต่อแพ็กเก็ตอีก (ตัดสินใจ<b>ครั้งเดียว</b>ตอนสร้างการเชื่อมต่อ) แค่เปิดตารางแล้วส่งต่อ</li>
            <li>จุดที่คนพลาดบ่อยและ<b>อาจารย์เน้นมาก</b>: มันเลียนแบบวงจรจริงแต่<b>ไม่ได้อุทิศเส้นทางให้</b> — แพ็กเก็ตยังต้องเข้าบัฟเฟอร์/เข้าคิวที่แต่ละโหนด และ<b>ลิงก์ยังถูกแชร์กับคู่อื่น</b>ได้ตลอด (อาจารย์ถามในห้อง: "เส้นทางที่จองแล้ว คนอื่นแชร์ได้ไหม? — ได้!") ต่างจาก circuit ที่จองความจุขาด</li>
            <li><b>ข้อดี</b> (สไลด์ 62): แพ็กเก็ตถึง<b>ตามลำดับ</b>ที่ส่ง · ถึง<b>อย่างถูกต้อง</b> · และ<b>ส่งได้เร็วกว่า</b> (per-packet) เพราะโหนดไม่ต้องเสียเวลาตัดสินใจเส้นทางทุกก้อน</li>
          </ul>
          <div class="lect"><span class="who">🎙 จากปากอาจารย์ — คำถามชี้เป็นชี้ตาย <span class="exam-badge">ระวังสอบ</span></span>
          "switching ทั้งหมดที่เห็นมา <b>ตัวไหนคืออินเทอร์เน็ตปัจจุบัน?</b> — ใครตอบ circuit switching <b>สอบตกเลยนะ</b>" 😅 คำตอบคือฝั่ง <b>packet switching: อินเทอร์เน็ต (IP) ทำงานแบบ datagram</b> เป็นหลัก (ส่วน virtual circuit คือแนวทางของเครือข่ายอย่าง X.25 ในยุคก่อน) — จำง่ายๆ: โทรศัพท์บ้าน = circuit · อินเทอร์เน็ต = datagram · X.25 = virtual circuit</div>
        </Step>

        <!-- ============ 17. Event timing ============ -->
        <Step kind="anim" icon="⏱️" title="เทียบเวลากันชัดๆ: ใครเร็วกว่า ตอนไหน (Event Timing)" id="timing">
          <p>สไลด์ "Event timing for circuit switching and packet switching" คือ<b>แผนภาพเวลา</b> (time-space diagram): แกนตั้ง = เวลา (ไหลลงล่าง) เส้นตั้ง 4 เส้น = สถานี A, โหนด 1, โหนด 2, สถานี B — แถบที่ลาดเอียงคือข้อมูลที่วิ่งอยู่บนลิงก์ (เอียงเพราะการเดินทางใช้เวลา = propagation delay) กดปุ่มสลับดูทั้ง 3 แบบ:</p>
          <div class="lab">
            <h4>⏱️ แผนภาพเวลา: กดเลือกแบบ</h4>
            <div class="btnrow">
              <button class="btn" data-timing="cs">Circuit switching</button>
              <button class="btn ghost" data-timing="vc">Virtual circuit</button>
              <button class="btn ghost" data-timing="dg">Datagram</button>
            </div>
            <canvas id="timingCanvas"></canvas>
            <div class="enc-cap" id="timingCap"></div>
          </div>
          <p>วิธีอ่านและสิ่งที่ควรสังเกต <span class="exam-badge">อาจารย์บอกว่าออกสอบแนว "รูปไหนคือแบบไหน"</span>:</p>
          <ul>
            <li><b>Circuit switching</b>: เห็นเส้นบางๆ ไป-กลับก่อน (ขอสร้างวงจร + ตอบรับ — มีแวะประมวลผลที่ทุกโหนด) จากนั้นข้อมูลจริง<b>ไหลยาวรวดเดียว</b>ทะลุถึงปลายทาง ไม่หยุดแวะที่โหนดอีก (วงจรต่อถึงกันแล้ว!)</li>
            <li><b>Virtual circuit</b>: มีไป-กลับตอนต้นเหมือนกัน (call request/accept — วางเส้นทาง) จากนั้นแพ็กเก็ต 1,2,3 วิ่งแบบ<b>บันได</b> (store-and-forward ทีละลิงก์) แต่ไล่ต่อเนื่องเป็นขบวน</li>
            <li><b>Datagram</b>: <b>ไม่มีไป-กลับตอนต้นเลย</b> — โยนแพ็กเก็ตแรกได้ทันที! แต่ทุกโหนดมีจังหวะ "คิดเส้นทาง" สั้นๆ ก่อนส่งต่อทุกก้อน</li>
            <li>ใครชนะ? <b>ขึ้นกับงาน</b>: ข้อความสั้นๆ ครั้งเดียว → datagram จบก่อน (ไม่เสียค่า setup) · คุยยาวต่อเนื่อง → circuit/VC คุ้มค่า setup เพราะหลังจากนั้นไหลลื่น — ไม่มีคำตอบเดียวที่ถูกตลอด นี่คือ trade-off จริงๆ ของวิศวกรรม</li>
          </ul>
        </Step>

        <!-- ============ 18. ขนาดแพ็กเก็ต ============ -->
        <Step kind="deep" icon="📐" title="ขนาดแพ็กเก็ต: ทำไม 'ยิ่งเล็กยิ่งดี' ถึงผิด (Lab เลื่อนเล่นได้)" id="psize">
          <p>คำถามวิศวกรรมข้อสุดท้ายของคาบ: หั่นข้อความเป็นแพ็กเก็ต <b>ควรหั่นเล็กแค่ไหน?</b> สไลด์ 64–66 (fig 3.9) ตอบด้วยตัวอย่างตัวเลขจริง ซึ่งอาจารย์เดินสดในห้องด้วย: ข้อความ <b>40 ไบต์</b> ส่งจาก X ไป Y ผ่านโหนด a, b (= 3 ลิงก์) โดย<b>ทุกแพ็กเก็ตต้องพก header 3 ไบต์</b>:</p>
          <div class="lab">
            <h4>🧪 Lab: เลื่อนเลือกจำนวนแพ็กเก็ต แล้วดูเวลารวม</h4>
            <div class="row">
              <label>แบ่งข้อความ 40 ไบต์ เป็น&nbsp;
                <select id="psCount">
                  <option value="1">1 แพ็กเก็ต (ก้อนเดียว 40 ไบต์)</option>
                  <option value="2">2 แพ็กเก็ต (ก้อนละ 20 ไบต์)</option>
                  <option value="4">4 แพ็กเก็ต (ก้อนละ 10 ไบต์)</option>
                  <option value="5" selected>5 แพ็กเก็ต (ก้อนละ 8 ไบต์)</option>
                  <option value="8">8 แพ็กเก็ต (ก้อนละ 5 ไบต์)</option>
                  <option value="10">10 แพ็กเก็ต (ก้อนละ 4 ไบต์)</option>
                  <option value="20">20 แพ็กเก็ต (ก้อนละ 2 ไบต์)</option>
                </select>
              </label>
            </div>
            <canvas id="psCanvas"></canvas>
            <div class="enc-cap" id="psOut"></div>
          </div>
          <p>ไล่ตามตัวเลขของสไลด์ (หน่วย "เวลา-ไบต์" = เวลาที่ใช้ส่ง 1 ไบต์บน 1 ลิงก์):</p>
          <table class="tbl">
            <thead><tr><th>รูป 3.9</th><th>แบ่งเป็น</th><th>ขนาด/แพ็กเก็ต</th><th>เวลารวม</th><th>เกิดอะไรขึ้น</th></tr></thead>
            <tbody>
              <tr><td>a</td><td>1 ก้อน</td><td>40+3 = 43</td><td><b>129</b></td><td>แต่ละลิงก์ต้องรอรับ "ทั้งก้อน" ก่อนส่งต่อ — ไม่มีการทำงานซ้อนกันเลย</td></tr>
              <tr><td>b</td><td>2 ก้อน</td><td>20+3 = 23</td><td><b>92</b></td><td>เริ่มเกิด <b>pipelining</b>: ลิงก์ถัดไปส่งก้อนแรก พร้อมๆ กับลิงก์แรกส่งก้อนสอง</td></tr>
              <tr><td>c</td><td>5 ก้อน</td><td>8+3 = 11</td><td><b>77</b> 🏆</td><td>ซ้อนกันได้เต็มที่ — เร็วสุดในตัวอย่างนี้</td></tr>
              <tr><td>d</td><td>10 ก้อน</td><td>4+3 = 7</td><td><b>84</b></td><td>เล็กเกินไป! <b>header 3 ไบต์ต่อก้อนเริ่มท่วม</b> (ข้อมูลจริง 4 ไบต์ แบก header 3 ไบต์ = แบกภาษี 43%) เวลากลับ<b>เพิ่มขึ้น</b></td></tr>
            </tbody>
          </table>
          <p>เหตุผลเบื้องหลังสองแรงดึง:</p>
          <ul>
            <li><b>แรงที่อยากให้เล็ก</b>: ก้อนเล็ก → ลิงก์ถัดไปเริ่มงานได้เร็ว → การส่ง<b>ซ้อนขนานกัน (pipelining)</b> มากขึ้น เวลารวมลด (สไลด์: "การแตกแพ็กเก็ตช่วยให้เวลาส่งลดลง เพราะส่งได้พร้อมกับรับ")</li>
            <li><b>แรงที่อยากให้ใหญ่</b>: ทุกก้อนจ่าย "ภาษี header คงที่" — ยิ่งหั่นเยอะ จำนวน header ยิ่งเยอะตาม สัดส่วนข้อมูลจริงยิ่งหด</li>
          </ul>
          <div class="note"><b>สรุปของสไลด์ + คำเตือนของอาจารย์ <span class="exam-badge">ระวังสอบ</span>:</b> ขนาดแพ็กเก็ตต้อง<b>พอเหมาะ</b> — ไม่ใหญ่เกินไป และ<b>ไม่เล็กเกินไป</b> · อาจารย์ย้ำในห้องว่า "เวลาเจอคำถาม อย่าตอบว่ายิ่งเล็กยิ่งดีนะครับ" เพราะกราฟมันเป็นรูปตัว U — มีจุดต่ำสุดตรงกลาง ไม่ใช่ไถลลงเรื่อยๆ</div>
          <p><span class="plus">เสริมจากผู้เขียน</span> ของจริงบนโลก: Ethernet กำหนดขนาดเฟรมสูงสุด (MTU) ราว 1,500 ไบต์ — ก็คือคำตอบเชิงวิศวกรรมของโจทย์ "พอเหมาะ" ข้อนี้ที่ทั้งอุตสาหกรรมตกลงกัน</p>
        </Step>

        <!-- ============ 19. การบ้านอาจารย์ ============ -->
        <Step kind="check" icon="📝" title="การบ้านท้ายคาบของอาจารย์: เติมตารางเทียบ CS / Datagram / VC เอง!" id="hw">
          <p>สไลด์สุดท้ายของอาจารย์ (สไลด์ 68) คือตารางเปรียบเทียบที่<b>จงใจเว้นว่างไว้</b> แล้วสั่งท้ายคาบว่า <i>"ลองตอบดูก่อน ลองเขียนดูครับ เดี๋ยวสัปดาห์หน้าอธิบาย"</i> — เพราะฉะนั้นห้ามเปิดเฉลยก่อนทำ! กดที่ช่องเพื่อวนตัวเลือก ครบแล้วกดตรวจ:</p>
          <div class="lab">
            <h4>📝 กดช่องเพื่อเปลี่ยนคำตอบ → ครบแล้วกด "ตรวจคำตอบ"</h4>
            <table class="tbl" id="cmpTable">
              <thead><tr><th style="text-align:left">หัวข้อ</th><th>Circuit<br/>Switching</th><th>Datagram<br/>PS</th><th>Virtual Circuit<br/>PS</th></tr></thead>
              <tbody></tbody>
            </table>
            <div class="btnrow">
              <button class="btn" id="cmpCheck">✓ ตรวจคำตอบ</button>
              <button class="btn ghost" id="cmpReset">↺ ล้างตาราง</button>
            </div>
            <div class="enc-cap" id="cmpOut"></div>
          </div>
          <p class="why">ตารางนี้คือบทสรุปของครึ่งคาบหลังทั้งหมดในหน้าเดียว — ถ้าเติมได้หมดโดยไม่เปิดตำรา แปลว่าเรื่อง switching อยู่ในมือแล้ว และตามที่อาจารย์บอก: ทำวันนี้ สัปดาห์หน้าฟังเฉลยในห้องแล้วเช็กกัน</p>
        </Step>

        <!-- ============ 20. เช็กเข้าใจ ============ -->
        <Step kind="check" icon="✅" title="เช็กว่าเข้าใจจริง (ตอบแบบสอนคนอื่นได้)" id="check">
          <p>ลองตอบโดย<b>พูดออกเสียงเหมือนกำลังสอนเพื่อน</b> — ถ้าติดขัดตรงไหน กลับขึ้นไปอ่านหัวข้อนั้น:</p>
          <div class="q">
            <div class="qh">1) ทำไมเครือข่ายต้องแบ่งเป็นชั้น (layer)? ให้เหตุผลอย่างน้อย 2 ข้อพร้อมตัวอย่าง</div>
            <details class="sol"><summary>เฉลย</summary><div class="body">(1) แยกหน้าที่ให้แก้/เปลี่ยนแต่ละชั้นได้อิสระ — เปลี่ยนจากสายแลนเป็น WiFi กระทบแค่ชั้นล่าง แอปข้างบนไม่ต้องรู้ (2) เป็นกติกากลางให้อุปกรณ์ต่างยี่ห้อ/ต่างระบบทำงานร่วมกันได้ — ขอแค่แต่ละชั้นทำตามสัญญาของชั้นตัวเอง (3) โบนัส: ออกแบบ/ดีบั๊ก/สอนต่อได้ง่าย เพราะแต่ละชั้นเล็กและชัด</div></details>
          </div>
          <div class="q">
            <div class="qh">2) Router, Switch, Bridge — ใครทำงานชั้นไหน และ "เห็น" ข้อมูลลึกแค่ไหน?</div>
            <details class="sol"><summary>เฉลย</summary><div class="body">Router = ชั้น 3 (Network/Internet) เปิดอ่านถึงหัว IP เพื่อหาเส้นทางข้ามเครือข่าย · Bridge = ชั้น 2 (Data link) ดูแค่ที่อยู่ระดับลิงก์ ทำตัวเป็นตัวกรองที่อยู่เชื่อม LAN สองวง · Switch = ตัวแทนยุคใหม่ของ bridge ทำงานชั้น 2 เหมือนกัน (อาจารย์: ปัจจุบันโพรโทคอลเหลือ IP ตัวเดียว บทบาท bridge เลยกลายเป็น switch) · ไม่มีใครในสามตัวนี้แตะ TCP/ข้อมูลผู้ใช้เลย</div></details>
          </div>
          <div class="q">
            <div class="qh">3) TCP ให้บริการ "น่าเชื่อถือ" หมายถึงอะไรบ้าง? แล้ว UDP ต่างยังไง?</div>
            <details class="sol"><summary>เฉลย</summary><div class="body">น่าเชื่อถือ = (1) ครบและถูกต้อง — ส่ง 3 ก้อนถึงแค่ 2 ต้องรู้และขอส่งซ้ำ (TCP เก็บสำเนาไว้เพื่อการนี้) (2) เรียงลำดับ — ถึงเป็น 3,1,2 ต้องเรียงเป็น 1,2,3 ก่อนส่งขึ้นชั้นบน · UDP ไม่มีบริการทั้งสองอย่าง (unreliable) แลกกับความเร็ว/ความเบา เหมาะกับสตรีมสด/เกมที่ช้าไม่ได้แต่หายนิดหน่อยได้</div></details>
          </div>
          <div class="q">
            <div class="qh">4) MAC address, IP address, port — สามตัวนี้ตอบคำถามคนละข้อยังไง? ทำไมมีตัวเดียวไม่พอ?</div>
            <details class="sol"><summary>เฉลย</summary><div class="body">MAC (ชั้น 2) = เครื่องไหนในวงเดียวกัน (hop ถัดไป) · IP (ชั้น 3) = เครื่องไหนในโลก (ปลายทางสุดท้าย) · port (ชั้น 4) = แอปไหนในเครื่องนั้น · มีตัวเดียวไม่พอเพราะโจทย์ซ้อนกันสามระดับ: นำทางข้ามโลกต้องใช้ IP, ส่งต่อในวงใช้ MAC, ถึงเครื่องแล้วต้องแยกว่าให้โปรแกรมไหนด้วย port</div></details>
          </div>
          <div class="q">
            <div class="qh">5) ทำไม circuit switching ใช้สาย "ไม่ถึง 100%"? แล้วเหตุการณ์ "โทรไม่ติดเพราะสายเต็ม" สะท้อนข้อจำกัดอะไร?</div>
            <details class="sol"><summary>เฉลย</summary><div class="body">เพราะความจุถูกอุทิศให้คู่สนทนาตลอดการเชื่อมต่อ — ช่วงเงียบ/ช่วงฟังก็ไม่มีใครใช้แทนได้ = นอนเปล่า · "10 คู่สายเต็ม เครื่องที่ 11 โทรไม่ได้" คือ call blocking: ระบบจองขาดรับได้จำกัดเป๊ะๆ เกินแล้วปฏิเสธเลย ต่างจาก packet switching ที่รับทุกคนแต่ช้าลง (แชร์กัน)</div></details>
          </div>
          <div class="q">
            <div class="qh">6) Datagram กับ Virtual Circuit ตัดสินใจเส้นทาง "ต่างกันตรงไหน" และผลที่ตามมาคืออะไร?</div>
            <details class="sol"><summary>เฉลย</summary><div class="body">Datagram: ทุกโหนดตัดสินใจใหม่ให้ทุกแพ็กเก็ต → เส้นทางต่างกันได้ ถึงไม่เรียง (ปลายทางเรียงใหม่) แต่ไม่ต้อง setup + ยืดหยุ่นเลี่ยงโหนดพังได้ · VC: ตัดสินใจครั้งเดียวตอนสร้าง connection → ทุกแพ็กเก็ตตามเส้นเดิม ถึงเรียง ส่งต่อไวกว่า แต่ต้องเสียเวลา setup ก่อน · ระวัง: VC ไม่ได้จองความจุแบบ circuit — ลิงก์ยังแชร์กับคู่อื่นได้</div></details>
          </div>
          <div class="q">
            <div class="qh">7) <span class="exam-badge">แนวสอบ</span> อินเทอร์เน็ตปัจจุบันใช้ switching แบบไหน? และทำไมแพ็กเก็ต "ยิ่งเล็กยิ่งดี" ถึงผิด?</div>
            <details class="sol"><summary>เฉลย</summary><div class="body">อินเทอร์เน็ต (IP) = packet switching แบบ datagram (ห้ามตอบ circuit switching — อาจารย์บอกว่าตอบแบบนั้นคือตกเลย 😅) · แพ็กเก็ตเล็กช่วยให้ pipelining ซ้อนงานได้ก็จริง แต่ทุกก้อนแบก header คงที่ — เล็กเกินไป ภาษี header ท่วมจนเวลารวมกลับเพิ่ม (ตัวอย่างสไลด์: 5 ก้อน = 77 ดีสุด แต่ 10 ก้อน = 84 แย่ลง) ขนาดที่ถูกคือ "พอเหมาะ" ตรงจุดต่ำสุดของกราฟตัว U</div></details>
          </div>
        </Step>

        <!-- ============ 21. สรุป ============ -->
        <Step kind="intu" icon="🧾" title="สรุป Week 2 (แผ่นเดียว)" id="summary">
          <div class="formula">องค์ประกอบสื่อสาร 5: ผู้ส่ง · ผู้รับ · ข้อมูล · สื่อ · โพรโทคอล
โพรโทคอล = Syntax (รูปแบบ) + Semantics (ความหมาย/คุม error) + Timing (แม็ตช์ความเร็ว+เรียงลำดับ)
TCP/IP 5 ชั้น: Application → Transport(TCP·ครบ/ถูก/เรียง, UDP·เร็วแต่ไม่การันตี)
              → Internet(IP·หาเส้นทาง) → Network Access → Physical
ส่ง = ห่อ header ลงทีละชั้น (encapsulation) · รับ = แกะขึ้น (decapsulation) · ก้อนข้อมูล = PDU
Router แกะถึงแค่ IP (ชั้น 3) แล้วห่อเฟรมใหม่ตามเครือข่ายขาออก · Switch/Bridge = ชั้น 2
ที่อยู่: MAC (เครื่องในวง·ชั้น2) · IP (เครื่องในโลก·ชั้น3) · port (แอปในเครื่อง·ชั้น4)
OSI 7 ชั้น = framework ทฤษฎี (Session+Presentation ถูกยุบเข้า App ใน TCP/IP)
TCP/IP ชนะเพราะ: เกิดก่อน-ใช้จริงก่อน + ชั้นน้อยกว่า = header น้อยกว่า
เครือข่าย: LAN (ตึก·เจ้าของเดียว·เร็ว) · MAN (เมือง) · WAN (ประเทศ·เช่า carrier·switching nodes)
สวิตช์: สถานีต่อผ่านโหนดเสมอ · โหนด-โหนดแชร์สายด้วย FDM (แบ่งความถี่) / TDM (แบ่งเวลา)
Circuit switching: 3 เฟส (สร้างวงจร→ส่ง→ปลด) · จองขาด·ใช้ไม่ถึง100%·เต็มแล้วบล็อก·delay คงที่
Packet switching: หั่นก้อน~1000 octets + header · store-and-forward · แชร์สาย·ไม่บล็อกแค่ช้าลง·มี jitter
  ├ Datagram: เลือกทางทุกก้อน · ไม่เรียง · ไม่มี setup · ยืดหยุ่น = อินเทอร์เน็ต (IP)
  └ Virtual Circuit: วางทางครั้งเดียว · เรียงเป๊ะ · เร็วต่อก้อน · ยังแชร์สาย = X.25
